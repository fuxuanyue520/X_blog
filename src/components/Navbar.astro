---
import { Icon } from "astro-icon/components";

const authToastParam = Astro.url.searchParams.get("auth") ?? "";
const pwdErrCode = Astro.url.searchParams.get("pwdErr") ?? "";

const loginLogoutCopy: Record<string, { title: string; message: string }> = {
	login: {
		title: "登录成功",
		message: "欢迎回来，已登录管理员账号。",
	},
	logout: {
		title: "已退出登录",
		message: "你已安全退出，可随时再次登录。",
	},
};

const passwordErrCopy: Record<string, { title: string; message: string }> = {
	session: {
		title: "未登录",
		message: "登录已失效，请重新登录后再修改密码。",
	},
	fields: {
		title: "校验失败",
		message: "请填写当前密码、新密码与确认密码。",
	},
	mismatch: {
		title: "校验失败",
		message: "两次输入的新密码不一致。",
	},
	short: {
		title: "校验失败",
		message: "新密码至少需要 8 位字符。",
	},
	long: {
		title: "校验失败",
		message: "新密码过长，请缩短后再试。",
	},
	same: {
		title: "校验失败",
		message: "新密码不能与当前密码相同。",
	},
	current: {
		title: "密码错误",
		message: "当前密码不正确。",
	},
	user: {
		title: "修改失败",
		message: "账户不存在或无法保存。",
	},
	credential: {
		title: "修改失败",
		message: "账户凭据异常，无法校验当前密码。",
	},
	server: {
		title: "修改失败",
		message: "服务器繁忙，请稍后重试。",
	},
};

function resolveAuthToast(): {
	title: string;
	message: string;
	variant: "success" | "error";
} | null {
	if (authToastParam === "login" || authToastParam === "logout") {
		const copy = loginLogoutCopy[authToastParam];
		return copy ? { ...copy, variant: "success" as const } : null;
	}
	if (authToastParam === "password_ok") {
		return {
			title: "修改成功",
			message: "密码已更新，请使用新密码登录。",
			variant: "success",
		};
	}
	if (authToastParam === "password_err") {
		const copy = passwordErrCopy[pwdErrCode] ?? {
			title: "修改失败",
			message: "请稍后重试。",
		};
		return { ...copy, variant: "error" as const };
	}
	return null;
}

const authToastResolved = resolveAuthToast();

const currentUrl = new URL(Astro.url);
currentUrl.searchParams.delete("login");
currentUrl.searchParams.delete("error");
currentUrl.searchParams.delete("auth");
currentUrl.searchParams.delete("pwdErr");
const currentPathWithSearch = `${currentUrl.pathname}${currentUrl.search}`;
const logoutRedirectTo = Astro.url.pathname.startsWith("/admin")
	? "/"
	: currentPathWithSearch;
const errorMessages: Record<string, string> = {
	missing_fields: "请输入用户名和密码。",
	user_not_found: "用户名不存在。",
	wrong_password: "密码错误。",
	invalid_credentials: "用户名或密码错误。",
};
const errorCode = Astro.url.searchParams.get("error") ?? "";
const errorMessage = errorMessages[errorCode] ?? "";
const shouldOpenLoginModal =
	Astro.url.searchParams.get("login") === "1" || Boolean(errorMessage);
---

<nav
	class="fixed top-0 left-0 w-full h-16 lg:h-20 bg-dark-900/80 backdrop-blur-xl z-50 border-b border-white/5 transition-all duration-300"
	transition:persist
>
	<div
		class="max-w-[1600px] mx-auto h-full px-4 md:px-6 lg:px-8 flex items-center justify-between"
	>
		<div class="flex items-center gap-8 lg:gap-10">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-3 group">
				<div
					class="w-10 h-10 lg:w-12 lg:h-12 rounded-full overflow-hidden border-2 border-primary-500/50 group-hover:border-primary-500 group-hover:shadow-[0_0_15px_rgba(6,182,212,0.4)] transition-all duration-300"
				>
					<img
						src="/avatar.jpg"
						alt="Logo"
						class="w-full h-full object-cover"
					/>
				</div>
				<span
					class="text-xl lg:text-2xl font-serif font-bold text-gray-100 group-hover:text-primary-500 transition-colors tracking-wide"
					>秋兰以为佩</span
				>
			</a>

			<!-- Desktop Menu (Left Aligned) -->
			<div class="hidden md:flex items-center gap-6 lg:gap-8">
				<a
					href="/"
					class="text-base lg:text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-2 relative group"
				>
					<Icon name="ri:home-4-line" class="text-xl lg:text-2xl" />
					<span>主页</span>
					<span
						class="absolute -bottom-1.5 left-0 w-0 h-0.5 bg-primary-500 transition-all group-hover:w-full"
					></span>
				</a>
				<a
					href="/awards"
					class="text-base lg:text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-2 relative group"
				>
					<Icon name="ri:image-2-line" class="text-xl lg:text-2xl" />
					<span>荣誉墙</span>
					<span
						class="absolute -bottom-1.5 left-0 w-0 h-0.5 bg-primary-500 transition-all group-hover:w-full"
					></span>
				</a>
				<a
					href="/archive"
					class="text-base lg:text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-2 relative group"
				>
					<Icon name="ri:archive-line" class="text-xl lg:text-2xl" />
					<span>归档</span>
					<span
						class="absolute -bottom-1.5 left-0 w-0 h-0.5 bg-primary-500 transition-all group-hover:w-full"
					></span>
				</a>
				<a
					href="/about"
					class="text-base lg:text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-2 relative group"
				>
					<Icon name="ri:user-smile-line" class="text-xl lg:text-2xl" />
					<span>关于</span>
					<span
						class="absolute -bottom-1.5 left-0 w-0 h-0.5 bg-primary-500 transition-all group-hover:w-full"
					></span>
				</a>
				<a
					href="/admin/documents"
					class="hidden text-base lg:text-lg font-medium text-primary-300 hover:text-primary-200 transition-colors items-center gap-2 relative group"
					data-auth-admin-link-desktop
				>
					<Icon name="ri:shield-user-line" class="text-xl lg:text-2xl" />
					<span>管理</span>
					<span
						class="absolute -bottom-1.5 left-0 w-0 h-0.5 bg-primary-500 transition-all group-hover:w-full"
					></span>
				</a>
			</div>
		</div>

		<div class="flex items-center gap-3">
			<div class="hidden md:block">
				<button
					type="button"
					class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-dark-800/80 px-4 py-2 text-sm font-medium text-gray-200 transition-all hover:border-primary-400 hover:text-primary-300 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
					data-open-login-modal
					data-auth-guest
					aria-label="打开登录弹窗"
				>
					<Icon name="ri:user-shared-line" class="text-lg" />
					<span>登录</span>
				</button>

				<form
					method="POST"
					action="/api/admin/logout"
					class="hidden"
					data-auth-logout-desktop
				>
					<input type="hidden" name="redirectTo" value={logoutRedirectTo} />
					<button
						type="submit"
						class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-dark-800/80 px-4 py-2 text-sm font-medium text-gray-200 transition-all hover:border-primary-400 hover:text-primary-300 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						aria-label="退出登录"
					>
						<Icon name="ri:logout-box-r-line" class="text-lg" />
						<span>退出</span>
					</button>
				</form>
			</div>

			<button
				id="mobile-menu-btn"
				type="button"
				class="md:hidden text-gray-300 hover:text-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/20 p-1 rounded-lg transition-all"
				aria-label="打开菜单"
			>
				<Icon name="ri:menu-4-line" class="text-2xl" id="menu-icon-open" />
				<Icon
					name="ri:close-line"
					class="text-2xl hidden"
					id="menu-icon-close"
				/>
			</button>
		</div>
	</div>

	<!-- Mobile Menu Dropdown -->
	<div
		id="mobile-menu"
		class="fixed top-16 left-0 w-full bg-dark-900/95 backdrop-blur-xl border-b border-white/5 shadow-2xl transform -translate-y-[150%] transition-transform duration-300 md:hidden flex flex-col items-center py-6 gap-6 z-40"
	>
		<a
			href="/"
			class="text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-3 w-full justify-center py-2 active:bg-white/5"
		>
			<Icon name="ri:home-4-line" class="text-xl" />
			<span>主页</span>
		</a>
		<a
			href="/archive"
			class="text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-3 w-full justify-center py-2 active:bg-white/5"
		>
			<Icon name="ri:archive-line" class="text-xl" />
			<span>归档</span>
		</a>
		<a
			href="/awards"
			class="text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-3 w-full justify-center py-2 active:bg-white/5"
		>
			<Icon name="ri:image-2-line" class="text-xl" />
			<span>荣誉墙</span>
		</a>
		<a
			href="/about"
			class="text-lg font-medium text-gray-300 hover:text-primary-400 transition-colors flex items-center gap-3 w-full justify-center py-2 active:bg-white/5"
		>
			<Icon name="ri:user-smile-line" class="text-xl" />
			<span>关于</span>
		</a>
		<button
			type="button"
			class="flex w-full items-center justify-center gap-3 rounded-xl border border-white/10 bg-dark-800/80 px-4 py-3 text-lg font-medium text-gray-300 transition-all hover:border-primary-400 hover:text-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
			data-open-login-modal
			data-auth-guest
			aria-label="打开登录弹窗"
		>
			<Icon name="ri:user-shared-line" class="text-xl" />
			<span>登录</span>
		</button>
		<a
			href="/admin/documents"
			class="hidden text-lg font-medium text-primary-300 hover:text-primary-200 transition-colors items-center gap-3 w-full justify-center py-2 active:bg-white/5"
			data-auth-admin-link
		>
			<Icon name="ri:shield-user-line" class="text-xl" />
			<span>管理</span>
		</a>
		<form
			method="POST"
			action="/api/admin/logout"
			class="hidden w-full px-6"
			data-auth-admin-form
		>
			<input type="hidden" name="redirectTo" value={logoutRedirectTo} />
			<button
				type="submit"
				class="flex w-full items-center justify-center gap-3 rounded-xl border border-white/10 bg-dark-800/80 px-4 py-3 text-lg font-medium text-gray-300 transition hover:border-primary-400 hover:text-primary-400"
			>
				<Icon name="ri:logout-box-r-line" class="text-xl" />
				<span>退出登录</span>
			</button>
		</form>
	</div>
</nav>

{
	authToastResolved && (
		<div
			hidden
			data-auth-toast-source
			data-auth-toast-variant={authToastResolved.variant}
			data-auth-toast-title={authToastResolved.title}
			data-auth-toast-duration={
				authToastResolved.variant === "error" ? "4000" : "3200"
			}
		>
			{authToastResolved.message}
		</div>
	)
}

<div
	id="login-modal"
	data-open={shouldOpenLoginModal ? "true" : "false"}
	class:list={[
		"fixed inset-0 z-[70] flex items-center justify-center p-4",
		{ hidden: !shouldOpenLoginModal },
	]}
>
	<button
		type="button"
		class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
		data-close-login-modal
		aria-label="关闭登录弹窗"
	>
	</button>

	<div
		class="relative z-10 w-full max-w-md rounded-3xl border border-white/10 bg-dark-800/95 p-8 shadow-2xl shadow-black/40"
	>
		<button
			type="button"
			class="absolute right-4 top-4 rounded-full p-2 text-gray-400 transition hover:bg-white/5 hover:text-white"
			data-close-login-modal
			aria-label="关闭"
		>
			<Icon name="ri:close-line" class="text-xl" />
		</button>

		<div class="mb-8 text-center">
			<p class="mb-3 text-sm uppercase tracking-[0.35em] text-primary-400">
				Admin
			</p>
			<h2 class="text-3xl font-bold text-white">管理员登录</h2>
			<p class="mt-3 text-sm text-gray-400">
				输入用户名和密码后即可获得后台管理权限。
			</p>
		</div>

		<div
			id="login-error-message"
			class="mb-6 rounded-2xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm text-red-200 hidden"
		>
		</div>

		<form id="login-form" class="space-y-5" onsubmit="return false;">
			<input type="hidden" name="redirectTo" value={currentPathWithSearch} />

			<div>
				<label
					for="nav-login-username"
					class="mb-2 block text-sm font-medium text-gray-200"
				>
					用户名
				</label>
				<input
					id="nav-login-username"
					name="username"
					type="text"
					autocomplete="username"
					required
					class="w-full rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-3 text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
					placeholder="请输入管理员用户名"
				/>
			</div>

			<div>
				<label
					for="nav-login-password"
					class="mb-2 block text-sm font-medium text-gray-200"
				>
					密码
				</label>
				<div class="relative">
					<input
						id="nav-login-password"
						name="password"
						type="password"
						autocomplete="current-password"
						required
						class="w-full rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-3 pr-12 text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
						placeholder="请输入密码"
					/>
					<button
						type="button"
						id="toggle-password-btn"
						class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-300 transition-colors"
						aria-label="切换密码可见性"
					>
						<Icon
							name="ri:eye-line"
							class="text-xl"
							id="toggle-password-icon"
						/>
					</button>
				</div>
			</div>

			<button
				type="button"
				id="login-submit-btn"
				class="w-full rounded-2xl bg-primary-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-600 disabled:opacity-50 disabled:cursor-not-allowed"
			>
				登录
			</button>
		</form>
	</div>
</div>

<style>
	/* 与后台文档/荣誉一致的全局通知条（登录/退出反馈） */
	:global(.notification-stack) {
		position: fixed;
		top: 5rem;
		right: 1rem;
		z-index: 260;
		display: flex;
		width: min(calc(100vw - 2rem), 24rem);
		flex-direction: column;
		gap: 0.85rem;
		pointer-events: none;
	}

	@media (min-width: 768px) {
		:global(.notification-stack) {
			top: 6rem;
		}
	}

	:global(.notification) {
		position: relative;
		overflow: hidden;
		border-radius: 1.15rem;
		border: 1px solid rgb(255 255 255 / 0.12);
		padding: 1rem 1rem 0.95rem;
		box-shadow:
			0 20px 45px rgb(2 6 23 / 0.28),
			0 8px 18px rgb(15 23 42 / 0.18);
		backdrop-filter: blur(14px);
		pointer-events: auto;
		opacity: 0;
		transform: translate3d(0, -14px, 0) scale(0.96);
	}

	:global(.notification.is-entering) {
		animation: navbar-notification-in 0.38s cubic-bezier(0.2, 0.8, 0.2, 1)
			forwards;
	}

	:global(.notification.is-leaving) {
		animation: navbar-notification-out 0.28s ease forwards;
	}

	:global(.notification--success) {
		background:
			radial-gradient(
				circle at top right,
				rgb(74 222 128 / 0.22),
				transparent 42%
			),
			linear-gradient(180deg, rgb(22 101 52 / 0.96), rgb(20 83 45 / 0.96));
		color: rgb(240 253 244);
	}

	/* 与账户后台 AdminNotificationStyles 一致：错误通知此前仅账户页有样式，其它页几乎看不见 */
	:global(.notification--error) {
		background:
			radial-gradient(
				circle at top right,
				rgb(248 113 113 / 0.22),
				transparent 42%
			),
			linear-gradient(180deg, rgb(153 27 27 / 0.96), rgb(127 29 29 / 0.96));
		color: rgb(254 242 242);
	}

	:global(.notification__glow) {
		position: absolute;
		inset: -35% auto auto 68%;
		height: 7rem;
		width: 7rem;
		border-radius: 9999px;
		background: rgb(255 255 255 / 0.12);
		filter: blur(18px);
		pointer-events: none;
	}

	:global(.notification__row) {
		position: relative;
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
	}

	:global(.notification__icon) {
		display: inline-flex;
		height: 2.25rem;
		width: 2.25rem;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		border: 1px solid rgb(255 255 255 / 0.15);
		background: rgb(255 255 255 / 0.1);
		box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.12);
	}

	:global(.notification__icon svg) {
		height: 1.1rem;
		width: 1.1rem;
	}

	:global(.notification__content) {
		min-width: 0;
		flex: 1;
	}

	:global(.notification__title) {
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	:global(.notification__message) {
		margin-top: 0.25rem;
		font-size: 0.875rem;
		line-height: 1.55;
		color: rgb(255 255 255 / 0.9);
		word-break: break-word;
	}

	:global(.notification__close) {
		display: inline-flex;
		height: 2rem;
		width: 2rem;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border: 0;
		border-radius: 9999px;
		background: rgb(255 255 255 / 0.08);
		color: inherit;
		cursor: pointer;
		transition:
			background-color 0.18s ease,
			transform 0.18s ease;
	}

	:global(.notification__close:hover) {
		background: rgb(255 255 255 / 0.16);
		transform: scale(1.04);
	}

	:global(.notification__progress) {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 3px;
		background: rgb(255 255 255 / 0.18);
		transform-origin: left center;
		animation: navbar-notification-progress linear forwards;
		animation-duration: var(--toast-duration, 3000ms);
	}

	@keyframes navbar-notification-in {
		0% {
			opacity: 0;
			transform: translate3d(0, -14px, 0) scale(0.96);
		}
		65% {
			opacity: 1;
			transform: translate3d(0, 4px, 0) scale(1.01);
		}
		100% {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}
	}

	@keyframes navbar-notification-out {
		0% {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}
		100% {
			opacity: 0;
			transform: translate3d(0, -10px, 0) scale(0.97);
		}
	}

	@keyframes navbar-notification-progress {
		from {
			transform: scaleX(1);
		}
		to {
			transform: scaleX(0);
		}
	}
</style>

<script>
	import { mountAccountChangePasswordForm } from "@/scripts/account-change-password";

	function initNavbarAuthToast() {
		const ensureStack = () => {
			const existing = document.getElementById("notification-stack");
			if (existing instanceof HTMLElement) {
				return existing;
			}

			const stack = document.createElement("div");
			stack.id = "notification-stack";
			stack.className = "notification-stack";
			stack.setAttribute("aria-live", "polite");
			stack.setAttribute("aria-atomic", "false");
			document.body.appendChild(stack);
			return stack;
		};

		const removeToast = (toast: HTMLElement): void => {
			if (!(toast instanceof HTMLElement) || toast.dataset.leaving === "true") {
				return;
			}

			toast.dataset.leaving = "true";
			toast.classList.remove("is-entering");
			toast.classList.add("is-leaving");
			window.setTimeout(() => {
				toast.remove();
			}, 300);
		};

		interface NavbarToastOptions {
			message: string;
			variant?: "success" | "error";
			title?: string;
			duration?: number;
		}

		const showToast = ({
			message,
			variant = "success",
			title,
			duration = 3000,
		}: NavbarToastOptions): HTMLElement | undefined => {
			if (!message) {
				return;
			}

			const stack = ensureStack();
			const toast = document.createElement("section");
			const resolvedTitle =
				title ?? (variant === "error" ? "操作失败" : "操作成功");
			const icon =
				variant === "error"
					? '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="16.5" r="1" fill="currentColor"/><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>'
					: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7L9 18l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

			toast.className = `notification notification--${variant} is-entering`;
			toast.setAttribute("role", "status");
			toast.style.setProperty("--toast-duration", `${duration}ms`);
			toast.innerHTML = `
				<div class="notification__glow" aria-hidden="true"></div>
				<div class="notification__row">
					<div class="notification__icon" aria-hidden="true">${icon}</div>
					<div class="notification__content">
						<div class="notification__title">${resolvedTitle}</div>
						<div class="notification__message"></div>
					</div>
					<button type="button" class="notification__close" aria-label="关闭通知">×</button>
				</div>
				<div class="notification__progress" aria-hidden="true"></div>
			`;
			const messageNode = toast.querySelector(".notification__message");
			if (messageNode instanceof HTMLElement) {
				messageNode.textContent = message;
			}

			const closeButton = toast.querySelector(".notification__close");
			if (closeButton instanceof HTMLButtonElement) {
				closeButton.addEventListener("click", () => removeToast(toast));
			}

			stack.appendChild(toast);
			window.setTimeout(() => removeToast(toast), duration);
			return toast;
		};

		document.querySelectorAll("[data-auth-toast-source]").forEach((source) => {
			if (
				!(source instanceof HTMLElement) ||
				source.dataset.authToastConsumed === "true"
			) {
				return;
			}

			source.dataset.authToastConsumed = "true";
			const message = source.textContent?.trim() ?? "";
			const variant =
				source.dataset.authToastVariant === "error" ? "error" : "success";
			const title = source.dataset.authToastTitle ?? undefined;
			const duration =
				Number(source.dataset.authToastDuration ?? "3000") || 3000;

			showToast({
				message,
				variant,
				title,
				duration,
			});
		});

		// 延迟清除 URL 参数，确保 toast 已经显示
		const currentUrl = new URL(window.location.href);
		if (
			currentUrl.searchParams.has("auth") ||
			currentUrl.searchParams.has("pwdErr")
		) {
			// 等待 toast 显示后再清除 URL 参数
			setTimeout(() => {
				currentUrl.searchParams.delete("auth");
				currentUrl.searchParams.delete("pwdErr");
				window.history.replaceState(
					{},
					"",
					`${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`,
				);
			}, 100);
		}
	}

	// Runs on initial load and after every navigation
	document.addEventListener("astro:page-load", () => {
		mountAccountChangePasswordForm();
		initNavbarAuthToast();

		const menuBtn = document.getElementById("mobile-menu-btn");
		const mobileMenu = document.getElementById("mobile-menu");
		const menuIconOpen = document.getElementById("menu-icon-open");
		const menuIconClose = document.getElementById("menu-icon-close");
		const loginModal = document.getElementById("login-modal");
		const openModalButtons = document.querySelectorAll(
			"[data-open-login-modal]",
		);
		const closeModalButtons = document.querySelectorAll(
			"[data-close-login-modal]",
		);
		const usernameInput = document.getElementById("nav-login-username");
		const guestActions = document.querySelectorAll("[data-auth-guest]");
		const adminDesktopLink = document.querySelector(
			"[data-auth-admin-link-desktop]",
		);
		const adminDesktopLogout = document.querySelector(
			"[data-auth-logout-desktop]",
		);
		const adminMobileLink = document.querySelector("[data-auth-admin-link]");
		const adminMobileForm = document.querySelector("[data-auth-admin-form]");
		let isMenuOpen = false;

		// 获取登录状态并更新 UI
		fetch("/api/admin/session", {
			credentials: "same-origin",
			headers: {
				Accept: "application/json",
				"Cache-Control": "no-cache",
			},
		})
			.then(async (response) => {
				if (!response.ok) return null;
				try {
					return await response.json();
				} catch {
					return null;
				}
			})
			.then((session) => {
				const authenticated = Boolean(session?.authenticated);

				guestActions.forEach((element) => {
					element.classList.toggle("hidden", authenticated);
					if (
						element instanceof HTMLElement &&
						element.classList.contains("md:inline-flex")
					) {
						element.style.display = authenticated ? "none" : "";
					}
				});

				if (adminDesktopLink instanceof HTMLElement) {
					adminDesktopLink.classList.toggle("hidden", !authenticated);
					adminDesktopLink.classList.toggle("inline-flex", authenticated);
				}

				if (adminDesktopLogout instanceof HTMLElement) {
					adminDesktopLogout.classList.toggle("hidden", !authenticated);
					adminDesktopLogout.classList.toggle("block", authenticated);
				}

				if (adminMobileLink instanceof HTMLElement) {
					adminMobileLink.classList.toggle("hidden", !authenticated);
					adminMobileLink.classList.toggle("flex", authenticated);
				}

				if (adminMobileForm instanceof HTMLElement) {
					adminMobileForm.classList.toggle("hidden", !authenticated);
				}

				if (
					authenticated &&
					loginModal &&
					!loginModal.classList.contains("hidden")
				) {
					loginModal.classList.add("hidden");
					document.body.style.overflow = "";
				}

				if (authenticated && usernameInput) {
					usernameInput.value = "";
				}
			})
			.catch(() => {
				// 忽略错误
			});

		if (menuBtn && mobileMenu && menuIconOpen && menuIconClose) {
			isMenuOpen = false;
			mobileMenu.classList.add("-translate-y-[150%]");
			menuIconOpen.classList.remove("hidden");
			menuIconClose.classList.add("hidden");

			const toggleMenu = () => {
				isMenuOpen = !isMenuOpen;
				if (isMenuOpen) {
					mobileMenu.classList.remove("-translate-y-[150%]");
					menuIconOpen.classList.add("hidden");
					menuIconClose.classList.remove("hidden");
				} else {
					mobileMenu.classList.add("-translate-y-[150%]");
					menuIconOpen.classList.remove("hidden");
					menuIconClose.classList.add("hidden");
				}
			};

			if (menuBtn instanceof HTMLElement) {
				menuBtn.onclick = toggleMenu;
			}
		}

		if (loginModal) {
			const openModal = () => {
				loginModal.classList.remove("hidden");
				document.body.style.overflow = "hidden";
				// 打开弹窗时允许自动填充
				loginForm.removeAttribute("autocomplete");
				setTimeout(() => usernameInput?.focus(), 0);
			};

			const closeModal = () => {
				loginModal.classList.add("hidden");
				document.body.style.overflow = "";

				// 清除错误信息
				hideLoginError();

				// 清空表单内容
				const usernameInput = document.getElementById(
					"nav-login-username",
				) as HTMLInputElement;
				const passwordInput = document.getElementById(
					"nav-login-password",
				) as HTMLInputElement;
				if (usernameInput) usernameInput.value = "";
				if (passwordInput) passwordInput.value = "";

				// 重置 autocomplete 属性，允许下次自动填充
				loginForm.removeAttribute("autocomplete");

				// 只清除 login 和 error 参数，保留 auth 和 pwdErr 参数用于显示 toast 消息
				const url = new URL(window.location.href);
				if (url.searchParams.has("login") || url.searchParams.has("error")) {
					url.searchParams.delete("login");
					url.searchParams.delete("error");
					window.history.replaceState(
						{},
						"",
						`${url.pathname}${url.search}${url.hash}`,
					);
				}
			};

			if (loginModal.dataset.open === "true") {
				openModal();
			}

			openModalButtons.forEach((button) => {
				if (button instanceof HTMLElement) {
					button.onclick = () => {
						openModal();
						if (mobileMenu) {
							mobileMenu.classList.add("-translate-y-[150%]");
						}
						if (menuIconOpen && menuIconClose) {
							menuIconOpen.classList.remove("hidden");
							menuIconClose.classList.add("hidden");
						}
						isMenuOpen = false;
					};
				}
			});

			closeModalButtons.forEach((button) => {
				if (button instanceof HTMLElement) {
					button.onclick = (e) => {
						e.preventDefault();
						e.stopPropagation();
						closeModal();
					};
				}
			});

			document.onkeydown = (event) => {
				if (
					event.key === "Escape" &&
					!loginModal.classList.contains("hidden")
				) {
					closeModal();
				}
			};

			// 处理登录表单提交
			const loginForm = document.getElementById("login-form");
			const loginSubmitBtn = document.getElementById("login-submit-btn");
			const loginErrorMessage = document.getElementById("login-error-message");

			if (loginForm && loginSubmitBtn && loginErrorMessage) {
				// 点击登录按钮提交
				loginSubmitBtn.addEventListener("click", async () => {
					await handleLogin();
				});

				// 密码框按回车提交
				const passwordInput = document.getElementById(
					"nav-login-password",
				) as HTMLInputElement;
				if (passwordInput) {
					passwordInput.addEventListener("keydown", (e) => {
						if (e.key === "Enter") {
							e.preventDefault();
							handleLogin();
						}
					});
				}

				// 用户名框按回车聚焦到密码框
				const usernameInput = document.getElementById(
					"nav-login-username",
				) as HTMLInputElement;
				if (usernameInput) {
					usernameInput.addEventListener("keydown", (e) => {
						if (e.key === "Enter") {
							e.preventDefault();
							passwordInput?.focus();
						}
					});
				}

				// 密码可见/隐藏切换
				const togglePasswordBtn = document.getElementById(
					"toggle-password-btn",
				);
				const togglePasswordIcon = document.getElementById(
					"toggle-password-icon",
				);
				if (togglePasswordBtn && togglePasswordIcon && passwordInput) {
					togglePasswordBtn.addEventListener("click", () => {
						const isPassword = passwordInput.type === "password";
						passwordInput.type = isPassword ? "text" : "password";
						togglePasswordIcon.setAttribute(
							"name",
							isPassword ? "ri:eye-off-line" : "ri:eye-line",
						);
					});
				}

				async function handleLogin() {
					const username =
						(
							document.getElementById("nav-login-username") as HTMLInputElement
						)?.value?.trim() ?? "";
					const password =
						(document.getElementById("nav-login-password") as HTMLInputElement)
							?.value ?? "";
					const redirectTo =
						(
							loginForm.querySelector(
								'input[name="redirectTo"]',
							) as HTMLInputElement
						)?.value ?? "/";

					if (!username || !password) {
						showLoginError("请输入用户名和密码。");
						return;
					}

					// 禁用提交按钮
					loginSubmitBtn.disabled = true;
					loginSubmitBtn.textContent = "登录中...";
					hideLoginError();

					try {
						// 临时移除密码字段的 name 属性，防止浏览器识别为密码提交
						const passwordInput = document.getElementById(
							"nav-login-password",
						) as HTMLInputElement;
						const originalName = passwordInput?.name || "";
						if (passwordInput) {
							passwordInput.removeAttribute("name");
						}

						const formData = new FormData();
						formData.append("username", username);
						formData.append("password", password);
						formData.append("redirectTo", redirectTo);

						const response = await fetch("/api/admin/login", {
							method: "POST",
							body: formData,
							credentials: "same-origin",
						});

						// 恢复密码字段的 name 属性
						if (passwordInput) {
							passwordInput.name = originalName;
						}

						// 处理重定向
						if (response.redirected) {
							const url = new URL(response.url);
							const authStatus = url.searchParams.get("auth");
							const errorCode = url.searchParams.get("error");

							if (authStatus === "login") {
								// 登录成功 - 允许密码保存
								loginForm.removeAttribute("autocomplete");

								// 登录成功 - 先显示通知，然后跳转（不刷新，让跳转后的页面显示通知）
								loginModal.classList.add("hidden");
								document.body.style.overflow = "";
								// 直接跳转到目标 URL，保留 auth 参数以显示通知
								window.location.href = response.url;
								return;
							} else if (errorCode) {
								// 登录失败 - 禁用密码保存
								loginForm.setAttribute("autocomplete", "off");
								// 登录失败
								showLoginError(getErrorMessage(errorCode));
							} else {
								// 未知状态，跳转
								window.location.href = response.url;
							}
						} else if (response.ok) {
							// 没有重定向但成功，刷新页面
							window.location.reload();
						} else {
							showLoginError("登录失败，请稍后重试。");
						}
					} catch (error) {
						console.error("登录错误:", error);
						showLoginError("网络错误，请稍后重试。");
					} finally {
						loginSubmitBtn.disabled = false;
						loginSubmitBtn.textContent = "登录";
					}
				}
			}

			function showLoginError(message: string) {
				if (loginErrorMessage) {
					loginErrorMessage.textContent = message;
					loginErrorMessage.classList.remove("hidden");
				}
			}

			function hideLoginError() {
				if (loginErrorMessage) {
					loginErrorMessage.classList.add("hidden");
				}
			}

			function getErrorMessage(errorCode: string): string {
				const errorMap: Record<string, string> = {
					missing_fields: "请输入用户名和密码。",
					user_not_found: "用户名不存在。",
					wrong_password: "密码错误。",
					invalid_credentials: "用户名或密码错误。",
				};
				return errorMap[errorCode] ?? "登录失败，请稍后重试。";
			}
		}
	});
</script>
