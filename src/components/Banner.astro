---
---

<div class="relative w-full h-[40vh] md:h-[60vh] min-h-[300px] md:min-h-[400px] overflow-hidden mt-16 lg:mt-20 group" transition:persist>
    <!-- Background Video -->
    <div id="banner-bg" class="absolute inset-0 transform scale-100 transition-transform duration-1000 ease-out group-hover:scale-105 will-change-transform bg-gradient-to-br from-purple-900/40 to-blue-900/40">
        <video
            id="background-video"
            class="absolute inset-0 w-full h-full object-cover"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            onerror="this.style.display='none'"
            poster="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1920 1080'%3E%3Crect fill='%234c1d95' width='1920' height='1080'/%3E%3C/svg%3E"
        >
            <source src="/videos/background.mp4" type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-gradient-to-br from-purple-900/20 to-blue-900/20"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-dark-900/10 to-dark-900"></div>
    </div>
    
    <!-- Content -->
    <div class="relative z-10 bottom-0 left-0 w-full p-6 md:p-10 bg-gradient-to-t from-dark-900 via-dark-900/60 to-transparent pt-24">
        <div class="max-w-[1600px] mx-auto flex flex-col justify-end h-full">
             <h1 class="text-3xl md:text-5xl font-serif font-bold text-white mb-2 drop-shadow-xl tracking-wide translate-y-4 animate-fade-in-up">
                在学习与迷茫之间
             </h1>
             <p class="text-gray-200 text-base md:text-lg font-light tracking-wider flex items-center gap-3 translate-y-4 animate-fade-in-up stagger-2">
                <span class="w-6 h-[1px] bg-primary-400 inline-block"></span>
                探索 · 记录 · 沉淀
             </p>
        </div>
    </div>
</div>

<script>
    // 强制播放背景视频（解决某些浏览器的自动播放限制）
    const video = document.getElementById('background-video');
    if (video) {
        // Edge 浏览器可能需要用户交互才能播放
        video.addEventListener('loadeddata', () => {
            video.play().catch(err => {
                console.log('视频自动播放失败，使用渐变背景:', err);
                // 不隐藏视频，保留渐变背景
            });
        });
        
        // 如果加载失败，使用渐变背景
        video.addEventListener('error', () => {
            console.log('视频加载失败，使用渐变背景');
        });
    }
</script>
