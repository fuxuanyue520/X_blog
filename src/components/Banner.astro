---

---

<div
	class="relative w-full h-[40vh] md:h-[60vh] min-h-[300px] md:min-h-[400px] overflow-hidden mt-16 lg:mt-20 group"
	transition:persist
>
	<!-- Background Video -->
	<div
		id="banner-bg"
		class="absolute inset-0 transform scale-100 transition-transform duration-1000 ease-out group-hover:scale-105 will-change-transform"
	>
		<video
			id="background-video"
			class="absolute inset-0 w-full h-full object-cover"
			autoplay
			muted
			loop
			playsinline
			preload="auto"
		>
			<source src="/videos/background.mp4" type="video/mp4" />
		</video>
		<!-- 添加半透明遮罩，让背景更柔和 -->
		<div class="absolute inset-0 bg-dark-900/15"></div>
	</div>

	<!-- Content -->
	<div
		class="absolute bottom-0 left-0 w-full p-6 md:p-10 bg-gradient-to-t from-dark-900 via-dark-900/80 to-transparent pt-32 z-10"
	>
		<div class="max-w-[1600px] mx-auto flex flex-col justify-end h-full">
			<h1
				class="text-3xl md:text-5xl font-serif font-bold text-white mb-2 drop-shadow-xl tracking-wide translate-y-4 animate-fade-in-up"
			>
				在学习与迷茫之间
			</h1>
			<p
				class="text-gray-200 text-base md:text-lg font-light tracking-wider flex items-center gap-3 translate-y-4 animate-fade-in-up stagger-2"
			>
				<span class="w-6 h-[1px] bg-primary-400 inline-block"></span>
				探索 · 记录 · 沉淀
			</p>
		</div>
	</div>
</div>

<script>
	// 检测视频是否加载成功，失败则显示备用背景
	const video = document.getElementById("background-video");
	if (video) {
		video.addEventListener("loadeddata", () => {
			console.log("视频加载成功");
			video.play().catch((err) => {
				console.log("视频播放失败:", err);
			});
		});

		video.addEventListener("error", () => {
			console.log("视频加载失败，添加备用背景");
			document
				.getElementById("banner-bg")
				.classList.add(
					"bg-gradient-to-br",
					"from-purple-900/40",
					"to-blue-900/40",
				);
		});
	}
</script>
