---

---

<div
	class="relative w-full h-[40vh] md:h-[60vh] min-h-[300px] md:min-h-[400px] overflow-hidden mt-16 lg:mt-20 group"
	transition:persist
>
	<!-- Background Video -->
	<div
		id="banner-bg"
		class="absolute inset-0 transform scale-100 transition-transform duration-1000 ease-out group-hover:scale-105 will-change-transform bg-dark-900"
	>
		<video
			id="background-video"
			class="absolute inset-0 w-full h-full object-cover"
			autoplay
			muted
			loop
			playsinline
			webkit-playsinline
			preload="auto"
			controlsList="nodownload nofullscreen noremoteplayback"
		>
			<source src="/videos/background.mp4" type="video/mp4" />
			<!-- 备用方案：如果浏览器不支持 video 标签 -->
			<div
				class="absolute inset-0 bg-gradient-to-br from-purple-900/40 to-blue-900/40"
			>
			</div>
		</video>
		<!-- 添加半透明遮罩，让背景更柔和 -->
		<div class="absolute inset-0 bg-dark-900/15"></div>
	</div>

	<!-- Content -->
	<div
		class="absolute bottom-0 left-0 w-full p-6 md:p-10 bg-gradient-to-t from-dark-900 via-dark-900/80 to-transparent pt-32 z-10"
	>
		<div class="max-w-[1600px] mx-auto flex flex-col justify-end h-full">
			<h1
				class="text-3xl md:text-5xl font-serif font-bold text-white mb-2 drop-shadow-xl tracking-wide translate-y-4 animate-fade-in-up"
			>
				在学习与迷茫之间
			</h1>
			<p
				class="text-gray-200 text-base md:text-lg font-light tracking-wider flex items-center gap-3 translate-y-4 animate-fade-in-up stagger-2"
			>
				<span class="w-6 h-[1px] bg-primary-400 inline-block"></span>
				探索 · 记录 · 沉淀
			</p>
		</div>
	</div>
</div>

<script>
	// 强制播放视频，确保所有浏览器都能显示
	(function () {
		const video = document.getElementById("background-video");
		const bannerBg = document.getElementById("banner-bg");

		if (!video) return;

		// 尝试播放视频
		const tryPlay = async () => {
			try {
				await video.play();
				console.log("视频播放成功");
				// 播放成功后，移除备用背景
				bannerBg.classList.remove(
					"bg-gradient-to-br",
					"from-purple-900/40",
					"to-blue-900/40",
				);
			} catch (err) {
				console.log("视频自动播放失败:", err);
				// 播放失败，显示渐变背景
				bannerBg.classList.add(
					"bg-gradient-to-br",
					"from-purple-900/40",
					"to-blue-900/40",
				);
			}
		};

		// 视频加载完成后尝试播放
		if (video.readyState >= 3) {
			tryPlay();
		} else {
			video.addEventListener("loadeddata", tryPlay);
		}

		// 如果长时间没有加载成功，显示备用背景
		setTimeout(() => {
			if (!video.readyState || video.readyState < 3) {
				console.log("视频加载超时，显示备用背景");
				bannerBg.classList.add(
					"bg-gradient-to-br",
					"from-purple-900/40",
					"to-blue-900/40",
				);
			}
		}, 3000);

		// 错误处理
		video.addEventListener("error", () => {
			console.log("视频加载错误，显示备用背景");
			bannerBg.classList.add(
				"bg-gradient-to-br",
				"from-purple-900/40",
				"to-blue-900/40",
			);
		});
	})();
</script>
