---
import { Icon } from "astro-icon/components";

interface NavItem {
	id: string;
	label: string;
	href: string;
	icon: string;
}

interface Props {
	activeSection: "awards" | "documents" | "account";
}

const { activeSection } = Astro.props;

const navItems: NavItem[] = [
	{
		id: "documents",
		label: "文档管理",
		href: "/admin/documents",
		icon: "ri:file-text-line",
	},
	{
		id: "awards",
		label: "荣誉管理",
		href: "/admin/awards",
		icon: "ri:trophy-line",
	},
	{
		id: "account",
		label: "账户设置",
		href: "/admin/account",
		icon: "ri:user-settings-line",
	},
];
---

<section class="w-full">
	<div
		class="grid gap-6 lg:grid-cols-[200px_minmax(0,1fr)] xl:grid-cols-[220px_minmax(0,1fr)]"
	>
		<aside
			transition:persist="admin-sidebar"
			class="h-fit rounded-2xl bg-dark-900/60 p-3 shadow-lg shadow-black/20 backdrop-blur-xl lg:sticky lg:top-24"
		>
			<div class="mb-3 px-3 py-2">
				<p class="text-xs font-medium uppercase tracking-wider text-gray-500">
					后台列表
				</p>
			</div>
			<nav class="space-y-1" aria-label="后台导航" data-admin-nav>
				{
					navItems.map((item) => {
						const isActive = item.id === activeSection;

						return (
							<a
								href={item.href}
								data-admin-nav-href={item.href}
								class:list={[
									"group relative flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-all duration-200",
									isActive
										? "bg-primary-500/10 text-primary-300"
										: "text-gray-400 hover:bg-white/5 hover:text-gray-200",
								]}
							>
								<span
									class:list={[
										"admin-nav-bar pointer-events-none absolute left-0 top-1/2 h-6 w-0.5 -translate-y-1/2 rounded-full transition-all duration-200",
										isActive
											? "bg-primary-400"
											: "bg-transparent group-hover:bg-gray-600",
									]}
								/>
								<Icon
									name={item.icon}
									class:list={[
										"admin-nav-icon text-lg transition-colors duration-200",
										isActive
											? "text-primary-400"
											: "text-gray-500 group-hover:text-gray-400",
									]}
								/>
								<span>{item.label}</span>
							</a>
						);
					})
				}
			</nav>
		</aside>

		<div
			class="space-y-6"
			transition:name="admin-main-panel"
			transition:animate="fade"
		>
			<slot />
		</div>
	</div>
</section>

<script>
	function normalizeAdminPath(value: string) {
		const path = value.split("?")[0] ?? "";
		if (path.length > 1 && path.endsWith("/")) {
			return path.slice(0, -1);
		}
		return path;
	}

	function syncAdminSidebarActive() {
		const current = normalizeAdminPath(window.location.pathname);
		const nav = document.querySelector("[data-admin-nav]");
		if (!nav) {
			return;
		}

		nav.querySelectorAll("a[data-admin-nav-href]").forEach((anchor) => {
			const href = anchor.getAttribute("data-admin-nav-href") ?? "";
			const target = normalizeAdminPath(href);
			const active = target === current;

			anchor.classList.toggle("bg-primary-500/10", active);
			anchor.classList.toggle("text-primary-300", active);
			anchor.classList.toggle("text-gray-400", !active);
			anchor.classList.toggle("hover:bg-white/5", !active);
			anchor.classList.toggle("hover:text-gray-200", !active);

			const bar = anchor.querySelector(".admin-nav-bar");
			if (bar) {
				bar.classList.toggle("bg-primary-400", active);
				bar.classList.toggle("bg-transparent", !active);
				bar.classList.toggle("group-hover:bg-gray-600", !active);
			}

			const icon = anchor.querySelector(".admin-nav-icon");
			if (icon) {
				icon.classList.toggle("text-primary-400", active);
				icon.classList.toggle("text-gray-500", !active);
				icon.classList.toggle("group-hover:text-gray-400", !active);
			}
		});
	}

	syncAdminSidebarActive();
	document.addEventListener("astro:page-load", syncAdminSidebarActive);
</script>
