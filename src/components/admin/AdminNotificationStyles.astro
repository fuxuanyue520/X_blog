<style is:global>
	.notification-stack {
		position: fixed;
		top: 5.5rem;
		right: 1rem;
		z-index: 99999;
		display: flex;
		width: min(calc(100vw - 2rem), 24rem);
		flex-direction: column;
		gap: 0.85rem;
		pointer-events: none;
	}

	@media (min-width: 768px) {
		.notification-stack {
			top: 6rem;
		}
	}

	.notification {
		position: relative;
		overflow: hidden;
		border-radius: 1.15rem;
		border: 1px solid rgb(255 255 255 / 0.12);
		padding: 1rem 1rem 0.95rem;
		box-shadow:
			0 20px 45px rgb(2 6 23 / 0.28),
			0 8px 18px rgb(15 23 42 / 0.18);
		backdrop-filter: blur(14px);
		pointer-events: auto;
		opacity: 0;
		transform: translate3d(0, -14px, 0) scale(0.96);
	}

	.notification.is-entering {
		animation: admin-notification-in 0.38s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}

	.notification.is-leaving {
		animation: admin-notification-out 0.28s ease forwards;
	}

	.notification--success {
		background:
			radial-gradient(
				circle at top right,
				rgb(74 222 128 / 0.22),
				transparent 42%
			),
			linear-gradient(180deg, rgb(22 101 52 / 0.96), rgb(20 83 45 / 0.96));
		color: rgb(240 253 244);
	}

	.notification--error {
		background:
			radial-gradient(
				circle at top right,
				rgb(248 113 113 / 0.22),
				transparent 42%
			),
			linear-gradient(180deg, rgb(153 27 27 / 0.96), rgb(127 29 29 / 0.96));
		color: rgb(254 242 242);
	}

	.notification__glow {
		position: absolute;
		inset: -35% auto auto 68%;
		height: 7rem;
		width: 7rem;
		border-radius: 9999px;
		background: rgb(255 255 255 / 0.12);
		filter: blur(18px);
		pointer-events: none;
	}

	.notification__row {
		position: relative;
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
	}

	.notification__icon {
		display: inline-flex;
		height: 2.25rem;
		width: 2.25rem;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		border: 1px solid rgb(255 255 255 / 0.15);
		background: rgb(255 255 255 / 0.1);
		box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.12);
	}

	.notification__icon svg {
		height: 1.1rem;
		width: 1.1rem;
	}

	.notification__content {
		min-width: 0;
		flex: 1;
	}

	.notification__title {
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.notification__message {
		margin-top: 0.25rem;
		font-size: 0.875rem;
		line-height: 1.55;
		color: rgb(255 255 255 / 0.9);
		word-break: break-word;
	}

	.notification__close {
		display: inline-flex;
		height: 2rem;
		width: 2rem;
		flex-shrink: 0;
		align-items: center;
		justify-content: center;
		border: 0;
		border-radius: 9999px;
		background: rgb(255 255 255 / 0.08);
		color: inherit;
		cursor: pointer;
		transition:
			background-color 0.18s ease,
			transform 0.18s ease;
	}

	.notification__close:hover {
		background: rgb(255 255 255 / 0.16);
		transform: scale(1.04);
	}

	.notification__progress {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 3px;
		background: rgb(255 255 255 / 0.18);
		transform-origin: left center;
		animation: admin-notification-progress linear forwards;
		animation-duration: var(--toast-duration, 3000ms);
	}

	@keyframes admin-notification-in {
		0% {
			opacity: 0;
			transform: translate3d(0, -14px, 0) scale(0.96);
		}
		65% {
			opacity: 1;
			transform: translate3d(0, 4px, 0) scale(1.01);
		}
		100% {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}
	}

	@keyframes admin-notification-out {
		0% {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}
		100% {
			opacity: 0;
			transform: translate3d(0, -10px, 0) scale(0.97);
		}
	}

	@keyframes admin-notification-progress {
		from {
			transform: scaleX(1);
		}
		to {
			transform: scaleX(0);
		}
	}
</style>
