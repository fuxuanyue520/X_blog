---
import PageLayout from "@/layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";
import { listAwardFilterOptions, listAwards } from "@/lib/awards";

export const prerender = false;

const selectedSchool = Astro.url.searchParams.get("school")?.trim() ?? "";
const selectedYearValue = Astro.url.searchParams.get("year")?.trim() ?? "";
const selectedLevel = Astro.url.searchParams.get("level")?.trim() ?? "";
const selectedYear = selectedYearValue ? Number(selectedYearValue) : undefined;

const [awards, filterOptions] = await Promise.all([
	listAwards({
		school: selectedSchool || undefined,
		awardYear: Number.isInteger(selectedYear) ? selectedYear : undefined,
		awardLevel: selectedLevel || undefined,
	}),
	listAwardFilterOptions(),
]);

const schoolOptions = filterOptions.schools.map((school) => ({ value: school, label: school }));

const yearOptions = filterOptions.years.map((year) => ({ value: String(year), label: `${year} 年` }));

const levelOptions = filterOptions.levels.map((level) => ({ value: level, label: level }));

function getSelectedLabel(options: Array<{ value: string; label: string }>, value: string, fallback: string) {
	return options.find((option) => option.value === value)?.label ?? fallback;
}
---

<PageLayout title="荣誉墙" description="记录个人奖状、证书与成长轨迹的荣誉墙">
	<div class="space-y-4">
		<section class="rounded-xl border border-gray-100 bg-white p-5 shadow-sm dark:border-white/5 dark:bg-dark-800 dark:shadow-lg md:p-6 lg:p-8">
			<div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
				<div class="max-w-3xl">
					<h1 class="flex items-center gap-3 text-xl font-serif font-bold text-gray-900 dark:text-white md:text-2xl lg:text-3xl">
						<span class="h-6 w-1.5 rounded-full bg-gradient-to-b from-primary-400 to-primary-600"></span>
						荣誉墙
					</h1>
					<p class="mt-4 text-sm leading-7 text-gray-600 dark:text-gray-300 md:text-base">
						这里记录的是一段段认真走过的路。每一张奖状、每一份证书，都对应某个阶段的投入、尝试和回应。
					</p>
				</div>

			</div>
		</section>

		<section class="rounded-xl border border-gray-100 bg-white p-4 shadow-sm dark:border-white/5 dark:bg-dark-800 dark:shadow-lg md:p-5">
			<form method="GET" class="grid items-center gap-3 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_auto]">
				<div class="relative" data-custom-select-root>
					<input type="hidden" name="school" value={selectedSchool} data-select-input />
					<details class="custom-select">
						<summary class="custom-select__trigger">
							<span class={`custom-select__label ${selectedSchool ? "is-selected" : ""}`} data-select-label>{getSelectedLabel(schoolOptions, selectedSchool, "学校")}</span>
							<Icon name="ri:arrow-down-s-line" class="custom-select__arrow" />
						</summary>
						<div class="custom-select__menu">
							{schoolOptions.map((option) => (
								<button
									type="button"
									class={`custom-select__option ${option.value === selectedSchool ? "is-active" : ""}`}
									data-select-option
									data-value={option.value}
									data-label={option.label}
								>
									<span>{option.label}</span>
									<span class="custom-select__check" aria-hidden="true"></span>
								</button>
							))}
						</div>
					</details>
				</div>

				<div class="relative" data-custom-select-root>
					<input type="hidden" name="year" value={selectedYearValue} data-select-input />
					<details class="custom-select">
						<summary class="custom-select__trigger">
							<span class={`custom-select__label ${selectedYearValue ? "is-selected" : ""}`} data-select-label>{getSelectedLabel(yearOptions, selectedYearValue, "年份")}</span>
							<Icon name="ri:arrow-down-s-line" class="custom-select__arrow" />
						</summary>
						<div class="custom-select__menu">
							{yearOptions.map((option) => (
								<button
									type="button"
									class={`custom-select__option ${option.value === selectedYearValue ? "is-active" : ""}`}
									data-select-option
									data-value={option.value}
									data-label={option.label}
								>
									<span>{option.label}</span>
									<span class="custom-select__check" aria-hidden="true"></span>
								</button>
							))}
						</div>
					</details>
				</div>

				<div class="relative" data-custom-select-root>
					<input type="hidden" name="level" value={selectedLevel} data-select-input />
					<details class="custom-select">
						<summary class="custom-select__trigger">
							<span class={`custom-select__label ${selectedLevel ? "is-selected" : ""}`} data-select-label>{getSelectedLabel(levelOptions, selectedLevel, "级别")}</span>
							<Icon name="ri:arrow-down-s-line" class="custom-select__arrow" />
						</summary>
						<div class="custom-select__menu">
							{levelOptions.map((option) => (
								<button
									type="button"
									class={`custom-select__option ${option.value === selectedLevel ? "is-active" : ""}`}
									data-select-option
									data-value={option.value}
									data-label={option.label}
								>
									<span>{option.label}</span>
									<span class="custom-select__check" aria-hidden="true"></span>
								</button>
							))}
						</div>
					</details>
				</div>

				<a
					href="/awards"
					class="inline-flex min-h-[52px] items-center justify-center rounded-xl border border-gray-200 px-5 py-3 text-sm font-medium text-gray-600 transition hover:border-primary-400 hover:text-primary-600 dark:border-white/10 dark:text-gray-300 dark:hover:border-primary-500/40 dark:hover:text-primary-300"
				>
					清空
				</a>
			</form>
		</section>

		{awards.length > 0 ? (
			<section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
				{awards.map((award) => (
					<article class="overflow-hidden rounded-xl bg-white shadow-sm transition-all hover:shadow-lg dark:bg-dark-800 dark:shadow-lg">
						<button
							type="button"
							class="group block w-full cursor-zoom-in text-left transition-all hover:-translate-y-1"
							data-award-preview-trigger
							data-image-src={award.imageUrl}
							data-image-alt={award.title}
							data-award-title={award.title}
						>
							<div class="flex aspect-[4/3] items-center justify-center overflow-hidden bg-gray-100 dark:bg-dark-700">
								<img
									src={award.imageUrl}
									alt={award.title}
									loading="lazy"
									class="h-full w-full object-contain object-center bg-white p-2 transition duration-500 group-hover:scale-[1.06] dark:bg-dark-700"
								/>
							</div>
							<div class="px-4 pb-4 pt-3">
								<h2 class="text-base font-serif font-semibold text-gray-900 dark:text-white">{award.title}</h2>
								<div class="mt-3 flex flex-wrap gap-2 text-xs">
									<span class="rounded-full border border-gray-200 bg-gray-50 px-2.5 py-1 text-gray-700 dark:border-white/10 dark:bg-dark-700/60 dark:text-gray-300">
										{award.school}
									</span>
									<span class="rounded-full border border-gray-200 bg-gray-50 px-2.5 py-1 text-gray-700 dark:border-white/10 dark:bg-dark-700/60 dark:text-gray-300">
										{award.awardYear}
									</span>
									<span class="rounded-full border border-primary-200 bg-primary-50 px-2.5 py-1 text-primary-700 dark:border-primary-500/30 dark:bg-primary-500/10 dark:text-primary-200">
										{award.awardLevel}
									</span>
								</div>
							</div>
						</button>
					</article>
				))}
			</section>
		) : (
			<section class="rounded-xl border border-dashed border-gray-200 bg-white p-10 text-center shadow-sm dark:border-white/10 dark:bg-dark-800 dark:shadow-lg">
				<div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary-50 text-primary-600 dark:bg-primary-500/10 dark:text-primary-300">
					<Icon name="ri:inbox-archive-line" class="text-2xl" />
				</div>
				<p class="mt-4 text-lg font-medium text-gray-900 dark:text-white">当前条件下还没有荣誉记录</p>
				<p class="mt-2 text-sm text-gray-500 dark:text-gray-400">可以换一个筛选条件试试，或者先到后台补充新的荣誉内容。</p>
			</section>
		)}
	</div>

	<div
		class="award-preview"
		data-award-preview-modal
		hidden
		aria-hidden="true"
	>
		<button type="button" class="award-preview__backdrop" data-award-preview-close aria-label="关闭预览"></button>
		<div class="award-preview__dialog" role="dialog" aria-modal="true" aria-labelledby="award-preview-title">
			<button
				type="button"
				class="award-preview__close"
				data-award-preview-close
				aria-label="关闭预览"
			>
				<Icon name="ri:close-line" class="text-xl" />
			</button>
			<div class="award-preview__frame">
				<img src="" alt="" data-award-preview-image class="award-preview__image" />
			</div>
			<p id="award-preview-title" class="award-preview__title" data-award-preview-title></p>
		</div>
	</div>
</PageLayout>

<style>
	.custom-select {
		position: relative;
	}

	.custom-select > summary {
		list-style: none;
	}

	.custom-select > summary::-webkit-details-marker {
		display: none;
	}

	.custom-select__trigger {
		display: flex;
		min-height: 52px;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		border-radius: 0.75rem;
		border: 1px solid rgb(229 231 235);
		background: linear-gradient(180deg, rgb(251 252 253), rgb(247 249 251));
		padding: 0.85rem 1rem;
		font-size: 0.95rem;
		font-weight: 500;
		color: rgb(55 65 81);
		cursor: pointer;
		transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
		user-select: none;
	}

	.custom-select[open] .custom-select__trigger,
	.custom-select__trigger:hover {
		border-color: rgb(59 130 246);
		background: rgb(255 255 255);
		box-shadow: 0 10px 24px rgb(59 130 246 / 0.08), 0 0 0 4px rgb(59 130 246 / 0.08);
		transform: translateY(-1px);
	}

	.custom-select__label {
		color: rgb(107 114 128);
	}

	.custom-select__label.is-selected {
		color: rgb(17 24 39);
	}

	.custom-select__arrow {
		flex-shrink: 0;
		font-size: 1.25rem;
		color: rgb(156 163 175);
		transition: transform 0.2s ease, color 0.2s ease;
	}

	.custom-select[open] .custom-select__arrow {
		transform: rotate(180deg);
		color: rgb(59 130 246);
	}

	.custom-select__menu {
		position: absolute;
		top: calc(100% + 0.35rem);
		left: 0;
		right: 0;
		z-index: 20;
		max-height: 320px;
		min-width: 100%;
		overflow-y: auto;
		border-radius: 1rem;
		border: 1px solid rgb(226 232 240);
		background: rgb(255 255 255 / 0.98);
		padding: 0.45rem;
		box-shadow: 0 18px 45px rgb(15 23 42 / 0.12);
		backdrop-filter: blur(12px);
		animation: select-menu-in 0.16s ease-out;
	}

	.custom-select__option {
		display: flex;
		width: 100%;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		border: 0;
		border-radius: 0.8rem;
		background: transparent;
		padding: 0.85rem 0.95rem;
		font-size: 0.95rem;
		font-weight: 500;
		color: rgb(51 65 85);
		text-align: left;
		cursor: pointer;
		transition: background-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
	}

	.custom-select__option:hover,
	.custom-select__option.is-active {
		background: linear-gradient(180deg, rgb(239 246 255), rgb(231 242 255));
		color: rgb(29 78 216);
		transform: translateX(2px);
	}

	.custom-select__check {
		height: 0.75rem;
		width: 0.75rem;
		flex-shrink: 0;
		border-radius: 9999px;
		background: transparent;
		box-shadow: inset 0 0 0 1.5px rgb(203 213 225);
		transition: background-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
	}

	.custom-select__option.is-active .custom-select__check {
		background: rgb(37 99 235);
		box-shadow: inset 0 0 0 2px rgb(219 234 254);
		transform: scale(1.05);
	}

	@keyframes select-menu-in {
		from {
			opacity: 0;
			transform: translateY(-6px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	:global(.dark) .custom-select__trigger {
		border-color: rgb(255 255 255 / 0.1);
		background: linear-gradient(180deg, rgb(42 48 64 / 0.95), rgb(35 41 55 / 0.95));
		color: rgb(243 244 246);
	}

	:global(.dark) .custom-select[open] .custom-select__trigger,
	:global(.dark) .custom-select__trigger:hover {
		border-color: rgb(96 165 250 / 0.45);
		background: rgb(45 55 72 / 0.95);
		box-shadow: 0 12px 28px rgb(2 6 23 / 0.22), 0 0 0 4px rgb(59 130 246 / 0.12);
	}

	:global(.dark) .custom-select__label {
		color: rgb(156 163 175);
	}

	:global(.dark) .custom-select__label.is-selected {
		color: rgb(243 244 246);
	}

	:global(.dark) .custom-select[open] .custom-select__arrow {
		color: rgb(147 197 253);
	}

	:global(.dark) .custom-select__menu {
		border-color: rgb(255 255 255 / 0.08);
		background: rgb(31 41 55 / 0.98);
		box-shadow: 0 18px 45px rgb(2 6 23 / 0.45);
	}

	:global(.dark) .custom-select__option {
		color: rgb(209 213 219);
	}

	:global(.dark) .custom-select__option:hover,
	:global(.dark) .custom-select__option.is-active {
		background: rgb(59 130 246 / 0.12);
		color: rgb(191 219 254);
	}

	:global(.dark) .custom-select__check {
		box-shadow: inset 0 0 0 1.5px rgb(100 116 139);
	}

	:global(.dark) .custom-select__option.is-active .custom-select__check {
		background: rgb(96 165 250);
		box-shadow: inset 0 0 0 2px rgb(30 41 59);
	}

	.award-preview[hidden] {
		display: none;
	}

	.award-preview {
		position: fixed;
		inset: 0;
		z-index: 70;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.5rem;
	}

	.award-preview__backdrop {
		position: absolute;
		inset: 0;
		border: 0;
		background: rgb(15 23 42 / 0.72);
		backdrop-filter: blur(6px);
		cursor: zoom-out;
	}

	.award-preview__dialog {
		position: relative;
		z-index: 1;
		display: flex;
		max-height: min(92vh, 980px);
		width: min(1100px, 100%);
		flex-direction: column;
		gap: 1rem;
		border-radius: 1.25rem;
		background: transparent;
		padding: 3.75rem 0 0;
		box-shadow: none;
	}

	.award-preview__close {
		position: fixed;
		top: 1rem;
		right: 1rem;
		z-index: 82;
		display: inline-flex;
		height: 2.5rem;
		width: 2.5rem;
		align-items: center;
		justify-content: center;
		border: 0;
		border-radius: 9999px;
		background: rgb(255 255 255 / 0.92);
		color: rgb(55 65 81);
		cursor: pointer;
		box-shadow: 0 8px 24px rgb(15 23 42 / 0.12);
		transition: transform 0.18s ease, background-color 0.18s ease;
	}

	.award-preview__close:hover {
		transform: scale(1.05);
		background: rgb(248 250 252);
	}

	.award-preview__frame {
		display: flex;
		min-height: 0;
		flex: 1;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		border-radius: 0;
		background: transparent;
		padding: 0;
	}

	.award-preview__image {
		max-height: calc(92vh - 4rem);
		width: 100%;
		object-fit: contain;
	}

	@media (min-width: 768px) {
		.award-preview__close {
			top: 1.5rem;
			right: 1.5rem;
		}
	}

	.award-preview__title {
		text-align: center;
		font-size: 0.95rem;
		font-weight: 500;
		color: rgb(71 85 105);
	}

	:global(.dark) .award-preview__close {
		background: rgb(31 41 55 / 0.92);
		color: rgb(226 232 240);
	}

	:global(.dark) .award-preview__close:hover {
		background: rgb(51 65 85);
	}

	:global(.dark) .award-preview__title {
		color: rgb(203 213 225);
	}
</style>

<script is:inline>
	const initCustomSelects = () => {
		document.querySelectorAll("[data-custom-select-root]").forEach((root) => {
			if (root.dataset.selectReady === "true") {
				return;
			}

			const form = root.closest("form");
			const details = root.querySelector("details");
			const summary = root.querySelector("summary");
			const input = root.querySelector("[data-select-input]");
			const label = root.querySelector("[data-select-label]");
			const options = root.querySelectorAll("[data-select-option]");

			if (!form || !details || !summary || !input || !label || options.length === 0) {
				return;
			}

			root.dataset.selectReady = "true";
			let closeTimer;

			root.addEventListener("mouseenter", () => {
				if (closeTimer) {
					clearTimeout(closeTimer);
				}
			});

			root.addEventListener("mouseleave", () => {
				closeTimer = window.setTimeout(() => {
					details.removeAttribute("open");
				}, 120);
			});

			summary.addEventListener("click", (event) => {
				event.preventDefault();
				if (closeTimer) {
					clearTimeout(closeTimer);
				}
				if (details.hasAttribute("open")) {
					details.removeAttribute("open");
				} else {
					document.querySelectorAll("[data-custom-select-root] details[open]").forEach((item) => {
						if (item !== details) {
							item.removeAttribute("open");
						}
					});
					details.setAttribute("open", "");
				}
			});

			options.forEach((option) => {
				option.addEventListener("click", () => {
					const nextValue = option.getAttribute("data-value") ?? "";
					const nextLabel = option.getAttribute("data-label") ?? option.textContent?.trim() ?? "";

					input.value = nextValue;
					label.textContent = nextLabel;

					options.forEach((item) => item.classList.remove("is-active"));
					option.classList.add("is-active");
					details.removeAttribute("open");
					form.requestSubmit();
				});
			});
		});
	};

	const initAwardPreview = () => {
		const modal = document.querySelector("[data-award-preview-modal]");
		const image = modal?.querySelector("[data-award-preview-image]");
		const title = modal?.querySelector("[data-award-preview-title]");
		const closeButtons = modal?.querySelectorAll("[data-award-preview-close]");

		if (!modal || !image || !title || modal.dataset.previewReady === "true") {
			return;
		}

		if (modal.parentElement !== document.body) {
			document.body.appendChild(modal);
		}

		modal.dataset.previewReady = "true";

		const closePreview = () => {
			modal.hidden = true;
			modal.setAttribute("aria-hidden", "true");
			document.body.style.overflow = "";
			image.setAttribute("src", "");
			image.setAttribute("alt", "");
			title.textContent = "";
		};

		const openPreview = (src, alt, nextTitle) => {
			image.setAttribute("src", src);
			image.setAttribute("alt", alt);
			title.textContent = nextTitle;
			modal.hidden = false;
			modal.setAttribute("aria-hidden", "false");
			document.body.style.overflow = "hidden";
		};

		document.querySelectorAll("[data-award-preview-trigger]").forEach((trigger) => {
			if (trigger.dataset.previewBound === "true") {
				return;
			}

			trigger.dataset.previewBound = "true";
			trigger.addEventListener("click", () => {
				openPreview(
					trigger.getAttribute("data-image-src") ?? "",
					trigger.getAttribute("data-image-alt") ?? "",
					trigger.getAttribute("data-award-title") ?? "",
				);
			});
		});

		closeButtons?.forEach((button) => {
			button.addEventListener("click", closePreview);
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && !modal.hidden) {
				closePreview();
			}
		});
	};

	initCustomSelects();
	initAwardPreview();
	document.addEventListener("astro:page-load", initCustomSelects);
	document.addEventListener("astro:page-load", initAwardPreview);
</script>
