---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getAuthenticatedAdmin } from "@/lib/auth";
import {
	AWARD_LEVELS,
	HONOR_TYPES,
	groupAwardsByType,
	getAwardById,
	listAwards,
	listAwardFilterOptions,
} from "@/lib/awards";
import AdminShell from "@/components/admin/AdminShell.astro";

export const prerender = false;

const admin = await getAuthenticatedAdmin(Astro);

if (!admin) {
	return Astro.redirect("/?login=1");
}

const status = Astro.url.searchParams.get("status") ?? "";
const code = Astro.url.searchParams.get("code") ?? "";
const highlightId = Number(Astro.url.searchParams.get("highlight") ?? "");
const editId = Number(Astro.url.searchParams.get("edit") ?? "");
const keyword = Astro.url.searchParams.get("q")?.trim() ?? "";
const selectedType = Astro.url.searchParams.get("type")?.trim() ?? "";
const selectedYearValue = Astro.url.searchParams.get("year")?.trim() ?? "";
const selectedLevel = Astro.url.searchParams.get("level")?.trim() ?? "";
const selectedYear = selectedYearValue ? Number(selectedYearValue) : undefined;
const currentYear = new Date().getFullYear();

const statusMessages: Record<string, string> = {
	created: "荣誉记录已成功添加到荣誉墙。",
	updated: "荣誉信息已更新。",
	deleted: "荣誉记录已删除。",
	invalid_award: "没有找到要操作的荣誉记录。",
	invalid_fields: "请完整填写荣誉类型和年份。",
	invalid_type: "荣誉类型不在允许范围内。",
	invalid_level: "荣誉级别不在允许范围内。",
	invalid_image_type: "上传文件必须是图片或 PDF 格式。",
	image_too_large: "图片体积不能超过 8MB。",
	missing_image: "新增荣誉记录时必须上传图片或 PDF。",
};

const feedbackMessage =
	status === "error" ? statusMessages[code] : statusMessages[status];
const toastVariant = status === "error" ? "error" : "success";
const toastTitle =
	status === "created"
		? "新增成功"
		: status === "updated"
			? "保存成功"
			: status === "deleted"
				? "删除成功"
				: status === "error"
					? "操作失败"
					: "操作成功";
const toastDuration = status === "error" ? 4200 : 3200;

const activeFilters = {
	keyword: keyword || undefined,
	honorType: selectedType || undefined,
	awardYear: Number.isInteger(selectedYear) ? selectedYear : undefined,
	awardLevel: selectedLevel || undefined,
};

const startTime = Date.now();

const [allAwards, editingAward] = await Promise.all([
	listAwards(),
	Number.isInteger(editId) && editId > 0
		? getAwardById(editId)
		: Promise.resolve(null),
]);

const loadTime1 = Date.now();

const filterOptions = await listAwardFilterOptions();

const loadTime2 = Date.now();

const awards =
	activeFilters.keyword ||
	activeFilters.honorType ||
	activeFilters.awardYear ||
	activeFilters.awardLevel
		? allAwards.filter((award) => {
				if (activeFilters.keyword) {
					const keywordLower = activeFilters.keyword.toLowerCase();
					const matchKeyword =
						award.title.toLowerCase().includes(keywordLower) ||
						award.honorType.toLowerCase().includes(keywordLower) ||
						award.awardLevel.toLowerCase().includes(keywordLower) ||
						String(award.awardYear).includes(keywordLower);
					if (!matchKeyword) return false;
				}
				if (
					activeFilters.honorType &&
					award.honorType !== activeFilters.honorType
				)
					return false;
				if (
					activeFilters.awardYear &&
					award.awardYear !== activeFilters.awardYear
				)
					return false;
				if (
					activeFilters.awardLevel &&
					award.awardLevel !== activeFilters.awardLevel
				)
					return false;
				return true;
			})
		: allAwards;

const groupedAwards = groupAwardsByType(awards);

const typeOptions = filterOptions.types.map((type) => ({
	value: type,
	label: type,
}));

const yearOptions = filterOptions.years.map((year) => ({
	value: String(year),
	label: `${year} 年`,
}));

const levelOptions = filterOptions.levels.map((level) => ({
	value: level,
	label: level,
}));

function getSelectedLabel(
	options: Array<{ value: string; label: string }>,
	value: string,
	fallback: string,
) {
	return options.find((option) => option.value === value)?.label ?? fallback;
}

function buildCountItems(values: string[]) {
	const counts = new Map<string, number>();

	for (const value of values) {
		const normalized = value.trim();
		if (!normalized) {
			continue;
		}
		counts.set(normalized, (counts.get(normalized) ?? 0) + 1);
	}

	return Array.from(counts.entries())
		.map(([label, count]) => ({ label, count }))
		.sort(
			(left, right) =>
				right.count - left.count ||
				left.label.localeCompare(right.label, "zh-CN"),
		);
}

function buildTypeSummary(items: typeof allAwards) {
	const counts = new Map<string, number>();
	for (const award of items) {
		counts.set(award.honorType, (counts.get(award.honorType) ?? 0) + 1);
	}
	return HONOR_TYPES.map((type) => ({
		label: type,
		count: counts.get(type) ?? 0,
	})).filter((item) => item.count > 0);
}

function buildLevelSummary(items: typeof allAwards) {
	const counts = new Map<string, number>();
	const knownLevels = new Set(AWARD_LEVELS);

	for (const award of items) {
		if (award.awardLevel) {
			counts.set(award.awardLevel, (counts.get(award.awardLevel) ?? 0) + 1);
		}
	}

	const known = AWARD_LEVELS.map((level) => ({
		label: level,
		count: counts.get(level) ?? 0,
	})).filter((item) => item.count > 0);

	const extras: Array<{ label: string; count: number }> = [];
	for (const [level, count] of counts.entries()) {
		if (!knownLevels.has(level as (typeof AWARD_LEVELS)[number])) {
			extras.push({ label: level, count });
		}
	}
	extras.sort(
		(left, right) =>
			right.count - left.count ||
			left.label.localeCompare(right.label, "zh-CN"),
	);

	return [...known, ...extras];
}

function buildYearSummary(items: typeof allAwards) {
	const counts = new Map<string, number>();
	for (const award of items) {
		const year = String(award.awardYear);
		counts.set(year, (counts.get(year) ?? 0) + 1);
	}

	return Array.from(counts.entries())
		.map(([label, count]) => ({ label, count }))
		.sort(
			(left, right) =>
				Number(right.label) - Number(left.label) || right.count - left.count,
		);
}

const totalAwards = allAwards.length;
let currentYearAwardsCount = 0;
for (const award of allAwards) {
	if (award.awardYear === currentYear) {
		currentYearAwardsCount++;
	}
}
const allTypeSummary = buildTypeSummary(allAwards).sort(
	(left, right) =>
		right.count - left.count || left.label.localeCompare(right.label),
);
const allLevelSummary = buildLevelSummary(allAwards);
const yearSummary = buildYearSummary(allAwards);
const recentYearSummary = yearSummary.slice(0, 5).reverse();
const dominantType = allTypeSummary[0];
const maxWaveCount = Math.max(
	...recentYearSummary.map((item) => item.count),
	0,
);
const lineChartWidth = 220;
const lineChartHeight = 88;
const lineChartPadding = { top: 16, right: 10, bottom: 18, left: 10 };
const lineChartInnerWidth =
	lineChartWidth - lineChartPadding.left - lineChartPadding.right;
const lineChartInnerHeight =
	lineChartHeight - lineChartPadding.top - lineChartPadding.bottom;
const wavePoints = recentYearSummary.map((item, index) => {
	const x =
		recentYearSummary.length > 1
			? lineChartPadding.left +
				(index / (recentYearSummary.length - 1)) * lineChartInnerWidth
			: lineChartPadding.left + lineChartInnerWidth / 2;
	const normalizedHeight =
		maxWaveCount > 0 ? (item.count / maxWaveCount) * lineChartInnerHeight : 0;

	return {
		...item,
		x,
		y: lineChartHeight - lineChartPadding.bottom - normalizedHeight,
	};
});
const wavePath = wavePoints
	.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`)
	.join(" ");
const waveAreaPath =
	wavePoints.length > 0
		? `${wavePath} L ${wavePoints[wavePoints.length - 1]?.x ?? lineChartWidth} ${lineChartHeight - lineChartPadding.bottom} L ${wavePoints[0]?.x ?? 0} ${lineChartHeight - lineChartPadding.bottom} Z`
		: "";
const levelChartColors = [
	"#38bdf8",
	"#818cf8",
	"#22c55e",
	"#f59e0b",
	"#f472b6",
	"#fb7185",
];
const pieRadius = 28;
const pieCircumference = 2 * Math.PI * pieRadius;
let pieOffset = 0;
const levelPieSegments = allLevelSummary.map((item, index) => {
	const ratio = totalAwards > 0 ? item.count / totalAwards : 0;
	const segment = pieCircumference * ratio;
	const currentOffset = pieOffset;
	pieOffset -= segment;

	return {
		...item,
		color: levelChartColors[index % levelChartColors.length],
		ratio,
		dashArray: `${segment} ${pieCircumference - segment}`,
		dashOffset: currentOffset,
	};
});

const shouldOpenEditModal = Boolean(editingAward);
const shouldOpenCreateModal =
	status === "error" && !shouldOpenEditModal && code !== "invalid_award";
---

<BaseLayout title="荣誉管理" description="后台管理奖项、软著、专利与证书">
	<AdminShell activeSection="awards">
		{
			feedbackMessage && (
				<div
					hidden
					data-toast-source
					data-toast-variant={toastVariant}
					data-toast-title={toastTitle}
					data-toast-duration={String(toastDuration)}
				>
					{feedbackMessage}
				</div>
			)
		}

		<section
			class="rounded-3xl border border-white/10 bg-dark-800/70 p-4 md:p-5"
		>
			<div>
				<div>
					<h2 class="mt-2 text-xl font-semibold text-white md:text-2xl">
						荣誉汇总
					</h2>
				</div>
			</div>

			<div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
				<div class="rounded-2xl border border-white/10 bg-dark-900/40 p-3.5">
					<div class="flex items-center justify-between gap-3">
						<h3 class="text-sm font-semibold text-white">类型分布</h3>
						<span class="text-xs text-gray-500">按数量降序</span>
					</div>
					<p class="mt-1 text-xs text-gray-500">
						共 {totalAwards} 条
					</p>
					<div class="mt-3 max-h-48 space-y-2 overflow-y-auto">
						{
							allTypeSummary.length > 0 ? (
								allTypeSummary.map((item) => (
									<div class="space-y-1.5">
										<div class="flex items-center justify-between gap-3 text-[13px]">
											<span class="truncate text-gray-200">{item.label}</span>
											<span class="shrink-0 text-gray-400">
												{item.count} 条
											</span>
										</div>
										<div class="h-1.5 overflow-hidden rounded-full bg-white/5">
											<div
												class="h-full rounded-full bg-gradient-to-r from-primary-400 to-cyan-300"
												style={`width: ${totalAwards > 0 ? (item.count / totalAwards) * 100 : 0}%`}
											/>
										</div>
									</div>
								))
							) : (
								<p class="text-sm text-gray-500">暂无荣誉数据</p>
							)
						}
					</div>
				</div>

				<div class="rounded-2xl border border-white/10 bg-dark-900/40 p-3.5">
					<div class="flex items-center justify-between gap-3">
						<h3 class="text-sm font-semibold text-white">年份走势</h3>
						<span class="text-xs text-gray-500">最近 5 年</span>
					</div>
					<div class="mt-2 max-h-48 overflow-y-auto">
						{
							recentYearSummary.length > 0 ? (
								<div class="rounded-2xl border border-white/10 bg-dark-950/40 p-2.5">
									<svg
										viewBox={`0 0 ${lineChartWidth} ${lineChartHeight}`}
										preserveAspectRatio="xMidYMid meet"
										class="aspect-[2.2/1] max-h-40 w-full"
										aria-label="荣誉年份走势波形图"
									>
										<defs>
											<linearGradient
												id="awards-wave-fill"
												x1="0"
												x2="0"
												y1="0"
												y2="1"
											>
												<stop offset="0%" stop-color="rgb(56 189 248 / 0.35)" />
												<stop
													offset="100%"
													stop-color="rgb(56 189 248 / 0.02)"
												/>
											</linearGradient>
											<linearGradient
												id="awards-wave-line"
												x1="0"
												x2="1"
												y1="0"
												y2="0"
											>
												<stop offset="0%" stop-color="rgb(34 211 238)" />
												<stop offset="100%" stop-color="rgb(96 165 250)" />
											</linearGradient>
										</defs>
										<line
											x1={lineChartPadding.left}
											y1={lineChartHeight - lineChartPadding.bottom}
											x2={lineChartWidth - lineChartPadding.right}
											y2={lineChartHeight - lineChartPadding.bottom}
											stroke="rgb(255 255 255 / 0.08)"
											stroke-width="0.8"
										/>
										{wavePoints.map((point) => (
											<line
												x1={point.x}
												y1={lineChartPadding.top}
												x2={point.x}
												y2={lineChartHeight - lineChartPadding.bottom}
												stroke="rgb(255 255 255 / 0.06)"
												stroke-width="0.6"
											/>
										))}
										{waveAreaPath && (
											<path d={waveAreaPath} fill="url(#awards-wave-fill)" />
										)}
										{wavePath && (
											<path
												d={wavePath}
												fill="none"
												stroke="url(#awards-wave-line)"
												stroke-width="2.2"
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										)}
										{wavePoints.map((point) => (
											<g>
												<circle
													cx={point.x}
													cy={point.y}
													r="2.2"
													fill="rgb(125 211 252)"
													stroke="rgb(15 23 42)"
													stroke-width="0.9"
												/>
												<text
													x={point.x}
													y={Math.max(point.y - 6, 10)}
													text-anchor="middle"
													font-size="7"
													fill="rgb(226 232 240)"
												>
													{point.count}
												</text>
												<text
													x={point.x}
													y={lineChartHeight - 4}
													text-anchor="middle"
													font-size="6.5"
													fill="rgb(148 163 184)"
												>
													{point.label}
												</text>
											</g>
										))}
									</svg>
								</div>
							) : (
								<p class="text-sm text-gray-500">暂无年份统计</p>
							)
						}
					</div>
				</div>

				<div
					class="rounded-2xl border border-white/10 bg-dark-900/40 p-3.5 md:col-span-2 xl:col-span-1"
				>
					<div class="flex items-center justify-between gap-3">
						<h3 class="text-sm font-semibold text-white">级别分布</h3>
					</div>
					<div class="mt-2 max-h-48 overflow-y-auto">
						{
							levelPieSegments.length > 0 ? (
								<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
									<div class="mx-auto w-full max-w-[140px] shrink-0">
										<svg
											viewBox="0 0 100 100"
											class="mx-auto h-32 w-32"
											aria-label="荣誉级别分布饼图"
										>
											<circle
												cx="50"
												cy="50"
												r={pieRadius}
												fill="none"
												stroke="rgb(255 255 255 / 0.08)"
												stroke-width="12"
											/>
											<g transform="rotate(-90 50 50)">
												{levelPieSegments.map((item) => (
													<circle
														cx="50"
														cy="50"
														r={pieRadius}
														fill="none"
														stroke={item.color}
														stroke-width="12"
														stroke-linecap="butt"
														stroke-dasharray={item.dashArray}
														stroke-dashoffset={item.dashOffset}
													/>
												))}
											</g>
										</svg>
									</div>
									<div class="grid flex-1 gap-1.5">
										{levelPieSegments.map((item) => (
											<div class="flex items-center justify-between gap-3 rounded-xl border border-white/10 bg-dark-950/40 px-3 py-1.5 text-[13px]">
												<div class="flex items-center gap-2">
													<span
														class="h-2.5 w-2.5 rounded-full"
														style={`background:${item.color}`}
													/>
													<span class="text-gray-200">{item.label}</span>
												</div>
												<span class="text-gray-400">
													{item.count} / {Math.round(item.ratio * 100)}%
												</span>
											</div>
										))}
									</div>
								</div>
							) : (
								<span class="text-sm text-gray-500">暂无级别标签</span>
							)
						}
					</div>
				</div>
			</div>
		</section>

		<div class="rounded-3xl border border-white/10 bg-dark-800/70 p-4 md:p-5">
			<div
				class="mb-4 flex min-w-0 flex-col gap-3 md:flex-row md:flex-nowrap md:items-center md:justify-between"
			>
				<h2 class="min-w-0 text-xl font-semibold text-white md:text-2xl">荣誉列表</h2>
				<div class="flex shrink-0 flex-nowrap gap-3">
					<button
						type="button"
						class="inline-flex min-h-[42px] shrink-0 items-center gap-2 whitespace-nowrap rounded-xl bg-primary-500 px-4 py-2 text-sm font-medium text-white shadow-[0_10px_24px_rgba(14,165,233,0.16)] transition-all hover:bg-primary-600 hover:shadow-[0_12px_28px_rgba(14,165,233,0.22)] focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						data-open-award-modal="create"
						aria-label="新建荣誉记录"
					>
						<Icon name="ri:add-circle-line" class="text-lg" />
						新建
					</button>
				</div>
			</div>

			<form
				action="/admin/awards"
				method="GET"
				data-admin-awards-filter-form
				class="mb-4"
			>
				<div class="admin-filter-toolbar grid w-full grid-cols-1 gap-2.5 lg:grid-cols-[minmax(0,1fr)_10rem_10rem_10rem_auto_auto] lg:items-stretch">
					<div class="relative min-h-[48px] min-w-0">
						<input
							type="search"
							name="q"
							value={keyword}
							placeholder="搜索标题、类型、级别、年份"
							class="min-h-[48px] w-full rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-2.5 text-sm text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
						/>
					</div>
					<div
						class="relative min-h-[48px] min-w-0 w-full"
						data-custom-select-root
						data-select-submit-on-change="true"
					>
						<input
							type="hidden"
							name="type"
							value={selectedType}
							data-select-input
						/>
						<details class="custom-select custom-select--filter-toolbar">
							<summary class="custom-select__trigger">
								<span
									class={`custom-select__label ${selectedType ? "is-selected" : ""}`}
									data-select-label
									data-placeholder="类型"
									>{getSelectedLabel(typeOptions, selectedType, "类型")}</span
								>
								<Icon
									name="ri:arrow-down-s-line"
									class="custom-select__arrow"
								/>
							</summary>
							<div class="custom-select__menu">
								{
									typeOptions.map((option) => (
										<button
											type="button"
											class={`custom-select__option ${option.value === selectedType ? "is-active" : ""}`}
											data-select-option
											data-value={option.value}
											data-label={option.label}
										>
											<span>{option.label}</span>
											<span class="custom-select__check" aria-hidden="true" />
										</button>
									))
								}
							</div>
						</details>
					</div>
					<div
						class="relative min-h-[48px] min-w-0 w-full"
						data-custom-select-root
						data-select-submit-on-change="true"
					>
						<input
							type="hidden"
							name="year"
							value={selectedYearValue}
							data-select-input
						/>
						<details class="custom-select custom-select--filter-toolbar">
							<summary class="custom-select__trigger">
								<span
									class={`custom-select__label ${selectedYearValue ? "is-selected" : ""}`}
									data-select-label
									data-placeholder="年份"
									>{
										getSelectedLabel(yearOptions, selectedYearValue, "年份")
									}</span
								>
								<Icon
									name="ri:arrow-down-s-line"
									class="custom-select__arrow"
								/>
							</summary>
							<div class="custom-select__menu">
								{
									yearOptions.map((option) => (
										<button
											type="button"
											class={`custom-select__option ${option.value === selectedYearValue ? "is-active" : ""}`}
											data-select-option
											data-value={option.value}
											data-label={option.label}
										>
											<span>{option.label}</span>
											<span class="custom-select__check" aria-hidden="true" />
										</button>
									))
								}
							</div>
						</details>
					</div>
					<div
						class="relative min-h-[48px] min-w-0 w-full"
						data-custom-select-root
						data-select-submit-on-change="true"
					>
						<input
							type="hidden"
							name="level"
							value={selectedLevel}
							data-select-input
						/>
						<details class="custom-select custom-select--filter-toolbar">
							<summary class="custom-select__trigger">
								<span
									class={`custom-select__label ${selectedLevel ? "is-selected" : ""}`}
									data-select-label
									data-placeholder="级别"
									>{getSelectedLabel(levelOptions, selectedLevel, "级别")}</span
								>
								<Icon
									name="ri:arrow-down-s-line"
									class="custom-select__arrow"
								/>
							</summary>
							<div class="custom-select__menu">
								{
									levelOptions.map((option) => (
										<button
											type="button"
											class={`custom-select__option ${option.value === selectedLevel ? "is-active" : ""}`}
											data-select-option
											data-value={option.value}
											data-label={option.label}
										>
											<span>{option.label}</span>
											<span class="custom-select__check" aria-hidden="true" />
										</button>
									))
								}
							</div>
						</details>
					</div>
					<button
						type="submit"
						class="inline-flex min-h-[48px] w-full items-center justify-center whitespace-nowrap rounded-2xl bg-primary-500 px-5 text-sm font-medium text-white transition-all hover:bg-primary-600 lg:min-w-[5.5rem] focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						aria-label="搜索荣誉记录"
					>
						搜索
					</button>
					<a
						href="/admin/awards"
						data-admin-awards-clear
						class="inline-flex min-h-[48px] w-full items-center justify-center whitespace-nowrap rounded-2xl border border-white/10 px-5 text-sm font-medium text-gray-300 transition-all hover:border-primary-400 hover:text-primary-300 lg:min-w-[5.5rem] focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						aria-label="清空筛选条件"
					>
						清空
					</a>
				</div>
			</form>

			<div data-admin-awards-results>
				{
					awards.length > 0 ? (
						<div class="space-y-5">
							{groupedAwards.map((group) => (
								<section class="space-y-3">
									<div class="flex items-center justify-between gap-3">
										<h3 class="text-base font-semibold text-white md:text-lg">
											{group.honorType}
										</h3>
										<span class="rounded-full border border-white/10 bg-dark-900/70 px-3 py-1 text-xs text-gray-400">
											{group.items.length} 条
										</span>
									</div>
									<div class="space-y-3">
										{group.items.map((award) => (
											<article
												id={
													highlightId === award.id
														? `award-${award.id}`
														: undefined
												}
												class:list={[
													"grid gap-3 rounded-2xl border border-white/10 bg-dark-900/60 p-3 md:grid-cols-[104px_minmax(0,1fr)_auto] md:items-center",
													highlightId === award.id
														? "border-primary-400/50 shadow-[0_0_0_1px_rgba(34,211,238,0.3)]"
														: "",
												]}
											>
												<div class="overflow-hidden rounded-xl bg-dark-950">
													<img
														src={award.imageUrl}
														alt={award.title}
														class="h-24 w-full object-cover"
													/>
												</div>
												<div class="min-w-0 space-y-2">
													<h4 class="truncate text-lg font-semibold text-white">
														{award.title}
													</h4>
													<div class="flex flex-wrap items-center gap-2 text-xs text-gray-300">
														<span class="rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-1 text-amber-200">
															{award.honorType}
														</span>
														{award.awardLevel && (
															<span class="rounded-full border border-primary-500/30 bg-primary-500/10 px-2.5 py-1 text-primary-200">
																{award.awardLevel}
															</span>
														)}
														<span class="rounded-full border border-white/10 bg-dark-800 px-2.5 py-1 text-gray-300">
															{award.awardYear} 年
														</span>
													</div>
												</div>
												<div class="flex flex-wrap gap-2 md:flex-col md:items-end">
													<button
														type="button"
														class="inline-flex min-h-[38px] items-center justify-center gap-1.5 whitespace-nowrap rounded-xl border border-white/10 px-3 py-2 text-sm font-medium text-gray-200 transition-all hover:border-primary-400 hover:text-primary-300 md:min-w-[84px] focus:outline-none focus:ring-2 focus:ring-primary-500/20"
														data-open-award-modal="edit"
														data-award-id={award.id}
														data-award-type={award.honorType}
														data-award-competition-name={award.competitionName}
														data-award-name={award.awardName}
														data-award-year={award.awardYear}
														data-award-level={award.awardLevel}
														data-award-image-name={award.imageName}
														data-award-image-url={award.imageUrl}
														aria-label={`编辑荣誉记录 ${award.title}`}
													>
														<Icon name="ri:edit-line" class="text-base" />
														编辑
													</button>
													<form
														method="POST"
														action="/api/admin/awards/delete"
														class="delete-award-form"
													>
														<input type="hidden" name="id" value={award.id} />
														<button
															type="submit"
															class="inline-flex min-h-[38px] items-center justify-center gap-1.5 whitespace-nowrap rounded-xl border border-red-500/20 bg-red-500/10 px-3 py-2 text-sm font-medium text-red-200 transition-all hover:border-red-500/40 hover:bg-red-500/15 md:min-w-[84px] focus:outline-none focus:ring-2 focus:ring-red-500/20"
															data-open-delete-modal
															data-award-title={award.title}
															aria-label={`删除荣誉记录 ${award.title}`}
														>
															<Icon
																name="ri:delete-bin-line"
																class="text-base"
															/>
															删除
														</button>
													</form>
												</div>
											</article>
										))}
									</div>
								</section>
							))}
						</div>
					) : (
						<div class="rounded-3xl border border-dashed border-white/10 bg-dark-900/40 p-8 text-center">
							<p class="text-lg font-medium text-white">
								当前条件下还没有荣誉记录
							</p>
							<p class="mt-3 text-sm text-gray-400">
								可以换一个筛选条件试试，或者点击右上角“新建”新增一条记录。
							</p>
						</div>
					)
				}
			</div>
		</div>

		<div
			id="award-modal"
			data-open={shouldOpenEditModal || shouldOpenCreateModal
				? "true"
				: "false"}
			data-initial-award={editingAward ? JSON.stringify(editingAward) : ""}
			data-should-open-edit={shouldOpenEditModal ? "true" : "false"}
			data-should-open-create={shouldOpenCreateModal ? "true" : "false"}
			data-current-year={String(currentYear)}
			class:list={[
				"fixed inset-0 z-[200] flex items-center justify-center overflow-y-auto px-3 py-6 sm:px-5 sm:py-8",
				{ hidden: !(shouldOpenEditModal || shouldOpenCreateModal) },
			]}
		>
			<button
				type="button"
				class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
				data-close-award-modal
				aria-label="关闭弹窗"
			>
			</button>

			<div
				class="relative z-10 my-auto flex max-h-[calc(100vh-3rem)] w-full max-w-3xl flex-col overflow-hidden rounded-[24px] border border-white/10 bg-dark-800/95 shadow-2xl shadow-black/40 sm:max-h-[calc(100vh-4rem)]"
			>
				{/*
					弹窗文案以 #award-strings-bank 内各 id 节点正文的 text 为准（所见即所得，勿用 data- 再存一份）。
					客户端打开弹窗、切换新建/编辑时也会读这些元素的 textContent。
				*/}
				<div
					id="award-strings-bank"
					class="sr-only"
					aria-hidden="true"
				>
					<span id="award-s-create-title" class="block">新建荣誉</span>
					<span id="award-s-create-desc" class="block"
						>上传荣誉图片或 PDF</span
					>
					<span id="award-s-edit-title" class="block">编辑荣誉</span>
					<span id="award-s-edit-desc" class="block"
						>更新当前荣誉的图片和分类信息。</span
					>
					<span id="award-s-image-label-new" class="block">图片 / PDF</span>
					<span id="award-s-image-label-edit" class="block"
						>图片 / PDF（如需更换再上传）</span
					>
					<span id="award-s-submit-new" class="block">新建</span>
					<span id="award-s-submit-edit" class="block">保存修改</span>
					<span id="award-s-ocr-new" class="block"
						>上传荣誉图片或 PDF 后，这里会展示 OCR 提取出的完整文本。</span
					>
					<span id="award-s-ocr-edit" class="block"
						>如重新上传荣誉图片或 PDF，这里会展示新的 OCR 原文。</span
					>
				</div>
				<div
					class="flex items-start justify-between gap-4 border-b border-white/10 bg-white/[0.02] px-4 py-3 md:px-6"
				>
					<div>
						<p
							id="award-modal-tag"
							class="text-sm uppercase tracking-[0.35em] text-primary-400"
						>
							Honor
						</p>
						<h2
							id="award-modal-title"
							class="mt-3 text-2xl font-semibold text-white"
						>
						</h2>
						<p
							id="award-modal-description"
							class="mt-2 text-sm text-gray-400"
						>
						</p>
						<script
							is:inline
							define:vars={{ isEdit: shouldOpenEditModal }}
						>
							(function (edit) {
								var t = function (id) {
									var e = document.getElementById(id);
									return e && e.textContent
										? e.textContent.trim()
										: "";
								};
								var titleId = edit
									? "award-s-edit-title"
									: "award-s-create-title";
								var descId = edit
									? "award-s-edit-desc"
									: "award-s-create-desc";
								var mt = document.getElementById("award-modal-title");
								var md = document.getElementById("award-modal-description");
								if (mt) mt.textContent = t(titleId);
								if (md) md.textContent = t(descId);
							})(isEdit);
						</script>
					</div>
					<button
						type="button"
						class="rounded-full p-2 text-gray-400 transition hover:bg-white/5 hover:text-white"
						data-close-award-modal
						aria-label="关闭"
					>
						<Icon name="ri:close-line" class="text-xl" />
					</button>
				</div>

				<form
					id="award-form"
					method="POST"
					action="/api/admin/awards/save"
					enctype="multipart/form-data"
					class="flex min-h-0 flex-1 flex-col"
				>
					<input id="award-id" type="hidden" name="id" />
					<div
						class="panel-scrollbar min-h-0 flex-1 space-y-4 overflow-y-auto px-4 pb-4 pt-3 md:px-6 md:pb-4 md:pt-4"
					>
						<div class="award-form__row award-form__row--primary">
							<div>
								<label for="award-competition-name" class="award-form__label">
									名称
								</label>
								<input
									id="award-competition-name"
									name="competitionName"
									type="text"
									class="award-form__control"
									placeholder="例如：全国大学生数学建模竞赛"
								/>
							</div>

							<div>
								<label for="award-name" class="award-form__label">
									名次（可选）
								</label>
								<input
									id="award-name"
									name="awardName"
									type="text"
									class="award-form__control"
									placeholder="例如：一等奖"
								/>
							</div>
						</div>

						<div class="award-form__row award-form__row--meta">
							<div
								class="relative award-form__field--compact"
								data-custom-select-root
								data-select-submit-on-change="false"
							>
								<label for="award-type" class="award-form__label">类型</label>
								<input
									id="award-type"
									name="honorType"
									type="hidden"
									value="奖项"
									data-select-input
								/>
								<details class="custom-select award-form__select">
									<summary class="custom-select__trigger">
										<span
											class="custom-select__label is-selected"
											data-select-label
											data-placeholder="类型">奖项</span
										>
										<Icon
											name="ri:arrow-down-s-line"
											class="custom-select__arrow"
										/>
									</summary>
									<div class="custom-select__menu">
										{
											HONOR_TYPES.map((type, index) => (
												<button
													type="button"
													class={`custom-select__option ${index === 0 ? "is-active" : ""}`}
													data-select-option
													data-value={type}
													data-label={type}
												>
													<span>{type}</span>
													<span
														class="custom-select__check"
														aria-hidden="true"
													/>
												</button>
											))
										}
									</div>
								</details>
							</div>

							<div class="award-form__field--compact">
								<label for="award-year" class="award-form__label">年份</label>
								<input
									id="award-year"
									name="awardYear"
									type="text"
									inputmode="numeric"
									required
									class="award-form__control"
									placeholder="例如：2025"
								/>
							</div>
						</div>

						<div class="award-form__row award-form__row--support">
							<div
								class="relative award-form__field--compact"
								data-custom-select-root
								data-select-submit-on-change="false"
							>
								<label for="award-level" class="award-form__label"
									>级别（可选）</label
								>
								<input
									id="award-level"
									name="awardLevel"
									type="hidden"
									value=""
									data-select-input
								/>
								<details class="custom-select award-form__select">
									<summary class="custom-select__trigger">
										<span
											class="custom-select__label"
											data-select-label
											data-placeholder="级别">级别</span
										>
										<Icon
											name="ri:arrow-down-s-line"
											class="custom-select__arrow"
										/>
									</summary>
									<div class="custom-select__menu">
										<button
											type="button"
											class="custom-select__option is-active"
											data-select-option
											data-value=""
											data-label="级别"
										>
											<span>不填写</span>
											<span class="custom-select__check" aria-hidden="true"
											></span>
										</button>
										{
											AWARD_LEVELS.map((level, index) => (
												<button
													type="button"
													class="custom-select__option"
													data-select-option
													data-value={level}
													data-label={level}
												>
													<span>{level}</span>
													<span
														class="custom-select__check"
														aria-hidden="true"
													/>
												</button>
											))
										}
									</div>
								</details>
							</div>
							<div>
								<label
									id="award-image-label"
									for="award-image"
									class="award-form__label"
								>
									图片
								</label>
								<input
									id="award-image"
									name="image"
									type="file"
									accept="image/*,.pdf,application/pdf"
									class="award-form__control award-form__upload"
								/>
								<p
									id="award-image-hint"
									class="mt-3 hidden text-sm text-gray-400"
								>
									当前图片：
									<a
										id="award-image-link"
										href="#"
										target="_blank"
										class="text-primary-300 hover:text-primary-200"></a>
								</p>
							</div>
						</div>

						<div>
							<label for="award-ocr-text" class="award-form__label">
								OCR 原文
							</label>
							<textarea
								id="award-ocr-text"
								rows="4"
								readonly
								class="panel-scrollbar award-form__textarea h-28 w-full resize-none text-sm leading-6 text-gray-300 outline-none transition-[border-color,background-image,color] duration-300"
								placeholder="上传荣誉图片或 PDF 后，这里会展示 OCR 提取出的完整文本。"
							></textarea>
						</div>
					</div>

					<div
						class="shrink-0 border-t border-white/10 bg-dark-900/40 px-4 py-3 md:px-6"
					>
						<button
							id="award-submit-button"
							type="submit"
							class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-600"
						>
							<Icon
								id="award-submit-icon"
								name="ri:add-circle-line"
								class="text-lg"
							/>
							<span id="award-submit-text">新建</span>
						</button>
					</div>
				</form>
			</div>
		</div>

		<div
			id="award-delete-modal"
			class="fixed inset-0 z-[210] hidden items-center justify-center p-4"
		>
			<button
				type="button"
				class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
				data-close-delete-modal
				aria-label="关闭删除确认"></button>

			<div
				class="relative z-10 w-full max-w-md rounded-3xl border border-white/10 bg-dark-800/95 p-6 shadow-2xl shadow-black/40"
			>
				<div class="flex items-start gap-4">
					<div
						class="flex h-11 w-11 items-center justify-center rounded-2xl bg-red-500/10 text-red-300"
					>
						<Icon name="ri:delete-bin-line" class="text-xl" />
					</div>
					<div class="flex-1">
						<h2 class="text-xl font-semibold text-white">确认删除</h2>
						<p class="mt-2 text-sm leading-6 text-gray-400">
							删除后将无法恢复，请确认是否删除
							<span id="delete-award-name" class="text-gray-200"></span>
							。
						</p>
					</div>
				</div>

				<div class="mt-6 flex justify-end gap-3">
					<button
						type="button"
						class="rounded-2xl border border-white/10 px-4 py-2 text-sm font-medium text-gray-300 transition-all hover:border-primary-400 hover:text-primary-300 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						data-close-delete-modal
						aria-label="取消删除"
					>
						取消
					</button>
					<button
						id="confirm-delete-button"
						type="button"
						class="rounded-2xl bg-red-500 px-4 py-2 text-sm font-medium text-white transition-all hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-500/20"
						aria-label="确认删除"
					>
						确定删除
					</button>
				</div>
			</div>
		</div>
	</AdminShell>
</BaseLayout>

<style>
	.award-form__row {
		display: grid;
		gap: 1rem;
		align-items: start;
	}

	.award-form__label {
		margin-bottom: 0.5rem;
		display: block;
		font-size: 0.875rem;
		font-weight: 500;
		color: rgb(229 231 235);
	}

	.award-form__control,
	.award-form__textarea {
		width: 100%;
		border-radius: 1rem;
		border: 1px solid rgb(255 255 255 / 0.1);
		background: rgb(15 23 42 / 0.8);
		padding: 0.875rem 1rem;
		color: rgb(243 244 246);
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	.award-form__control {
		min-height: 52px;
	}

	.award-form__control:focus,
	.award-form__textarea:focus {
		border-color: rgb(96 165 250 / 0.5);
		box-shadow: 0 0 0 4px rgb(59 130 246 / 0.12);
	}

	.award-form__upload {
		display: block;
		min-height: 52px;
		border-color: rgb(255 255 255 / 0.1);
		background: rgb(15 23 42 / 0.8);
		padding-top: 0.5rem;
		padding-bottom: 0.5rem;
		font-size: 0.875rem;
		color: rgb(209 213 219);
	}

	.award-form__upload::file-selector-button {
		margin-right: 0.85rem;
		border: 0;
		border-radius: 9999px;
		background: rgb(59 130 246 / 0.14);
		padding: 0.5rem 0.95rem;
		font-size: 0.875rem;
		font-weight: 500;
		color: rgb(224 242 254);
		cursor: pointer;
	}

	.award-form__textarea {
		background: rgb(15 23 42 / 0.8);
	}

	.custom-select {
		position: relative;
	}

	.custom-select--filter-toolbar {
		width: 100%;
	}

	.custom-select--filter-toolbar .custom-select__trigger {
		min-height: 48px;
		padding-top: 0.65rem;
		padding-bottom: 0.65rem;
	}

	.custom-select > summary {
		list-style: none;
	}

	.custom-select > summary::-webkit-details-marker {
		display: none;
	}

	.custom-select__trigger {
		display: flex;
		min-height: 52px;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		border-radius: 1rem;
		border: 1px solid rgb(255 255 255 / 0.1);
		background: linear-gradient(
			180deg,
			rgb(42 48 64 / 0.95),
