		const clearOcrProgressVisual = () => {
			ocrTextInput.style.backgroundImage = "";
			ocrTextInput.style.backgroundRepeat = "";
			ocrTextInput.style.backgroundPosition = "";
			ocrTextInput.style.backgroundSize = "";
		};

		const setOcrProgress = (value: number, status: string): void => {
			const normalizedValue = Math.max(0, Math.min(100, Math.round(value)));
			setOcrDisplay(`${status}\n\n进度：${normalizedValue}%`, "loading");
			ocrTextInput.style.backgroundImage = `linear-gradient(to right, rgba(34, 211, 238, 0.22) 0%, rgba(34, 211, 238, 0.22) ${normalizedValue}%, rgba(15, 23, 42, 0.18) ${normalizedValue}%, rgba(15, 23, 42, 0.18) 100%)`;
			ocrTextInput.style.backgroundRepeat = "no-repeat";
			ocrTextInput.style.backgroundPosition = "left bottom";
			ocrTextInput.style.backgroundSize = "100% 10px";
		};

		const resetOcrProgress = () => {
			clearOcrProgressTimer();
			clearOcrProgressVisual();
		};

		const setOcrDisplay = (message: string, tone = "default"): void => {
			ocrTextInput.value = message;
			ocrTextInput.classList.remove(
				"text-gray-300",
				"text-primary-200",
				"text-red-300",
				"border-white/10",
				"border-primary-400/30",
				"border-red-400/40",
				"bg-dark-950/80",
				"bg-red-950/20",
			);
			if (tone === "loading") {
				ocrTextInput.classList.add(
					"text-primary-200",
					"border-primary-400/30",
					"bg-dark-950/80",
				);
				return;
			}
			clearOcrProgressVisual();
			if (tone === "error") {
				ocrTextInput.classList.add(
					"text-red-300",
					"border-red-400/40",
					"bg-red-950/20",
				);
				return;
			}
			ocrTextInput.classList.add(
				"text-gray-300",
				"border-white/10",
				"bg-dark-950/80",
			);
		};

		const syncCustomSelectValue = (
			root: HTMLElement,
			nextValue: string,
		): void => {
			const input = root.querySelector("[data-select-input]");
			const label = root.querySelector("[data-select-label]");
			const options = root.querySelectorAll("[data-select-option]");

			if (
				!(input instanceof HTMLInputElement) ||
				!(label instanceof HTMLElement)
			) {
				return;
			}

			input.value = nextValue;
			const activeOption = Array.from(options).find(
				(option) => option.getAttribute("data-value") === nextValue,
			);
			label.textContent =
				activeOption?.getAttribute("data-label") ??
				label.dataset.placeholder ??
				"";
			label.classList.toggle("is-selected", Boolean(nextValue));

			options.forEach((option) => {
				option.classList.toggle(
					"is-active",
					option.getAttribute("data-value") === nextValue,
				);
			});
		};

		const fillFormFromOcr = (
			parsed: ParsedAwardData & { rawText?: string },
		): void => {
			setOcrDisplay(parsed.rawText ?? "");
			if (parsed.competitionName) {
				competitionNameInput.value = parsed.competitionName;
			}
			if (parsed.awardName) {
				awardNameInput.value = parsed.awardName;
			}
			if (parsed.awardYear) {
				yearInput.value = parsed.awardYear;
			}
			if (parsed.awardLevel) {
				syncCustomSelectValue(levelSelectRoot, parsed.awardLevel);
			}
		};

		interface OcrCandidate {
			text: string;
			label?: string;
			averageConfidence?: number;
		}

		interface OcrResponse {
			candidates?: OcrCandidate[];
			error?: string;
		}

		const requestOcrCandidates = (
			file: File,
			jobId: number,
		): Promise<OcrResponse> =>
			new Promise(
				(
					resolve: (value: OcrResponse) => void,
					reject: (reason: Error) => void,
				) => {
					const formData = new FormData();
					formData.append("image", file);

					if (currentOcrRequest) {
						currentOcrRequest.abort();
					}

					const request = new XMLHttpRequest();
					currentOcrRequest = request;
					let simulatedProgress = 38;

					const finishRequest = () => {
						clearOcrProgressTimer();
						if (currentOcrRequest === request) {
							currentOcrRequest = null;
						}
					};

					const startSimulatedProgress = () => {
						clearOcrProgressTimer();
						ocrProgressTimer = window.setInterval(() => {
							if (jobId !== currentOcrJob) {
								return;
							}
							if (simulatedProgress < 72) {
								simulatedProgress += 4;
							} else if (simulatedProgress < 90) {
								simulatedProgress += 1;
							}
							const status =
								simulatedProgress < 65
									? "服务端正在识别荣誉图片文字..."
									: "正在整理 OCR 结果并准备回填...";
							setOcrProgress(simulatedProgress, status);
						}, 320);
					};

					request.open("POST", "/api/admin/awards/ocr");
					request.responseType = "json";

					request.upload.addEventListener("loadstart", () => {
						if (jobId !== currentOcrJob) {
							return;
						}
						setOcrProgress(5, "正在准备上传荣誉文件...");
					});

					request.upload.addEventListener("progress", (event) => {
						if (jobId !== currentOcrJob || !event.lengthComputable) {
							return;
						}
						const percent = 5 + Math.round((event.loaded / event.total) * 30);
						setOcrProgress(percent, "正在上传荣誉文件...");
					});

					request.upload.addEventListener("load", () => {
						if (jobId !== currentOcrJob) {
							return;
						}
						setOcrProgress(38, "文件上传完成，服务端开始识别...");
						startSimulatedProgress();
					});

					request.addEventListener("load", () => {
						finishRequest();
						const payload =
							request.response && typeof request.response === "object"
								? request.response
								: {};
						if (request.status >= 200 && request.status < 300) {
							resolve(payload);
							return;
						}
						reject(
							new Error(
								payload?.error || "自动解析失败，请手动填写表单后提交。",
							),
						);
					});

					request.addEventListener("error", () => {
						finishRequest();
						reject(new Error("OCR 请求失败，请稍后重试。"));
					});

					request.addEventListener("abort", () => {
						finishRequest();
						reject(new Error("OCR 请求已取消。"));
					});

					request.send(formData);
				},
			);

		const parseImageWithOcr = async (file: File): Promise<void> => {
			const jobId = ++currentOcrJob;
			setOcrProgress(5, "正在准备上传荣誉文件...");

			try {
				if (jobId !== currentOcrJob) {
					return;
				}

				const payload = await requestOcrCandidates(file, jobId);
				const candidates = Array.isArray(payload?.candidates)
					? payload.candidates
					: [];

				if (jobId !== currentOcrJob) {
					return;
				}

				let bestCandidate = null;
				const fallbackTexts = [];

				for (const candidate of candidates) {
					if (!candidate?.text) {
						continue;
					}

					fallbackTexts.push(candidate.text);
					const parsed = extractAwardInfoFromTexts([candidate.text]);
					const normalizedCandidate = {
						label: candidate.label ?? "",
						parsed,
						averageConfidence: Number(candidate.averageConfidence) || 0,
						score: scoreOcrCandidate(
							parsed,
							Number(candidate.averageConfidence) || 0,
						),
						filledFields: countFilledFields(parsed),
					};

					if (
						!bestCandidate ||
						normalizedCandidate.score > bestCandidate.score
					) {
						bestCandidate = normalizedCandidate;
					}
				}

				const parsed =
					bestCandidate?.parsed ?? extractAwardInfoFromTexts(fallbackTexts);
				setOcrProgress(96, "正在回填识别结果...");

				if (!parsed.rawText) {
					resetOcrProgress();
					setOcrDisplay(
						"OCR 没有识别出有效文本，请换更清晰的图片后重试。",
						"error",
					);
					return;
				}

				fillFormFromOcr(parsed);
				resetOcrProgress();
			} catch (error) {
				console.error("award ocr failed", error);
				if (jobId !== currentOcrJob) {
					return;
				}
				const message =
					error instanceof Error && error.message
						? `自动解析失败：${error.message}`
						: "自动解析失败，请手动填写表单后提交。";
				resetOcrProgress();
				setOcrDisplay(message, "error");
			}
		};

		const openModal = () => {
			modal.classList.remove("hidden");
			modal.classList.add("flex");
			document.body.style.overflow = "hidden";
		};

		const closeModal = () => {
			modal.classList.add("hidden");
			modal.classList.remove("flex");
			document.body.style.overflow = "";

			const url = new URL(window.location.href);
			if (url.searchParams.has("edit")) {
				url.searchParams.delete("edit");
				window.history.replaceState(
					{},
					"",
					`${url.pathname}${url.search}${url.hash}`,
				);
			}
		};

		const openDeleteModal = (button: HTMLElement): void => {
			currentDeleteForm = button.closest("form");
			deleteName.textContent = `“${button.dataset.awardTitle ?? "该记录"}”`;
			deleteModal.classList.remove("hidden");
			deleteModal.classList.add("flex");
			document.body.style.overflow = "hidden";
		};

		const closeDeleteModal = () => {
			deleteModal.classList.add("hidden");
			deleteModal.classList.remove("flex");
			currentDeleteForm = null;
			document.body.style.overflow = modal.classList.contains("hidden")
				? ""
				: "hidden";
		};

		const resetFormForCreate = () => {
			if (currentOcrRequest) {
				currentOcrRequest.abort();
				currentOcrRequest = null;
			}
			form.reset();
			idInput.value = "";
			syncCustomSelectValue(typeSelectRoot, "奖项");
			yearInput.value = String(currentYear);
			syncCustomSelectValue(levelSelectRoot, "");
			resetOcrProgress();
			setOcrDisplay(modalCopy.ocrNew);
			imageInput.required = true;
			imageLabel.textContent = modalCopy.imageLabelNew;
			imageHint.classList.add("hidden");
			imageLink.href = "#";
			imageLink.textContent = "";
			modalTitle.textContent = modalCopy.createTitle;
			modalDescription.textContent = modalCopy.createDesc;
			submitText.textContent = modalCopy.submitNew;
			submitIcon.setAttribute("name", "ri:add-circle-line");
		};

		interface AwardFormData {
			id?: number;
			honorType?: string;
			competitionName?: string;
			awardName?: string;
			awardYear?: number;
			awardLevel?: string;
			imageName?: string;
			imageUrl?: string;
		}

		const fillFormForEdit = (award: AwardFormData): void => {
			if (currentOcrRequest) {
				currentOcrRequest.abort();
				currentOcrRequest = null;
			}
			idInput.value = String(award.id ?? "");
			syncCustomSelectValue(typeSelectRoot, award.honorType ?? "奖项");
			competitionNameInput.value = award.competitionName ?? "";
			awardNameInput.value = award.awardName ?? "";
			yearInput.value = String(award.awardYear ?? currentYear);
			syncCustomSelectValue(levelSelectRoot, award.awardLevel ?? "");
			resetOcrProgress();
			imageInput.value = "";
			imageInput.required = false;
			setOcrDisplay(modalCopy.ocrEdit);
			imageLabel.textContent = modalCopy.imageLabelEdit;
			imageHint.classList.remove("hidden");
			imageLink.href = award.imageUrl ?? "#";
			imageLink.textContent = award.imageName ?? "查看当前图片";
			modalTitle.textContent = modalCopy.editTitle;
			modalDescription.textContent = modalCopy.editDesc;
			submitText.textContent = modalCopy.submitEdit;
			submitIcon.setAttribute("name", "ri:save-line");
		};
		imageInput.addEventListener(
			"change",
			() => {
				const file = imageInput.files?.[0];
				if (!file) {
					resetOcrProgress();
					setOcrDisplay(
						idInput.value ? modalCopy.ocrEdit : modalCopy.ocrNew,
					);
					return;
				}

				void parseImageWithOcr(file);
			},
			listenerOptions,
		);

		document.addEventListener(
			"click",
			(event: MouseEvent) => {
				const target = event.target as Element;
				if (!(target instanceof Element)) {
					return;
				}

				const openButton = target.closest("[data-open-award-modal]");
				if (openButton instanceof HTMLElement) {
					const mode = openButton.dataset.openAwardModal;
					if (mode === "edit") {
						const idValue = openButton.dataset.awardId ?? "";
						if (!idValue) {
							return;
						}

						fillFormForEdit({
							id: Number(idValue),
							honorType: openButton.dataset.awardType ?? "奖项",
							competitionName: openButton.dataset.awardCompetitionName ?? "",
							awardName: openButton.dataset.awardName ?? "",
							awardYear: Number(openButton.dataset.awardYear ?? currentYear),
							awardLevel: openButton.dataset.awardLevel ?? "",
							imageName: openButton.dataset.awardImageName ?? "",
							imageUrl: openButton.dataset.awardImageUrl ?? "#",
						});
					} else {
						resetFormForCreate();
					}

					openModal();
					return;
				}

				const closeButton = target.closest("[data-close-award-modal]");
				if (closeButton) {
					closeModal();
					return;
				}

				const deleteButton = target.closest("[data-open-delete-modal]");
				if (deleteButton instanceof HTMLElement) {
					openDeleteModal(deleteButton);
					return;
				}

				if (target.closest("[data-close-delete-modal]")) {
					closeDeleteModal();
				}
			},
			listenerOptions,
		);

		confirmDeleteButton.addEventListener(
			"click",
			() => {
				if (currentDeleteForm instanceof HTMLFormElement) {
					currentDeleteForm.submit();
				}
			},
			listenerOptions,
		);

		document.addEventListener(
			"keydown",
			(event) => {
				if (
					event.key === "Escape" &&
					!deleteModal.classList.contains("hidden")
				) {
					closeDeleteModal();
				}
				if (event.key === "Escape" && !modal.classList.contains("hidden")) {
					closeModal();
				}
			},
			listenerOptions,
		);

		if (shouldOpenEditModal && initialEditingAward) {
			fillFormForEdit(initialEditingAward);
			openModal();
		} else if (shouldOpenCreateModal) {
			resetFormForCreate();
			openModal();
		} else {
			resetFormForCreate();
		}
	}

	function initAdminAwardsPartialRefresh() {
		const form = document.querySelector("[data-admin-awards-filter-form]");
		const results = document.querySelector("[data-admin-awards-results]");

		if (
			!(form instanceof HTMLFormElement) ||
			!(results instanceof HTMLElement) ||
			form.dataset.partialReady === "true"
		) {
			return;
		}

		form.dataset.partialReady = "true";

		const buildUrlFromForm = (): URL => {
			const url = new URL(
				form.getAttribute("action") || window.location.pathname,
				window.location.origin,
			);
			const formData = new FormData(form);

			for (const [key, value] of formData.entries()) {
				const normalizedValue = String(value).trim();
				if (normalizedValue) {
					url.searchParams.set(key, normalizedValue);
				}
			}

			return url;
		};

		const syncFormWithUrl = (url: URL): void => {
			const keywordInput = form.querySelector('input[name="q"]');
			if (keywordInput instanceof HTMLInputElement) {
				keywordInput.value = url.searchParams.get("q") ?? "";
			}

			form.querySelectorAll("[data-custom-select-root]").forEach((root) => {
				const input = root.querySelector("[data-select-input]");
				const label = root.querySelector("[data-select-label]");
				const options = root.querySelectorAll("[data-select-option]");

				if (
					!(input instanceof HTMLInputElement) ||
					!(label instanceof HTMLElement)
				) {
					return;
				}

				const nextValue = url.searchParams.get(input.name) ?? "";
				input.value = nextValue;

				const activeOption = Array.from(options).find(
					(option) => option.getAttribute("data-value") === nextValue,
				);
				label.textContent =
					activeOption?.getAttribute("data-label") ??
					label.dataset.placeholder ??
					"";
				label.classList.toggle("is-selected", Boolean(nextValue));

				options.forEach((option) => {
					option.classList.toggle(
						"is-active",
						option.getAttribute("data-value") === nextValue,
					);
				});
			});
		};

		const refreshResults = async (
			url: URL | string,
			replaceHistory = false,
		): Promise<void> => {
			results.setAttribute("aria-busy", "true");
			results.style.opacity = "0.55";

			try {
				const response = await fetch(url, {
					headers: {
						"X-Requested-With": "admin-awards-partial",
					},
				});

				if (!response.ok) {
					window.location.href = typeof url === "string" ? url : url.toString();
					return;
				}

				const html = await response.text();
				const doc = new DOMParser().parseFromString(html, "text/html");
				const nextResults = doc.querySelector("[data-admin-awards-results]");

				if (!(nextResults instanceof HTMLElement)) {
					window.location.href = typeof url === "string" ? url : url.toString();
					return;
				}

				results.innerHTML = nextResults.innerHTML;
				if (replaceHistory) {
					window.history.replaceState({}, "", url);
				} else {
					window.history.pushState({}, "", url);
				}
			} finally {
				results.style.opacity = "";
				results.removeAttribute("aria-busy");
			}
		};

		form.addEventListener("submit", async (event: SubmitEvent) => {
			event.preventDefault();
			await refreshResults(buildUrlFromForm().toString());
		});

		form.addEventListener("click", async (event: MouseEvent) => {
			const target = event.target as Element;
			if (!(target instanceof Element)) {
				return;
			}

			const clearLink = target.closest("[data-admin-awards-clear]");
			if (!(clearLink instanceof HTMLAnchorElement)) {
				return;
			}

			event.preventDefault();
			const url = new URL(clearLink.href, window.location.origin);
			syncFormWithUrl(url);
			await refreshResults(url.toString());
		});

		results.addEventListener("click", async (event: MouseEvent) => {
			const target = event.target as Element;
			if (!(target instanceof Element)) {
				return;
			}

			const link = target.closest("a[href]");
			if (!(link instanceof HTMLAnchorElement)) {
				return;
			}

			const url = new URL(link.href, window.location.origin);
			if (
				url.origin !== window.location.origin ||
				url.pathname !== "/admin/awards"
			) {
				return;
			}

			event.preventDefault();
			await refreshResults(url.toString());
		});

		const awardsWindow = window as Window & {
			__adminAwardsPopstateHandler?: () => void;
		};
		if (awardsWindow.__adminAwardsPopstateHandler) {
			window.removeEventListener(
				"popstate",
				awardsWindow.__adminAwardsPopstateHandler,
			);
		}
		const popstateHandler = () => {
			const url = new URL(window.location.href);
			syncFormWithUrl(url);
			void refreshResults(url.toString(), true);
		};
		window.addEventListener("popstate", popstateHandler);
		awardsWindow.__adminAwardsPopstateHandler = popstateHandler;
	}

	function initAwardToast() {
		const ensureStack = () => {
			const existing = document.getElementById("notification-stack");
			if (existing instanceof HTMLElement) {
				return existing;
			}

			const stack = document.createElement("div");
			stack.id = "notification-stack";
			stack.className = "notification-stack";
			stack.setAttribute("aria-live", "polite");
			stack.setAttribute("aria-atomic", "false");
			document.body.appendChild(stack);
			return stack;
		};

		const removeToast = (toast: HTMLElement): void => {
			if (!(toast instanceof HTMLElement) || toast.dataset.leaving === "true") {
				return;
			}

			toast.dataset.leaving = "true";
			toast.classList.remove("is-entering");
			toast.classList.add("is-leaving");
			window.setTimeout(() => {
				toast.remove();
			}, 300);
		};

		interface ToastOptions {
			message: string;
			variant?: "success" | "error";
			title?: string;
			duration?: number;
		}

		const showToast = ({
			message,
			variant = "success",
			title,
			duration = 3000,
		}: ToastOptions): HTMLElement | undefined => {
			if (!message) {
				return;
			}

			const stack = ensureStack();
			const toast = document.createElement("section");
			const resolvedTitle =
				title ?? (variant === "error" ? "操作失败" : "操作成功");
			const icon =
				variant === "error"
					? '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="16.5" r="1" fill="currentColor"/><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>'
					: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7L9 18l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

			toast.className = `notification notification--${variant} is-entering`;
			toast.setAttribute("role", "status");
			toast.style.setProperty("--toast-duration", `${duration}ms`);
			toast.innerHTML = `
				<div class="notification__glow" aria-hidden="true"></div>
				<div class="notification__row">
					<div class="notification__icon" aria-hidden="true">${icon}</div>
					<div class="notification__content">
						<div class="notification__title">${resolvedTitle}</div>
						<div class="notification__message"></div>
					</div>
					<button type="button" class="notification__close" aria-label="关闭通知">×</button>
				</div>
				<div class="notification__progress" aria-hidden="true"></div>
			`;
			const messageNode = toast.querySelector(".notification__message");
			if (messageNode instanceof HTMLElement) {
				messageNode.textContent = message;
			}

			const closeButton = toast.querySelector(".notification__close");
			if (closeButton instanceof HTMLButtonElement) {
				closeButton.addEventListener("click", () => removeToast(toast));
			}

			stack.appendChild(toast);
			window.setTimeout(() => removeToast(toast), duration);
			return toast;
		};

		if (typeof window !== "undefined") {
			(
				window as unknown as { showAwardToast: typeof showToast }
			).showAwardToast = showToast;
		}

		document.querySelectorAll("[data-toast-source]").forEach((source) => {
			if (
				!(source instanceof HTMLElement) ||
				source.dataset.toastConsumed === "true"
			) {
				return;
			}

			source.dataset.toastConsumed = "true";
			showToast({
				message: source.textContent?.trim() ?? "",
				variant: source.dataset.toastVariant === "error" ? "error" : "success",
				title: source.dataset.toastTitle ?? undefined,
				duration: Number(source.dataset.toastDuration ?? "3000") || 3000,
			});
		});

		const currentUrl = new URL(window.location.href);
		const transientParams = ["status", "code", "edit"];
		let didUpdateUrl = false;
		transientParams.forEach((key) => {
			if (currentUrl.searchParams.has(key)) {
				currentUrl.searchParams.delete(key);
				didUpdateUrl = true;
			}
		});
		if (didUpdateUrl) {
			window.history.replaceState(
				{},
				"",
				`${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`,
			);
		}
	}

	const runAwardsPageInit = () => {
		if (window.location.pathname !== "/admin/awards") {
			return;
		}
		initCustomSelects();
		initAwardAdmin();
		initAdminAwardsPartialRefresh();
		initAwardToast();
	};

	runAwardsPageInit();

	const awardsWindow = window as Window & {
		__adminAwardsPageLoadBound?: boolean;
	};
	if (!awardsWindow.__adminAwardsPageLoadBound) {
		document.addEventListener("astro:page-load", runAwardsPageInit);
		awardsWindow.__adminAwardsPageLoadBound = true;
	}
</script>
