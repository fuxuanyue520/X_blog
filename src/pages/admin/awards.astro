<script>
	interface Window {
		showAwardToast?: (options: {
			message: string;
			variant?: "success" | "error";
			title?: string;
			duration?: number;
		}) => HTMLElement | undefined;
	}

	function normalizePlainText(value: string): string {
		return value.replace(/\s+/g, " ").trim();
	}

	function normalizeCompactText(value: string): string {
		return value.replace(/\s+/g, "");
	}

	function normalizeCompetitionName(value: string): string {
		return value
			.replace(/^(在|于)/u, "")
			.replace(/^(?:19|20)\d{2}年/u, "")
			.replace(/^(?:\d{4}[./-]\d{1,2}[./-]\d{1,2})/u, "")
			.replace(/(荣获|获得|取得|获评|被评为).*$/u, "")
			.replace(/^(?:我校学生?|学生?)在/u, "")
			.replace(/^(?:学校|院校|项目|作品|团队|队伍)[:：]/u, "")
			.replace(/[，。；：:,]+$/u, "")
			.trim();
	}

	function isLikelySchoolLine(
		line: string,
		competitionKeywords: RegExp,
	): boolean {
		if (/^(学校|院校)[:：]/u.test(line)) {
			return true;
		}

		return (
			/(大学|学院|学校|中学|小学|幼儿园|职业技术|实验学校)/u.test(line) &&
			!competitionKeywords.test(line)
		);
	}

	function uniqueValues(values: string[]): string[] {
		return [...new Set(values.filter(Boolean))];
	}

	function getOcrLines(texts: string[]): string[] {
		return uniqueValues(
			texts.flatMap((text) =>
				text
					.replace(/\r/g, "")
					.split(/\n+/)
					.map((line) => normalizePlainText(line))
					.filter(Boolean),
			),
		);
	}

	function buildOcrRawText(texts: string[]): string {
		const mergedLines: string[] = [];
		const seen = new Set<string>();

		for (const text of texts) {
			const lines = String(text ?? "")
				.replace(/\r/g, "")
				.split(/\n+/)
				.map((line) => normalizePlainText(line))
				.filter(Boolean);

			for (const line of lines) {
				if (seen.has(line)) {
					continue;
				}
				seen.add(line);
				mergedLines.push(line);
			}
		}

		return mergedLines.join("\n");
	}

	function findAwardName(text: string, lines: string[]): string {
		const actionMatch = normalizeCompactText(text).match(
			/(?:荣获|获得|取得|获评|被评为)(特等奖学金|一等奖学金|二等奖学金|三等奖学金|团体特等奖|团体一等奖|团体二等奖|团体三等奖|特等奖|一等奖|二等奖|三等奖|金奖|银奖|铜奖|优秀奖|优胜奖|入围奖|成功参赛奖|纪念奖|冠军|亚军|季军|第[一二三四五六七八九十百零]+名|第\d+名)/u,
		);
		if (actionMatch?.[1]) {
			return actionMatch[1];
		}

		const candidates = [
			/(国家奖学金|国家励志奖学金|校一等奖学金|校二等奖学金|校三等奖学金)/u,
			/(特等奖学金|一等奖学金|二等奖学金|三等奖学金|优秀毕业生)/u,
			/(最佳组织奖|优秀组织奖|最佳人气奖|最佳创意奖|最佳表现奖|道德风尚奖)/u,
			/(团体特等奖|团体一等奖|团体二等奖|团体三等奖)/u,
			/(特等奖|一等奖|二等奖|三等奖|金奖|银奖|铜奖|优秀奖|优胜奖|入围奖|成功参赛奖|纪念奖)/u,
			/(冠军|亚军|季军)/u,
			/(第[一二三四五六七八九十百零]+名|第\d+名)/u,
		];

		for (const line of lines) {
			for (const pattern of candidates) {
				const match = line.match(pattern);
				if (match) {
					return match[0];
				}
			}
		}

		for (const pattern of candidates) {
			const match = text.match(pattern);
			if (match) {
				return match[0];
			}
		}

		return "";
	}

	function findCompetitionName(
		lines: string[],
		text: string,
		awardName?: string,
	): string {
		const competitionKeywords =
			/(竞赛|大赛|比赛|挑战赛|评选|活动|杯|建模|程序设计|电子设计|创新创业|互联网\+|机器人大赛|演讲赛|辩论赛|运动会|技能赛|作品赛|创业赛|创青春|挑战杯|英语赛|数学赛|物理赛|化学赛)/u;
		const compactText = normalizeCompactText(text);
		const cleanedLines = lines
			.map((line) => normalizePlainText(line))
			.filter(Boolean)
			.filter(
				(line) =>
					!/^(荣誉证书|获奖证书|证书|奖状|特发此状|特发此证|兹授予|兹证明)$/u.test(
						line,
					),
			)
			.filter((line) => !isLikelySchoolLine(line, competitionKeywords))
			.filter(
				(line) => !/^(姓名|学号|班级|专业|院系|日期|时间|地点)/u.test(line),
			);

		const directPatterns = [
			/(?:在|于)(.+?)(?:中|活动中|比赛中|竞赛中|大赛中|挑战赛中|评选中).{0,20}(?:荣获|获得|取得|获评|被评为)/u,
			/((?:19|20)\d{2}年.+?(?:竞赛|大赛|比赛|挑战赛|评选|活动|杯))(?:中)?(?:荣获|获得|取得|获评|被评为)/u,
			/((?:第[一二三四五六七八九十百零\d]+届)?[^，。；：]*?(?:竞赛|大赛|比赛|挑战赛|评选|活动|杯))(?:中)?(?:荣获|获得|取得|获评|被评为)/u,
		];

		for (const pattern of directPatterns) {
			const directMatch = text.match(pattern) ?? compactText.match(pattern);
			if (directMatch?.[1]) {
				return normalizeCompetitionName(directMatch[1]);
			}
		}

		for (const line of cleanedLines) {
			const inlineMatch = line.match(
				/((?:19|20)\d{2}年.+?(?:竞赛|大赛|比赛|挑战赛|评选|活动|杯)|(?:第[一二三四五六七八九十百零\d]+届)?[^，。；：]*?(?:竞赛|大赛|比赛|挑战赛|评选|活动|杯))(?:中)?(?:荣获|获得|取得|获评|被评为)?/u,
			);
			if (inlineMatch?.[1] && competitionKeywords.test(inlineMatch[1])) {
				return normalizeCompetitionName(inlineMatch[1]);
			}

			if (!awardName || !line.includes(awardName)) {
				continue;
			}

			const strippedLine = normalizeCompetitionName(
				line
					.replace(awardName, "")
					.replace(/(荣获|获得|取得|获评|被评为)/gu, "")
					.trim(),
			);
			if (strippedLine.length >= 4 && competitionKeywords.test(strippedLine)) {
				return strippedLine;
			}
		}

		const preferredLine = cleanedLines
			.filter((line) => !awardName || !line.includes(awardName))
			.find((line) => competitionKeywords.test(line));
		if (preferredLine) {
			return normalizeCompetitionName(preferredLine);
		}

		const awardLineIndex = cleanedLines.findIndex(
			(line) => awardName && line.includes(awardName),
		);
		if (awardLineIndex > 0) {
			const previousLine = cleanedLines[awardLineIndex - 1];
			if (competitionKeywords.test(previousLine)) {
				return normalizeCompetitionName(previousLine);
			}
		}

		const longestLine = cleanedLines
			.filter((line) => line.length >= 6)
			.filter((line) => !awardName || !line.includes(awardName))
			.sort((left, right) => right.length - left.length)[0];

		return longestLine ? normalizeCompetitionName(longestLine) : "";
	}

	function findAwardYear(text: string): string {
		const match = text.match(/((?:19|20)\d{2})/);
		return match ? match[1] : "";
	}

	function findAwardLevel(text: string): string {
		const compactText = normalizeCompactText(text);
		if (/(世界|国际|全球|洲际)/u.test(compactText)) {
			return "世界级";
		}
		if (/(全国|国家|国赛)/u.test(compactText)) {
			return "国家级";
		}
		if (/(全省|省级|省赛|自治区|直辖市)/u.test(compactText)) {
			return "省级";
		}
		if (/(全市|市级|市赛)/u.test(compactText)) {
			return "市级";
		}
		if (/(校级|校赛|本校)/u.test(compactText)) {
			return "校级";
		}
		return "";
	}

	interface ParsedAwardData {
		competitionName?: string;
		awardName?: string;
		awardYear?: string;
		awardLevel?: string;
	}

	function summarizeFilledFields(parsed: ParsedAwardData): string[] {
		const labels: string[] = [];
		if (parsed.competitionName) {
			labels.push("名称");
		}
		if (parsed.awardName) {
			labels.push("名次");
		}
		if (parsed.awardYear) {
			labels.push("年份");
		}
		if (parsed.awardLevel) {
			labels.push("级别");
		}
		return labels;
	}

	function countFilledFields(parsed: ParsedAwardData): number {
		return summarizeFilledFields(parsed).length;
	}

	function hasStrongFieldSignal(parsed: ParsedAwardData): boolean {
		return Boolean(
			parsed.competitionName ||
			parsed.awardName ||
			parsed.awardYear ||
			parsed.awardLevel,
		);
	}

	function analyzeOcrTextQuality(text: string) {
		const compactText = normalizeCompactText(text);
		const totalChars = compactText.length || 1;
		const chineseChars = (compactText.match(/[\u4e00-\u9fff]/gu) ?? []).length;
		const wordChars = (compactText.match(/[\u4e00-\u9fffA-Za-z0-9]/gu) ?? [])
			.length;
		const noisyChars = (
			compactText.match(
				/[^0-9A-Za-z\u4e00-\u9fff()（）【】\[\]《》“”"'‘’、，。！？；：:,.·\-+/#&]/gu,
			) ?? []
		).length;

		return {
			totalChars,
			chineseChars,
			wordChars,
			noisyChars,
			wordRatio: wordChars / totalChars,
			noiseRatio: noisyChars / totalChars,
			chineseRatio: chineseChars / totalChars,
		};
	}

	function scoreOcrCandidate(
		parsed: ParsedAwardData & { rawText?: string },
		averageConfidence = 0,
	): number {
		const quality = analyzeOcrTextQuality(parsed.rawText ?? "");
		const filledFields = countFilledFields(parsed);
		let score = 0;

		score += filledFields * 100;
		score += Math.round(averageConfidence * 35);
		score += Math.min(40, Math.round(quality.wordRatio * 30));
		score += Math.min(20, Math.round(quality.chineseRatio * 20));
		score -= Math.min(45, Math.round(quality.noiseRatio * 120));
		score += Math.min(18, Math.round(quality.totalChars / 6));

		if (parsed.competitionName) {
			score += 22;
		}
		if (parsed.awardName) {
			score += 26;
		}
		if (parsed.awardYear) {
			score += 14;
		}

		return score;
	}

	function extractAwardInfoFromTexts(
		texts: string[],
	): ParsedAwardData & { rawText: string } {
		const rawText = buildOcrRawText(texts);
		const lines = getOcrLines([rawText]);
		const flatText = normalizePlainText(rawText);
		const awardName = findAwardName(flatText, lines);
		const competitionName = findCompetitionName(lines, flatText, awardName);

		return {
			rawText,
			competitionName,
			awardName,
			awardYear: findAwardYear(flatText),
			awardLevel: findAwardLevel(flatText),
		};
	}

	function initCustomSelects() {
		document.querySelectorAll("[data-custom-select-root]").forEach((root) => {
			if (!(root instanceof HTMLElement)) {
				return;
			}

			if (root.dataset.selectReady === "true") {
				return;
			}

			const form = root.closest("form");
			const details = root.querySelector("details");
			const summary = root.querySelector("summary");
			const input = root.querySelector("[data-select-input]");
			const label = root.querySelector("[data-select-label]");
			const options = root.querySelectorAll("[data-select-option]");

			if (
				!(form instanceof HTMLFormElement) ||
				!(details instanceof HTMLDetailsElement) ||
				!(summary instanceof HTMLElement) ||
				!(input instanceof HTMLInputElement) ||
				!(label instanceof HTMLElement) ||
				options.length === 0
			) {
				return;
			}

			root.dataset.selectReady = "true";
			let closeTimer: number | undefined;

			root.addEventListener("mouseenter", () => {
				if (closeTimer) {
					clearTimeout(closeTimer);
				}
			});

			root.addEventListener("mouseleave", () => {
				closeTimer = window.setTimeout(() => {
					details.removeAttribute("open");
				}, 120);
			});

			summary.addEventListener("click", (event) => {
				event.preventDefault();
				if (closeTimer) {
					clearTimeout(closeTimer);
				}

				if (details.hasAttribute("open")) {
					details.removeAttribute("open");
				} else {
					document
						.querySelectorAll("[data-custom-select-root] details[open]")
						.forEach((item) => {
							if (item !== details) {
								item.removeAttribute("open");
							}
						});
					details.setAttribute("open", "");
				}
			});

			options.forEach((option) => {
				option.addEventListener("click", () => {
					const nextValue = option.getAttribute("data-value") ?? "";
					const nextLabel =
						option.getAttribute("data-label") ??
						option.textContent?.trim() ??
						"";

					input.value = nextValue;
					label.textContent = nextLabel;
					label.classList.toggle("is-selected", Boolean(nextValue));
					input.dispatchEvent(new Event("change", { bubbles: true }));

					options.forEach((item) => item.classList.remove("is-active"));
					option.classList.add("is-active");
					details.removeAttribute("open");
					if (root.dataset.selectSubmitOnChange === "true") {
						form.requestSubmit();
					}
				});
			});
		});
	}

