---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminShell from "@/components/admin/AdminShell.astro";
import { getAuthenticatedAdmin } from "@/lib/auth";
import {
	ARTICLE_CATEGORIES,
	getAdminArticleBySlug,
	listAdminArticles,
} from "@/lib/articles";
import { Icon } from "astro-icon/components";

export const prerender = false;

const admin = await getAuthenticatedAdmin(Astro);

if (!admin) {
	return Astro.redirect("/?login=1");
}

const status = Astro.url.searchParams.get("status") ?? "";
const code = Astro.url.searchParams.get("code") ?? "";
const highlightSlug = Astro.url.searchParams.get("highlight")?.trim() ?? "";
const editSlug = Astro.url.searchParams.get("edit")?.trim() ?? "";
const createRequested = Astro.url.searchParams.get("create") === "1";
const keyword = Astro.url.searchParams.get("q")?.trim() ?? "";
const selectedCategory = Astro.url.searchParams.get("category")?.trim() ?? "";
const selectedState = Astro.url.searchParams.get("state")?.trim() ?? "";

const [allDocuments, editingDocument] = await Promise.all([
	listAdminArticles(),
	editSlug ? getAdminArticleBySlug(editSlug) : Promise.resolve(null),
]);

const filteredDocuments = allDocuments.filter((document) => {
	if (selectedCategory && document.category !== selectedCategory) {
		return false;
	}

	if (selectedState === "published" && document.draft) {
		return false;
	}

	if (selectedState === "draft" && !document.draft) {
		return false;
	}

	if (keyword) {
		const query = keyword.toLowerCase();
		const haystack = [
			document.slug,
			document.title,
			document.description,
			document.category,
			document.tags.join(" "),
			document.body,
		]
			.join(" ")
			.toLowerCase();
		return haystack.includes(query);
	}

	return true;
});

const categoryLabels: Record<string, string> = {
	tech: "技术",
	essay: "随笔",
	project: "项目",
	other: "其他",
};

const statusMessages: Record<string, string> = {
	created: "文章已创建成功。",
	updated: "文章内容已更新。",
	deleted: "文章已删除。",
	invalid_document: "没有找到要操作的文章。",
	invalid_title: "文章标题不能为空。",
	invalid_slug: "文章 slug 无效，请使用英文、数字或短横线。",
	duplicate_slug: "该 slug 已存在，请更换后再保存。",
	invalid_category: "文章分类不在允许范围内。",
	invalid_published_at: "发布时间不能为空。",
	save_failed: "保存失败，请稍后重试。",
};

const effectiveStatus =
	!status && editSlug && !editingDocument ? "error" : status;
const effectiveCode =
	!status && editSlug && !editingDocument ? "invalid_document" : code;
const feedbackMessage =
	effectiveStatus === "error"
		? statusMessages[effectiveCode]
		: statusMessages[effectiveStatus];
const toastVariant = effectiveStatus === "error" ? "error" : "success";
const toastTitle =
	effectiveStatus === "created"
		? "创建成功"
		: effectiveStatus === "updated"
			? "保存成功"
			: effectiveStatus === "deleted"
				? "删除成功"
				: effectiveStatus === "error"
					? "操作失败"
					: "提示";

const modalDocument = editingDocument;
const shouldOpenEditModal = Boolean(modalDocument);
const shouldOpenCreateModal = createRequested && !shouldOpenEditModal;
const shouldOpenEditor = shouldOpenEditModal || shouldOpenCreateModal;

const currentSearch = new URLSearchParams(Astro.url.searchParams);

function buildAdminLink(overrides: Record<string, string | undefined>) {
	const nextSearch = new URLSearchParams(currentSearch);

	for (const [key, value] of Object.entries(overrides)) {
		if (value === undefined || value === "") {
			nextSearch.delete(key);
		} else {
			nextSearch.set(key, value);
		}
	}

	const query = nextSearch.toString();
	return `/admin/documents${query ? `?${query}` : ""}`;
}

function toDatetimeLocalValue(value?: string) {
	if (!value) {
		return "";
	}

	return value.slice(0, 16);
}

function toDateLabel(value: string) {
	const timestamp = new Date(value).getTime();
	if (Number.isNaN(timestamp)) {
		return value;
	}

	return new Date(timestamp).toLocaleString("zh-CN", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		hour: "2-digit",
		minute: "2-digit",
	});
}

const clearFilterUrl = buildAdminLink({
	q: undefined,
	category: undefined,
	state: undefined,
	status: undefined,
	code: undefined,
	edit: undefined,
	create: undefined,
	highlight: undefined,
});
const createUrl = buildAdminLink({
	create: "1",
	edit: undefined,
	status: undefined,
	code: undefined,
	highlight: undefined,
});
const closeModalUrl = buildAdminLink({
	edit: undefined,
	create: undefined,
	status: undefined,
	code: undefined,
});
---

<BaseLayout title="文档管理" description="后台管理博客文章与数据库内容">
	<AdminShell activeSection="documents">
		{
			feedbackMessage && (
				<div
					hidden
					data-toast-source
					data-toast-variant={toastVariant}
					data-toast-title={toastTitle}
					data-toast-duration="3200"
				>
					{feedbackMessage}
				</div>
			)
		}

		<div class="rounded-3xl border border-white/10 bg-dark-800/70 p-4 md:p-5">
			<div
				class="mb-4 flex flex-col gap-2.5 md:flex-row md:items-center md:justify-between"
			>
				<div>
					<h2 class="text-xl font-semibold text-white md:text-2xl">文档列表</h2>
					<p class="mt-2 text-sm text-gray-400">
						支持新建文章、编辑元信息与正文，也可以导入 Markdown 直接解析。
					</p>
				</div>
				<div class="flex flex-wrap gap-3">
					<a
						href="/archive"
						target="_blank"
						class="inline-flex min-h-[42px] items-center gap-2 rounded-xl border border-white/10 px-4 py-2 text-sm font-medium text-gray-300 transition hover:border-primary-400 hover:text-primary-300"
					>
						<Icon name="ri:archive-line" class="text-base" />
						查看归档页
					</a>
					<a
						href={createUrl}
						class="inline-flex min-h-[42px] items-center gap-2 rounded-xl bg-primary-500 px-4 py-2 text-sm font-medium text-white shadow-[0_10px_24px_rgba(14,165,233,0.16)] transition hover:bg-primary-600 hover:shadow-[0_12px_28px_rgba(14,165,233,0.22)]"
					>
						<Icon name="ri:add-circle-line" class="text-lg" />
						新建文章
					</a>
				</div>
			</div>

			<form action="/admin/documents" method="GET" class="mb-4 space-y-2.5">
				<div
					class="grid items-center gap-2.5 sm:grid-cols-[minmax(0,1fr)_auto]"
				>
					<div class="relative">
						<input
							type="search"
							name="q"
							value={keyword}
							placeholder="搜索标题、描述、标签、slug 或正文"
							class="min-h-[48px] w-full rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-2.5 text-sm text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
						/>
					</div>
					<button
						type="submit"
						class="inline-flex min-h-[48px] items-center justify-center rounded-2xl bg-primary-500 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-primary-600 sm:min-w-[112px]"
					>
						搜索
					</button>
				</div>
				<div
					class="grid items-center gap-2.5 md:grid-cols-2 xl:grid-cols-[repeat(2,minmax(0,1fr))_auto]"
				>
					<select
						name="category"
						class="min-h-[48px] rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-2.5 text-sm text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
					>
						<option value="">全部分类</option>
						{
							ARTICLE_CATEGORIES.map((category) => (
								<option
									value={category}
									selected={selectedCategory === category}
								>
									{categoryLabels[category]}
								</option>
							))
						}
					</select>
					<select
						name="state"
						class="min-h-[48px] rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-2.5 text-sm text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
					>
						<option value="">全部状态</option>
						<option value="published" selected={selectedState === "published"}>
							已发布
						</option>
						<option value="draft" selected={selectedState === "draft"}>
							草稿
						</option>
					</select>
					<a
						href={clearFilterUrl}
						class="inline-flex min-h-[48px] items-center justify-center rounded-2xl border border-white/10 px-4 py-2.5 text-sm font-medium text-gray-300 transition hover:border-primary-400 hover:text-primary-300 xl:min-w-[112px]"
					>
						清空
					</a>
				</div>
			</form>

			<div class="space-y-3">
				{
					filteredDocuments.length > 0 ? (
						filteredDocuments.map((document) => (
							<article
								id={
									highlightSlug === document.slug
										? `document-${document.slug}`
										: undefined
								}
								class:list={[
									"rounded-2xl border border-white/10 bg-dark-900/60 p-4 md:p-5",
									highlightSlug === document.slug
										? "border-primary-400/50 shadow-[0_0_0_1px_rgba(34,211,238,0.3)]"
										: "",
								]}
							>
								<div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
									<div class="min-w-0">
										<div class="flex flex-wrap items-center gap-2">
											<h3 class="truncate text-lg font-semibold text-white">
												{document.title}
											</h3>
											<span
												class:list={[
													"rounded-full border px-3 py-1 text-xs",
													document.draft
														? "border-amber-500/20 bg-amber-500/10 text-amber-200"
														: "border-emerald-500/20 bg-emerald-500/10 text-emerald-200",
												]}
											>
												{document.draft ? "草稿" : "已发布"}
											</span>
											<span class="rounded-full border border-white/10 bg-dark-800 px-3 py-1 text-xs text-gray-300">
												{categoryLabels[document.category]}
											</span>
											{document.isPinned && (
												<span class="rounded-full border border-primary-500/30 bg-primary-500/10 px-3 py-1 text-xs text-primary-200">
													置顶
												</span>
											)}
										</div>
										<p class="mt-2 break-all text-xs text-gray-500">
											slug: {document.slug}
										</p>
										<p class="mt-3 text-sm leading-7 text-gray-400">
											{document.description || document.excerpt}
										</p>
										<div class="mt-4 flex flex-wrap gap-2 text-sm text-gray-300">
											<span class="rounded-full border border-white/10 bg-dark-800 px-3 py-1">
												发布时间 {toDateLabel(document.publishedAt)}
											</span>
											{document.updatedAt && (
												<span class="rounded-full border border-white/10 bg-dark-800 px-3 py-1">
													更新时间 {toDateLabel(document.updatedAt)}
												</span>
											)}
											<span class="rounded-full border border-white/10 bg-dark-800 px-3 py-1">
												标签 {document.tags.length}
											</span>
										</div>
										{document.tags.length > 0 && (
											<div class="mt-3 flex flex-wrap gap-2">
												{document.tags.map((tag) => (
													<span class="rounded-full border border-white/10 bg-dark-800 px-2.5 py-1 text-xs text-gray-300">
														#{tag}
													</span>
												))}
											</div>
										)}
									</div>

									<div class="flex flex-wrap gap-2">
										<a
											href={`/posts/${document.slug}`}
											target="_blank"
											class="inline-flex min-h-[40px] items-center justify-center gap-1.5 rounded-xl border border-white/10 px-3 py-2 text-sm font-medium text-gray-200 transition hover:border-primary-400 hover:text-primary-300"
										>
											<Icon name="ri:external-link-line" class="text-base" />
											查看
										</a>
										<a
											href={buildAdminLink({
												edit: document.slug,
												create: undefined,
												status: undefined,
												code: undefined,
											})}
											class="inline-flex min-h-[40px] items-center justify-center gap-1.5 rounded-xl border border-white/10 px-3 py-2 text-sm font-medium text-gray-200 transition hover:border-primary-400 hover:text-primary-300"
										>
											<Icon name="ri:edit-line" class="text-base" />
											编辑
										</a>
										<button
											type="button"
											class="inline-flex min-h-[40px] items-center justify-center gap-1.5 rounded-xl border border-red-500/20 bg-red-500/10 px-3 py-2 text-sm font-medium text-red-200 transition hover:border-red-500/40 hover:bg-red-500/15"
											data-open-delete-modal
											data-document-slug={document.slug}
											data-document-title={document.title}
										>
											<Icon name="ri:delete-bin-line" class="text-base" />
											删除
										</button>
									</div>
								</div>
							</article>
						))
					) : (
						<div class="rounded-3xl border border-dashed border-white/10 bg-dark-900/40 p-8 text-center">
							<p class="text-lg font-medium text-white">当前条件下还没有文章</p>
							<p class="mt-3 text-sm text-gray-400">
								可以换一个筛选条件试试，或者点击右上角“新建文章”新增内容。
							</p>
						</div>
					)
				}
			</div>
		</div>

		<div
			id="document-modal"
			data-open={shouldOpenEditor ? "true" : "false"}
			data-close-url={closeModalUrl}
			class:list={[
				"fixed inset-0 z-[200] flex items-center justify-center overflow-y-auto px-3 py-6 sm:px-5 sm:py-8",
				{ hidden: !shouldOpenEditor },
			]}
		>
			<button
				type="button"
				class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
				data-close-document-modal
				aria-label="关闭弹窗"></button>

			<div
				class="relative z-10 my-auto flex max-h-[calc(100vh-3rem)] w-full max-w-5xl flex-col overflow-hidden rounded-[24px] border border-white/10 bg-dark-800/95 shadow-2xl shadow-black/40 sm:max-h-[calc(100vh-4rem)]"
			>
				<div
					class="flex items-start justify-between gap-4 border-b border-white/10 bg-white/[0.02] px-4 py-3 md:px-6"
				>
					<div>
						<p class="text-sm uppercase tracking-[0.35em] text-primary-400">
							Document
						</p>
						<h2 class="mt-3 text-2xl font-semibold text-white">
							{shouldOpenEditModal ? "编辑文章" : "新建文章"}
						</h2>
						<p class="mt-2 text-sm text-gray-400">
							支持直接在线编辑 Markdown，也支持导入 `.md` 文件自动解析
							frontmatter。
						</p>
					</div>
					<button
						type="button"
						class="rounded-full p-2 text-gray-400 transition hover:bg-white/5 hover:text-white"
						data-close-document-modal
						aria-label="关闭"
					>
						<Icon name="ri:close-line" class="text-xl" />
					</button>
				</div>

				<form
					id="document-form"
					method="POST"
					action="/api/admin/documents/save"
					class="flex min-h-0 flex-1 flex-col"
				>
					<input
						id="document-current-slug"
						type="hidden"
						name="currentSlug"
						value={modalDocument?.slug ?? ""}
					/>
					<div
						class="panel-scrollbar min-h-0 flex-1 space-y-4 overflow-y-auto px-4 pb-4 pt-3 md:px-6 md:pb-4 md:pt-4"
					>
						<section
							class="rounded-2xl border border-white/10 bg-dark-900/50 p-4"
						>
							<div class="flex items-start gap-3">
								<div
									class="mt-0.5 rounded-xl bg-primary-500/10 p-2 text-primary-300"
								>
									<Icon name="ri:file-upload-line" class="text-xl" />
								</div>
								<div class="min-w-0 flex-1">
									<h3 class="text-base font-semibold text-white">
										导入 Markdown
									</h3>
									<p class="mt-1 text-sm leading-6 text-gray-400">
										选择本地 `.md` 或 `.markdown` 文件后，会自动解析 frontmatter
										和正文并填充到表单中。
									</p>
									<div
										class="mt-4 grid gap-3 md:grid-cols-[minmax(0,1fr)_auto]"
									>
										<input
											id="document-import-file"
											type="file"
											accept=".md,.markdown,text/markdown,text/plain"
											class="document-form__control document-form__upload"
										/>
										<button
											type="button"
											id="document-import-button"
											class="inline-flex min-h-[44px] items-center justify-center rounded-xl border border-white/10 px-4 py-2 text-sm font-medium text-gray-200 transition hover:border-primary-400 hover:text-primary-300 md:min-w-[120px]"
										>
											解析导入
										</button>
									</div>
									<p
										id="document-import-feedback"
										class="mt-3 text-sm text-gray-400"
									>
										导入不会立即保存，你还可以继续修改后再提交。
									</p>
								</div>
							</div>
						</section>

						<div class="document-form__grid document-form__grid--primary">
							<div>
								<label for="document-title" class="document-form__label"
									>标题</label
								>
								<input
									id="document-title"
									name="title"
									type="text"
									required
									value={modalDocument?.title ?? ""}
									class="document-form__control"
									placeholder="例如：如何搭建自己的博客"
								/>
							</div>
							<div>
								<label for="document-slug" class="document-form__label"
									>Slug</label
								>
								<input
									id="document-slug"
									name="slug"
									type="text"
									value={modalDocument?.slug ?? ""}
									class="document-form__control"
									placeholder="例如：how-to-build-a-blog"
								/>
								<p class="mt-2 text-xs text-gray-500">
									建议使用英文、数字和短横线，提交后将作为文章路径。
								</p>
							</div>
						</div>

						<div>
							<label for="document-description" class="document-form__label">
								摘要
							</label>
							<textarea
								id="document-description"
								name="description"
								rows="3"
								class="document-form__control document-form__textarea"
								placeholder="用于首页卡片和文章详情页简介展示"
								>{modalDocument?.description ?? ""}</textarea
							>
						</div>

						<div class="document-form__grid document-form__grid--meta">
							<div>
								<label for="document-category" class="document-form__label">
									分类
								</label>
								<select
									id="document-category"
									name="category"
									class="document-form__control"
								>
									{
										ARTICLE_CATEGORIES.map((category) => (
											<option
												value={category}
												selected={
													(modalDocument?.category ?? "tech") === category
												}
											>
												{categoryLabels[category]}
											</option>
										))
									}
								</select>
							</div>
							<div>
								<label for="document-tags" class="document-form__label"
									>标签</label
								>
								<input
									id="document-tags"
									name="tags"
									type="text"
									value={(modalDocument?.tags ?? []).join(", ")}
									class="document-form__control"
									placeholder="多个标签请用英文逗号分隔"
								/>
							</div>
							<div>
								<label for="document-published-at" class="document-form__label">
									发布时间
								</label>
								<input
									id="document-published-at"
									name="publishedAt"
									type="datetime-local"
									required
									value={toDatetimeLocalValue(
										modalDocument?.publishedAt ?? new Date().toISOString(),
									)}
									class="document-form__control"
								/>
							</div>
							<div>
								<label for="document-updated-at" class="document-form__label">
									更新时间
								</label>
								<input
									id="document-updated-at"
									name="updatedAt"
									type="datetime-local"
									value={toDatetimeLocalValue(modalDocument?.updatedAt)}
									class="document-form__control"
								/>
							</div>
						</div>

						<div class="document-form__grid document-form__grid--meta">
							<div>
								<label for="document-cover-image" class="document-form__label">
									封面图（可选）
								</label>
								<input
									id="document-cover-image"
									name="coverImage"
									type="text"
									value={modalDocument?.coverImage ?? ""}
									class="document-form__control"
									placeholder="例如：/images/cover.png"
								/>
							</div>
							<div>
								<label for="document-draft" class="document-form__label"
									>状态</label
								>
								<select
									id="document-draft"
									name="draft"
									class="document-form__control"
								>
									<option value="false" selected={!modalDocument?.draft}>
										已发布
									</option>
									<option value="true" selected={Boolean(modalDocument?.draft)}>
										草稿
									</option>
								</select>
							</div>
						</div>

						<label class="document-form__checkbox">
							<input
								id="document-is-pinned"
								name="isPinned"
								type="checkbox"
								value="true"
								checked={Boolean(modalDocument?.isPinned)}
							/>
							<span>设为置顶文章</span>
						</label>

						<div>
							<label for="document-body" class="document-form__label"
								>Markdown 正文</label
							>
							<textarea
								id="document-body"
								name="body"
								rows="18"
								class="document-form__control document-form__editor"
								placeholder="在这里直接编写 Markdown 正文..."
								>{modalDocument?.body ?? ""}</textarea
							>
						</div>
					</div>

					<div
						class="flex flex-wrap items-center justify-end gap-3 border-t border-white/10 bg-white/[0.02] px-4 py-3 md:px-6"
					>
						<a
							href={closeModalUrl}
							class="inline-flex min-h-[42px] items-center justify-center rounded-xl border border-white/10 px-4 py-2 text-sm font-medium text-gray-300 transition hover:border-primary-400 hover:text-primary-300"
						>
							取消
						</a>
						<button
							type="submit"
							class="inline-flex min-h-[42px] items-center justify-center gap-2 rounded-xl bg-primary-500 px-4 py-2 text-sm font-medium text-white transition hover:bg-primary-600"
						>
							<Icon name="ri:save-line" class="text-base" />
							{shouldOpenEditModal ? "保存修改" : "创建文章"}
						</button>
					</div>
				</form>
			</div>
		</div>

		<div
			id="document-delete-modal"
			class="fixed inset-0 z-[210] hidden items-center justify-center px-4"
		>
			<button
				type="button"
				class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
				data-close-delete-modal
				aria-label="关闭删除确认"></button>
			<div
				class="relative z-10 w-full max-w-md rounded-[24px] border border-white/10 bg-dark-800/95 p-6 shadow-2xl shadow-black/40"
			>
				<div class="flex items-start justify-between gap-4">
					<div>
						<p class="text-sm uppercase tracking-[0.35em] text-red-300">
							Delete
						</p>
						<h3 class="mt-3 text-xl font-semibold text-white">确认删除文章</h3>
					</div>
					<button
						type="button"
						class="rounded-full p-2 text-gray-400 transition hover:bg-white/5 hover:text-white"
						data-close-delete-modal
						aria-label="关闭"
					>
						<Icon name="ri:close-line" class="text-xl" />
					</button>
				</div>
				<p class="mt-4 text-sm leading-7 text-gray-400">
					你将删除文章
					<span id="document-delete-title" class="font-medium text-white"
					></span>
					，对应的 Markdown 文件也会一并移除。
				</p>
				<form method="POST" action="/api/admin/documents/delete" class="mt-6">
					<input id="document-delete-slug" type="hidden" name="slug" value="" />
					<div class="flex justify-end gap-3">
						<button
							type="button"
							class="inline-flex min-h-[42px] items-center justify-center rounded-xl border border-white/10 px-4 py-2 text-sm font-medium text-gray-300 transition hover:border-primary-400 hover:text-primary-300"
							data-close-delete-modal
						>
							取消
						</button>
						<button
							type="submit"
							class="inline-flex min-h-[42px] items-center justify-center rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-2 text-sm font-medium text-red-200 transition hover:border-red-500/40 hover:bg-red-500/15"
						>
							确认删除
						</button>
					</div>
				</form>
			</div>
		</div>
	</AdminShell>
</BaseLayout>

<style>
	.document-form__grid {
		display: grid;
		gap: 1rem;
	}

	.document-form__grid--primary,
	.document-form__grid--meta {
		grid-template-columns: repeat(1, minmax(0, 1fr));
	}

	.document-form__label {
		margin-bottom: 0.55rem;
		display: inline-flex;
		font-size: 0.92rem;
		font-weight: 500;
		color: rgb(226 232 240);
	}

	.document-form__control {
		min-height: 48px;
		width: 100%;
		border-radius: 1rem;
		border: 1px solid rgb(255 255 255 / 0.1);
		background: rgb(17 24 39 / 0.78);
		padding: 0.8rem 1rem;
		font-size: 0.95rem;
		color: rgb(241 245 249);
		outline: none;
		transition:
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			background-color 0.2s ease;
	}

	.document-form__control:focus {
		border-color: rgb(56 189 248 / 0.7);
		box-shadow: 0 0 0 4px rgb(14 165 233 / 0.12);
	}

	.document-form__control::placeholder {
		color: rgb(107 114 128);
	}

	.document-form__textarea {
		min-height: 108px;
		resize: vertical;
	}

	.document-form__editor {
		min-height: 420px;
		resize: vertical;
		font-family:
			"JetBrains Mono", "Fira Code", Consolas, "Liberation Mono", Menlo,
			monospace;
		line-height: 1.75;
	}

	.document-form__upload {
		padding-top: 0.65rem;
		padding-bottom: 0.65rem;
	}

	.document-form__checkbox {
		display: inline-flex;
		align-items: center;
		gap: 0.7rem;
		font-size: 0.95rem;
		color: rgb(226 232 240);
	}

	.document-form__checkbox input {
		height: 1rem;
		width: 1rem;
		accent-color: rgb(14 165 233);
	}

	.document-toast {
		position: fixed;
		right: 1rem;
		top: 1rem;
		z-index: 260;
		max-width: min(420px, calc(100vw - 2rem));
		border-radius: 1rem;
		border: 1px solid rgb(255 255 255 / 0.1);
		background: rgb(15 23 42 / 0.95);
		padding: 0.95rem 1rem;
		box-shadow: 0 18px 45px rgb(2 6 23 / 0.45);
		backdrop-filter: blur(14px);
	}

	.document-toast__title {
		font-size: 0.92rem;
		font-weight: 600;
		color: rgb(248 250 252);
	}

	.document-toast__message {
		margin-top: 0.35rem;
		font-size: 0.9rem;
		line-height: 1.65;
		color: rgb(203 213 225);
	}

	.document-toast[data-variant="success"] {
		border-color: rgb(16 185 129 / 0.24);
	}

	.document-toast[data-variant="error"] {
		border-color: rgb(239 68 68 / 0.24);
	}

	@media (min-width: 768px) {
		.document-form__grid--primary {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.document-form__grid--meta {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>

<script is:inline>
	const initDocumentToast = () => {
		const source = document.querySelector("[data-toast-source]");
		if (
			!(source instanceof HTMLElement) ||
			source.dataset.toastConsumed === "true"
		) {
			return;
		}

		source.dataset.toastConsumed = "true";
		const toast = document.createElement("div");
		toast.className = "document-toast";
		toast.dataset.variant = source.dataset.toastVariant || "success";
		toast.innerHTML = `
			<div class="document-toast__title">${source.dataset.toastTitle || "提示"}</div>
			<div class="document-toast__message">${source.textContent?.trim() || ""}</div>
		`;
		document.body.appendChild(toast);

		const duration = Number(source.dataset.toastDuration || "3200");
		window.setTimeout(
			() => {
				toast.remove();
			},
			Number.isFinite(duration) ? duration : 3200,
		);
	};

	const initDocumentModal = () => {
		const modal = document.getElementById("document-modal");
		if (
			!(modal instanceof HTMLElement) ||
			modal.dataset.modalReady === "true"
		) {
			return;
		}

		modal.dataset.modalReady = "true";
		const closeUrl = modal.dataset.closeUrl || "/admin/documents";
		const closeButtons = modal.querySelectorAll("[data-close-document-modal]");

		const closeModal = () => {
			window.location.href = closeUrl;
		};

		closeButtons.forEach((button) => {
			button.addEventListener("click", closeModal);
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && modal.dataset.open === "true") {
				closeModal();
			}
		});
	};

	const initDeleteModal = () => {
		const modal = document.getElementById("document-delete-modal");
		const slugInput = document.getElementById("document-delete-slug");
		const titleElement = document.getElementById("document-delete-title");

		if (
			!(modal instanceof HTMLElement) ||
			!(slugInput instanceof HTMLInputElement) ||
			!(titleElement instanceof HTMLElement) ||
			modal.dataset.modalReady === "true"
		) {
			return;
		}

		modal.dataset.modalReady = "true";

		const closeModal = () => {
			modal.classList.add("hidden");
			modal.classList.remove("flex");
		};

		document.addEventListener("click", (event) => {
			const openButton = event.target.closest("[data-open-delete-modal]");
			if (openButton instanceof HTMLElement) {
				slugInput.value = openButton.dataset.documentSlug || "";
				titleElement.textContent = `《${openButton.dataset.documentTitle || "未命名文章"}》`;
				modal.classList.remove("hidden");
				modal.classList.add("flex");
				return;
			}

			const closeButton = event.target.closest("[data-close-delete-modal]");
			if (closeButton) {
				closeModal();
			}
		});
	};

	const initDocumentImport = () => {
		const importInput = document.getElementById("document-import-file");
		const importButton = document.getElementById("document-import-button");
		const feedback = document.getElementById("document-import-feedback");
		const titleInput = document.getElementById("document-title");
		const slugInput = document.getElementById("document-slug");
		const descriptionInput = document.getElementById("document-description");
		const categoryInput = document.getElementById("document-category");
		const tagsInput = document.getElementById("document-tags");
		const publishedAtInput = document.getElementById("document-published-at");
		const updatedAtInput = document.getElementById("document-updated-at");
		const coverImageInput = document.getElementById("document-cover-image");
		const draftInput = document.getElementById("document-draft");
		const isPinnedInput = document.getElementById("document-is-pinned");
		const bodyInput = document.getElementById("document-body");

		if (
			!(importInput instanceof HTMLInputElement) ||
			!(importButton instanceof HTMLButtonElement) ||
			!(feedback instanceof HTMLElement) ||
			!(titleInput instanceof HTMLInputElement) ||
			!(slugInput instanceof HTMLInputElement) ||
			!(descriptionInput instanceof HTMLTextAreaElement) ||
			!(categoryInput instanceof HTMLSelectElement) ||
			!(tagsInput instanceof HTMLInputElement) ||
			!(publishedAtInput instanceof HTMLInputElement) ||
			!(updatedAtInput instanceof HTMLInputElement) ||
			!(coverImageInput instanceof HTMLInputElement) ||
			!(draftInput instanceof HTMLSelectElement) ||
			!(isPinnedInput instanceof HTMLInputElement) ||
			!(bodyInput instanceof HTMLTextAreaElement)
		) {
			return;
		}

		let slugTouched = Boolean(slugInput.value);

		titleInput.addEventListener("input", () => {
			if (slugTouched) {
				return;
			}

			const generated = titleInput.value
				.normalize("NFKD")
				.replace(/[\u0300-\u036f]/g, "")
				.toLowerCase()
				.replace(/[^a-z0-9\s-]/g, " ")
				.replace(/\s+/g, "-")
				.replace(/-+/g, "-")
				.replace(/^-|-$/g, "");

			slugInput.value = generated;
		});

		slugInput.addEventListener("input", () => {
			slugTouched = slugInput.value.trim().length > 0;
		});

		const applyParsedData = (data) => {
			titleInput.value = data.title || "";
			slugInput.value = data.slug || "";
			descriptionInput.value = data.description || "";
			categoryInput.value = data.category || "other";
			tagsInput.value = Array.isArray(data.tags) ? data.tags.join(", ") : "";
			publishedAtInput.value = (data.publishedAt || "").slice(0, 16);
			updatedAtInput.value = (data.updatedAt || "").slice(0, 16);
			coverImageInput.value = data.coverImage || "";
			draftInput.value = data.draft ? "true" : "false";
			isPinnedInput.checked = Boolean(data.isPinned);
			bodyInput.value = data.body || "";
			slugTouched = false;
		};

		const parseMarkdownFile = async () => {
			const file = importInput.files?.[0];
			if (!file) {
				feedback.textContent = "请先选择一个 Markdown 文件。";
				feedback.className = "mt-3 text-sm text-red-300";
				return;
			}

			feedback.textContent = "正在解析 Markdown 文件...";
			feedback.className = "mt-3 text-sm text-gray-400";

			const formData = new FormData();
			formData.append("file", file);

			try {
				const response = await fetch("/api/admin/documents/parse", {
					method: "POST",
					body: formData,
				});
				const payload = await response.json();

				if (!response.ok || !payload?.data) {
					throw new Error(payload?.message || "解析失败");
				}

				applyParsedData(payload.data);
				feedback.textContent = "Markdown 已解析完成，字段已填充到表单中。";
				feedback.className = "mt-3 text-sm text-emerald-300";
			} catch (error) {
				feedback.textContent =
					error instanceof Error && error.message
						? error.message
						: "Markdown 解析失败";
				feedback.className = "mt-3 text-sm text-red-300";
			}
		};

		importButton.addEventListener("click", parseMarkdownFile);
		importInput.addEventListener("change", () => {
			if (importInput.files?.length) {
				void parseMarkdownFile();
			}
		});
	};

	initDocumentToast();
	initDocumentModal();
	initDeleteModal();
	initDocumentImport();
	document.addEventListener("astro:page-load", initDocumentToast);
	document.addEventListener("astro:page-load", initDocumentModal);
	document.addEventListener("astro:page-load", initDeleteModal);
	document.addEventListener("astro:page-load", initDocumentImport);
</script>
