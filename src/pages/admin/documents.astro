---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminShell from "@/components/admin/AdminShell.astro";
import { getAuthenticatedAdmin } from "@/lib/auth";
import {
	ARTICLE_CATEGORIES,
	getAdminArticleBySlug,
	listAdminArticles,
} from "@/lib/articles";
import { Icon } from "astro-icon/components";

export const prerender = false;

const admin = await getAuthenticatedAdmin(Astro);

if (!admin) {
	return Astro.redirect("/?login=1");
}

const status = Astro.url.searchParams.get("status") ?? "";
const code = Astro.url.searchParams.get("code") ?? "";
const highlightSlug = Astro.url.searchParams.get("highlight")?.trim() ?? "";
const editSlug = Astro.url.searchParams.get("edit")?.trim() ?? "";
const createRequested = Astro.url.searchParams.get("create") === "1";
const keyword = Astro.url.searchParams.get("q")?.trim() ?? "";
const selectedCategory = Astro.url.searchParams.get("category")?.trim() ?? "";
const selectedState = Astro.url.searchParams.get("state")?.trim() ?? "";

const [allDocuments, editingDocument] = await Promise.all([
	listAdminArticles({
		keyword: keyword || undefined,
		category: selectedCategory || undefined,
		status: selectedState || undefined,
	}),
	editSlug ? getAdminArticleBySlug(editSlug) : Promise.resolve(null),
]);

const categoryLabels: Record<string, string> = {
	tech: "技术",
	essay: "随笔",
	project: "项目",
	other: "其他",
};

function getSelectedLabel(
	options: Array<{ value: string; label: string }>,
	value: string,
	fallback: string,
) {
	return options.find((option) => option.value === value)?.label ?? fallback;
}

const documentCategoryFilterOptions: Array<{ value: string; label: string }> =
	ARTICLE_CATEGORIES.map((category) => ({
		value: category,
		label: categoryLabels[category],
	}));

const documentStateFilterOptions: Array<{ value: string; label: string }> = [
	{ value: "published", label: "已发布" },
	{ value: "draft", label: "草稿" },
];

const statusMessages: Record<string, string> = {
	created: "文章已创建成功。",
	updated: "文章内容已更新。",
	deleted: "文章已删除。",
	invalid_document: "没有找到要操作的文章。",
	invalid_title: "文章标题不能为空。",
	invalid_slug: "文章 slug 无效，请使用英文、数字或短横线。",
	duplicate_slug: "该 slug 已存在，请更换后再保存。",
	invalid_category: "文章分类不在允许范围内。",
	invalid_published_at: "发布时间不能为空。",
	save_failed: "保存失败，请稍后重试。",
};

const effectiveStatus =
	!status && editSlug && !editingDocument ? "error" : status;
const effectiveCode =
	!status && editSlug && !editingDocument ? "invalid_document" : code;
const feedbackMessage =
	effectiveStatus === "error"
		? statusMessages[effectiveCode]
		: statusMessages[effectiveStatus];
const toastVariant = effectiveStatus === "error" ? "error" : "success";
const toastTitle =
	effectiveStatus === "created"
		? "创建成功"
		: effectiveStatus === "updated"
			? "保存成功"
			: effectiveStatus === "deleted"
				? "删除成功"
				: effectiveStatus === "error"
					? "操作失败"
					: "提示";

const toastDuration = effectiveStatus === "error" ? 4200 : 3200;

const modalDocument = editingDocument;
const shouldOpenEditModal = Boolean(modalDocument);
const shouldOpenCreateModal = createRequested && !shouldOpenEditModal;
const shouldOpenEditor = shouldOpenEditModal || shouldOpenCreateModal;

const currentSearch = new URLSearchParams(Astro.url.searchParams);

function buildAdminLink(overrides: Record<string, string | undefined>) {
	const nextSearch = new URLSearchParams(currentSearch);

	for (const [key, value] of Object.entries(overrides)) {
		if (value === undefined || value === "") {
			nextSearch.delete(key);
		} else {
			nextSearch.set(key, value);
		}
	}

	const query = nextSearch.toString();
	return `/admin/documents${query ? `?${query}` : ""}`;
}

function toDateLabel(value: string) {
	const timestamp = new Date(value).getTime();
	if (Number.isNaN(timestamp)) {
		return value;
	}

	return new Date(timestamp).toLocaleString("zh-CN", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
		hour: "2-digit",
		minute: "2-digit",
	});
}

const clearFilterUrl = buildAdminLink({
	q: undefined,
	category: undefined,
	state: undefined,
	status: undefined,
	code: undefined,
	edit: undefined,
	create: undefined,
	highlight: undefined,
});
const createUrl = buildAdminLink({
	create: "1",
	edit: undefined,
	status: undefined,
	code: undefined,
	highlight: undefined,
});
const closeModalUrl = buildAdminLink({
	edit: undefined,
	create: undefined,
	status: undefined,
	code: undefined,
});
---

<BaseLayout title="文档管理" description="后台管理博客文章与数据库内容">
	<AdminShell activeSection="documents">
		{
			feedbackMessage && (
				<div
					hidden
					data-toast-source
					data-toast-variant={toastVariant}
					data-toast-title={toastTitle}
					data-toast-duration={String(toastDuration)}>
					{feedbackMessage}
				</div>
			)
		}

		<div
			class="rounded-3xl border border-white/10 bg-dark-800/70 p-4 md:p-5">
			<div
				class="mb-4 flex min-w-0 flex-col gap-3 md:flex-row md:flex-nowrap md:items-center md:justify-between">
				<h2
					class="min-w-0 text-xl font-semibold text-white md:text-2xl">
					文档列表
				</h2>
				<div class="flex shrink-0 flex-nowrap gap-3">
					<a
						href={createUrl}
						class="inline-flex min-h-[42px] shrink-0 items-center gap-2 whitespace-nowrap rounded-xl bg-primary-500 px-4 py-2 text-sm font-medium text-white shadow-[0_10px_24px_rgba(14,165,233,0.16)] transition hover:bg-primary-600 hover:shadow-[0_12px_28px_rgba(14,165,233,0.22)]">
						<Icon name="ri:file-add-line" class="text-lg" />
						新建
					</a>
				</div>
			</div>

			<form
				action="/admin/documents"
				method="GET"
				data-admin-documents-filter-form
				class="mb-4">
				<div
					class="admin-filter-toolbar grid w-full grid-cols-1 gap-2.5 md:grid-cols-[minmax(0,1fr)_11rem_11rem_auto_auto] md:items-stretch">
					<div class="relative min-h-[48px] min-w-0">
						<input
							type="search"
							name="q"
							value={keyword}
							placeholder="搜索标题、描述、标签、slug 或正文"
							class="min-h-[48px] w-full rounded-2xl border border-white/10 bg-dark-900/80 px-4 py-2.5 text-sm text-gray-100 outline-none transition focus:border-primary-400 focus:ring-2 focus:ring-primary-500/20"
						/>
					</div>
					<div
						class="relative min-h-[48px] min-w-0 w-full"
						data-custom-select-root
						data-select-submit-on-change="true">
						<input
							type="hidden"
							name="category"
							value={selectedCategory}
							data-select-input
						/>
						<details
							class="custom-select custom-select--filter-toolbar">
							<summary class="custom-select__trigger">
								<span
									class={`custom-select__label ${selectedCategory ? "is-selected" : ""}`}
									data-select-label
									data-placeholder="分类"
									>{
										getSelectedLabel(
											documentCategoryFilterOptions,
											selectedCategory,
											"分类",
										)
									}</span
								>
								<Icon
									name="ri:arrow-down-s-line"
									class="custom-select__arrow"
								/>
							</summary>
							<div class="custom-select__menu">
								{
									documentCategoryFilterOptions.map(
										(option) => (
											<button
												type="button"
												class={`custom-select__option ${option.value === selectedCategory ? "is-active" : ""}`}
												data-select-option
												data-value={option.value}
												data-label={option.label}>
												<span>{option.label}</span>
												<span
													class="custom-select__check"
													aria-hidden="true"
												/>
											</button>
										),
									)
								}
							</div>
						</details>
					</div>
					<div
						class="relative min-h-[48px] min-w-0 w-full"
						data-custom-select-root
						data-select-submit-on-change="true">
						<input
							type="hidden"
							name="state"
							value={selectedState}
							data-select-input
						/>
						<details
							class="custom-select custom-select--filter-toolbar">
							<summary class="custom-select__trigger">
								<span
									class={`custom-select__label ${selectedState ? "is-selected" : ""}`}
									data-select-label
									data-placeholder="状态"
									>{
										getSelectedLabel(
											documentStateFilterOptions,
											selectedState,
											"状态",
										)
									}</span
								>
								<Icon
									name="ri:arrow-down-s-line"
									class="custom-select__arrow"
								/>
							</summary>
							<div class="custom-select__menu">
								{
									documentStateFilterOptions.map((option) => (
										<button
											type="button"
											class={`custom-select__option ${option.value === selectedState ? "is-active" : ""}`}
											data-select-option
											data-value={option.value}
											data-label={option.label}>
											<span>{option.label}</span>
											<span
												class="custom-select__check"
												aria-hidden="true"
											/>
										</button>
									))
								}
							</div>
						</details>
					</div>
					<button
						type="submit"
						class="inline-flex min-h-[48px] w-full items-center justify-center whitespace-nowrap rounded-2xl bg-primary-500 px-5 text-sm font-medium text-white transition-all hover:bg-primary-600 md:min-w-[5.5rem] focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						aria-label="搜索文章">
						搜索
					</button>
					<a
						href={clearFilterUrl}
						data-admin-documents-clear
						class="inline-flex min-h-[48px] w-full items-center justify-center whitespace-nowrap rounded-2xl border border-white/10 px-5 text-sm font-medium text-gray-300 transition-all hover:border-primary-400 hover:text-primary-300 md:min-w-[5.5rem] focus:outline-none focus:ring-2 focus:ring-primary-500/20"
						aria-label="清空筛选条件">
						清空
					</a>
				</div>
			</form>

			<div class="space-y-4" data-admin-documents-results>
				{
					allDocuments.length > 0 ? (
						allDocuments.map((document) => (
							<article
								id={
									highlightSlug === document.slug
										? `document-${document.slug}`
										: undefined
								}
								class:list={[
									"grid gap-2 rounded-2xl border border-white/10 bg-dark-900/60 p-2.5 md:grid-cols-[4rem_minmax(0,1fr)_auto] md:items-start",
									highlightSlug === document.slug
										? "border-primary-400/50 shadow-[0_0_0_1px_rgba(34,211,238,0.3)]"
										: "",
								]}>
								<div
									class="flex h-16 w-16 shrink-0 overflow-hidden rounded-xl bg-dark-950 ring-1 ring-white/10 md:mx-0">
									{document.coverImage ? (
										<img
											src={document.coverImage}
											alt=""
											class="h-full w-full object-cover"
											loading="lazy"
											decoding="async"
										/>
									) : (
										<div
											class="flex h-full w-full items-center justify-center text-gray-600"
											aria-hidden="true">
											<Icon
												name="ri:image-2-line"
												class="text-2xl opacity-70"
											/>
										</div>
									)}
								</div>
								<div class="min-w-0 space-y-1.5">
									<h3 class="break-words text-base font-semibold leading-snug text-white">
										{document.title}
									</h3>
									<div class="flex flex-wrap items-center gap-1.5">
										<span
											class:list={[
												"shrink-0 rounded-full border px-2 py-0.5 text-[11px] whitespace-nowrap leading-tight",
												document.draft
													? "border-amber-500/20 bg-amber-500/10 text-amber-200"
													: "border-emerald-500/20 bg-emerald-500/10 text-emerald-200",
											]}>
											{document.draft ? "草稿" : "已发布"}
										</span>
										<span class="shrink-0 rounded-full border border-white/10 bg-dark-800 px-2 py-0.5 text-[11px] whitespace-nowrap leading-tight text-gray-300">
											{categoryLabels[document.category]}
										</span>
										{document.isPinned && (
											<span class="shrink-0 rounded-full border border-primary-500/30 bg-primary-500/10 px-2 py-0.5 text-[11px] whitespace-nowrap leading-tight text-primary-200">
												置顶
											</span>
										)}
									</div>
									<p
										class="truncate font-mono text-[11px] leading-tight text-gray-500"
										title={document.slug}>
										{document.slug}
									</p>
									<p class="line-clamp-1 text-xs leading-snug text-gray-400">
										{document.description ||
											document.excerpt}
									</p>
									<div class="flex flex-wrap gap-x-2 gap-y-0.5 border-t border-white/5 pt-1.5 text-[11px] leading-tight text-gray-400">
										<span class="whitespace-nowrap">
											发布{" "}
											{toDateLabel(document.publishedAt)}
										</span>
										{document.updatedAt && (
											<span class="whitespace-nowrap">
												· 更新{" "}
												{toDateLabel(
													document.updatedAt,
												)}
											</span>
										)}
										<span class="whitespace-nowrap">
											· 标签 {document.tags.length}
										</span>
									</div>
									{document.tags.length > 0 && (
										<div class="flex max-h-7 flex-wrap gap-1 overflow-hidden">
											{document.tags.map((tag) => (
												<span class="shrink-0 rounded border border-white/10 bg-dark-800/80 px-1.5 py-px text-[10px] leading-tight text-gray-300">
													#{tag}
												</span>
											))}
										</div>
									)}
								</div>

								<div class="flex shrink-0 flex-row gap-2 border-t border-white/5 pt-2.5 md:flex-col md:border-t-0 md:pt-0">
									<a
										href={buildAdminLink({
											edit: document.slug,
											create: undefined,
											status: undefined,
											code: undefined,
										})}
										class="inline-flex min-h-[38px] flex-1 items-center justify-center gap-1.5 whitespace-nowrap rounded-xl border border-white/10 px-3 py-2 text-sm font-medium text-gray-200 transition-all hover:border-primary-400 hover:text-primary-300 md:min-w-[84px] md:flex-none focus:outline-none focus:ring-2 focus:ring-primary-500/20">
										<Icon
											name="ri:edit-line"
											class="text-base"
										/>
										编辑
									</a>
									<button
										type="button"
										class="inline-flex min-h-[38px] flex-1 items-center justify-center gap-1.5 whitespace-nowrap rounded-xl border border-red-500/20 bg-red-500/10 px-3 py-2 text-sm font-medium text-red-200 transition-all hover:border-red-500/40 hover:bg-red-500/15 md:min-w-[84px] md:flex-none focus:outline-none focus:ring-2 focus:ring-red-500/20"
										data-open-delete-modal
										data-document-slug={document.slug}
										data-document-title={document.title}>
										<Icon
											name="ri:delete-bin-line"
											class="text-base"
										/>
										删除
									</button>
								</div>
							</article>
						))
					) : (
						<div class="rounded-3xl border border-dashed border-white/10 bg-dark-900/40 p-8 text-center">
							<p class="text-lg font-medium text-white">
								当前条件下还没有文章
							</p>
							<p class="mt-3 text-sm text-gray-400">
								可以换一个筛选条件试试，或者点击右上角“新建文章”新增内容。
							</p>
						</div>
					)
				}
			</div>
		</div>

		<div
			id="document-modal"
			data-open={shouldOpenEditor ? "true" : "false"}
			data-close-url={closeModalUrl}
			class:list={[
				"fixed inset-0 z-[200] flex items-center justify-center overflow-y-auto px-3 py-4 sm:px-4 sm:py-5",
				{ hidden: !shouldOpenEditor },
			]}>
			<button
				type="button"
				class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
				data-close-document-modal
				aria-label="关闭弹窗">
			</button>

			<div
				class="document-modal__shell relative z-10 my-auto flex w-full max-w-2xl flex-col overflow-hidden rounded-2xl border border-white/10 bg-dark-800/95 shadow-2xl shadow-black/40"
				style="max-height: min(92dvh, 820px);">
				<div
					class="flex shrink-0 items-start justify-between gap-3 border-b border-white/10 bg-white/[0.02] px-4 py-2.5 sm:px-5">
					<div>
						<p
							id="document-modal-tag"
							class="text-xs uppercase tracking-[0.35em] text-primary-400">
							Article
						</p>
						<h2
							class="mt-1.5 text-lg font-semibold text-white sm:text-xl">
							{shouldOpenEditModal ? "编辑文章" : "新建文章"}
						</h2>
						<p
							class="mt-1 text-xs text-gray-500 sm:text-sm sm:text-gray-400">
							可导入 <code
								class="rounded bg-white/5 px-1 font-mono text-[11px] text-primary-200/90"
								>.md</code
							> 填充字段
						</p>
					</div>
					<button
						type="button"
						class="rounded-full p-2 text-gray-400 transition hover:bg-white/5 hover:text-white"
						data-close-document-modal
						aria-label="关闭">
						<Icon name="ri:close-line" class="text-xl" />
					</button>
				</div>

				<form
					id="document-form"
					method="POST"
					action="/api/admin/documents/save"
					class="flex min-h-0 flex-1 flex-col">
					<input
						id="document-current-slug"
						type="hidden"
						name="currentSlug"
						value={modalDocument?.slug ?? ""}
					/>
					<div
						class="document-modal__body panel-scrollbar min-h-0 flex-1 space-y-3 overflow-y-auto overscroll-contain px-4 pb-3 pt-2.5 sm:px-5 sm:pb-4">
						<div
							class="rounded-xl border border-white/10 bg-dark-900/45 p-3 sm:p-3.5">
							<div
								class="flex items-center justify-between gap-2">
								<h3 class="text-sm font-semibold text-white">
									导入 Markdown
								</h3>
							</div>
							<div
								class="award-form__row award-form__row--import-actions mt-2.5 items-stretch sm:items-end">
								<input
									id="document-import-file"
									type="file"
									accept=".md,.markdown,text/markdown,text/plain"
									class="award-form__control award-form__upload min-w-0"
								/>
							</div>
						</div>

						<div class="award-form__row award-form__row--primary">
							<div>
								<label
									for="document-title"
									class="award-form__label">标题</label
								>
								<input
									id="document-title"
									name="title"
									type="text"
									required
									value={modalDocument?.title ?? ""}
									class="award-form__control"
									placeholder="例如：如何搭建自己的博客"
								/>
							</div>
							<div>
								<label
									for="document-slug"
									class="award-form__label">Slug</label
								>
								<input
									id="document-slug"
									name="slug"
									type="text"
									value={modalDocument?.slug ?? ""}
									class="award-form__control"
									placeholder="例如：how-to-build-a-blog"
								/>
							</div>
						</div>

						<div>
							<label
								for="document-description"
								class="award-form__label">
								摘要
							</label>
							<textarea
								id="document-description"
								name="description"
								rows="3"
								class="award-form__control award-form__textarea min-h-[5.5rem] resize-y"
								placeholder="用于首页与详情简介"
								>{modalDocument?.description ?? ""}</textarea
							>
						</div>

						<div class="award-form__row award-form__row--meta3">
							<div
								class="relative min-h-[48px] min-w-0"
								data-custom-select-root
								data-select-submit-on-change="false"
								data-modal-select="category">
								<input
									type="hidden"
									id="document-category"
									name="category"
									value={modalDocument?.category ?? "tech"}
									data-select-input
								/>
								<p class="award-form__label">分类</p>
								<details
									class="custom-select custom-select--filter-toolbar">
									<summary class="custom-select__trigger">
										<span
											class="custom-select__label is-selected"
											data-select-label
											data-placeholder="分类">
											{
												getSelectedLabel(
													documentCategoryFilterOptions,
													modalDocument?.category ??
														"tech",
													"分类",
												)
											}
										</span>
										<Icon
											name="ri:arrow-down-s-line"
											class="custom-select__arrow"
										/>
									</summary>
									<div class="custom-select__menu">
										{
											ARTICLE_CATEGORIES.map(
												(category) => (
													<button
														type="button"
														class={`custom-select__option ${(modalDocument?.category ?? "tech") === category ? "is-active" : ""}`}
														data-select-option
														data-value={category}
														data-label={
															categoryLabels[
																category
															]
														}>
														<span>
															{
																categoryLabels[
																	category
																]
															}
														</span>
														<span
															class="custom-select__check"
															aria-hidden="true"
														/>
													</button>
												),
											)
										}
									</div>
								</details>
							</div>
