<script>
	import { marked } from "marked";

	marked.use({
		gfm: true,
		breaks: true,
	});

	const initCoverPreview = () => {
		const input = document.getElementById("document-cover-image");
		const img = document.getElementById("document-cover-preview-img");
		const emptyHint = document.getElementById(
			"document-cover-preview-empty",
		);
		const fallback = document.getElementById(
			"document-cover-preview-fallback",
		);
		if (
			!(input instanceof HTMLInputElement) ||
			!(img instanceof HTMLImageElement) ||
			!(fallback instanceof HTMLElement)
		) {
			return;
		}
		if (input.dataset.coverPreviewReady === "true") {
			return;
		}
		input.dataset.coverPreviewReady = "true";

		const setPopoverVisible = (showImg: boolean) => {
			img.classList.toggle("hidden", !showImg);
			if (emptyHint instanceof HTMLElement) {
				emptyHint.classList.toggle("hidden", showImg);
			}
		};

		const apply = () => {
			fallback.textContent = "";
			fallback.classList.add("hidden");
			const raw = input.value.trim();
			if (!raw) {
				img.removeAttribute("src");
				setPopoverVisible(false);
				return;
			}

			const ok =
				/^https?:\/\//i.test(raw) ||
				raw.startsWith("/") ||
				raw.startsWith("data:image/");
			if (!ok) {
				fallback.textContent =
					"请使用 http(s) 完整链接、以 / 开头的站内绝对路径或 data: 图片；其它相对路径无法在此预览。";
				fallback.classList.remove("hidden");
				img.removeAttribute("src");
				setPopoverVisible(false);
				return;
			}

			setPopoverVisible(true);
			img.onload = () => {
				fallback.classList.add("hidden");
				setPopoverVisible(true);
			};
			img.onerror = () => {
				fallback.textContent =
					"无法加载该图片，请确认地址可在浏览器中直接打开（公网可访问或本站已部署资源）。";
				fallback.classList.remove("hidden");
				img.removeAttribute("src");
				setPopoverVisible(false);
			};
			img.src = raw;
		};

		input.addEventListener("input", apply);
		apply();
	};

	const initMarkdownEditor = () => {
		const root = document.querySelector("[data-doc-md-panels]");
		const tabs = document.querySelector("[data-doc-md-tabs]");
		const source = document.querySelector("[data-doc-md-source]");
		const preview = document.querySelector("[data-doc-md-preview]");
		if (
			!(root instanceof HTMLElement) ||
			!(tabs instanceof HTMLElement) ||
			!(source instanceof HTMLTextAreaElement) ||
			!(preview instanceof HTMLElement)
		) {
			return;
		}
		if (root.dataset.mdEditorReady === "true") {
			return;
		}
		root.dataset.mdEditorReady = "true";

		let debounce = 0;

		const render = () => {
			const text = source.value;
			if (!text.trim()) {
				preview.innerHTML =
					'<p class="text-gray-500 text-sm m-0">输入 Markdown 后在此查看渲染</p>';
				return;
			}
			preview.innerHTML = String(marked.parse(text));
		};

		const setMode = (mode: "edit" | "preview" | "split") => {
			root.classList.remove(
				"doc-md-panels--edit",
				"doc-md-panels--preview",
				"doc-md-panels--split",
			);
			root.classList.add(`doc-md-panels--${mode}`);
			tabs.querySelectorAll("[data-doc-md-mode]").forEach((btn) => {
				if (btn instanceof HTMLElement) {
					btn.classList.toggle(
						"is-active",
						btn.dataset.docMdMode === mode,
					);
				}
			});
			if (mode === "preview" || mode === "split") {
				render();
			}
		};

		tabs.addEventListener("click", (ev) => {
			const t = ev.target;
			if (!(t instanceof Node)) {
				return;
			}
			const btn =
				t instanceof Element ? t.closest("[data-doc-md-mode]") : null;
			if (!(btn instanceof HTMLElement)) {
				return;
			}
			const mode = btn.dataset.docMdMode;
			if (mode === "edit" || mode === "preview" || mode === "split") {
				setMode(mode);
			}
		});

		source.addEventListener("input", () => {
			window.clearTimeout(debounce);
			debounce = window.setTimeout(() => {
				if (
					root.classList.contains("doc-md-panels--preview") ||
					root.classList.contains("doc-md-panels--split")
				) {
					render();
				}
			}, 140);
		});

		if (window.matchMedia("(min-width: 640px)").matches) {
			setMode("split");
		} else {
			setMode("edit");
		}
		render();
	};

	function initDocumentToast() {
		const ensureStack = () => {
			const existing = document.getElementById("notification-stack");
			if (existing instanceof HTMLElement) {
				return existing;
			}

			const stack = document.createElement("div");
			stack.id = "notification-stack";
			stack.className = "notification-stack";
			stack.setAttribute("aria-live", "polite");
			stack.setAttribute("aria-atomic", "false");
			document.body.appendChild(stack);
			return stack;
		};

		const removeToast = (toast: HTMLElement): void => {
			if (!(toast instanceof HTMLElement) || toast.dataset.leaving === "true") {
				return;
			}

			toast.dataset.leaving = "true";
			toast.classList.remove("is-entering");
			toast.classList.add("is-leaving");
			window.setTimeout(() => {
				toast.remove();
			}, 300);
		};

		interface ToastOptions {
			message: string;
			variant?: "success" | "error";
			title?: string;
			duration?: number;
		}

		const showToast = ({
			message,
			variant = "success",
			title,
			duration = 3000,
		}: ToastOptions): HTMLElement | undefined => {
			if (!message) {
				return;
			}

			const stack = ensureStack();
			const toast = document.createElement("section");
			const resolvedTitle =
				title ?? (variant === "error" ? "操作失败" : "操作成功");
			const icon =
				variant === "error"
					? '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="16.5" r="1" fill="currentColor"/><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>'
					: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7L9 18l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

			toast.className = `notification notification--${variant} is-entering`;
			toast.setAttribute("role", "status");
			toast.style.setProperty("--toast-duration", `${duration}ms`);
			toast.innerHTML = `
				<div class="notification__glow" aria-hidden="true"></div>
				<div class="notification__row">
					<div class="notification__icon" aria-hidden="true">${icon}</div>
					<div class="notification__content">
						<div class="notification__title">${resolvedTitle}</div>
						<div class="notification__message"></div>
					</div>
					<button type="button" class="notification__close" aria-label="关闭通知">×</button>
				</div>
				<div class="notification__progress" aria-hidden="true"></div>
			`;
			const messageNode = toast.querySelector(".notification__message");
			if (messageNode instanceof HTMLElement) {
				messageNode.textContent = message;
			}

			const closeButton = toast.querySelector(".notification__close");
			if (closeButton instanceof HTMLButtonElement) {
				closeButton.addEventListener("click", () => removeToast(toast));
			}

			stack.appendChild(toast);
			window.setTimeout(() => removeToast(toast), duration);
			return toast;
		};

		if (typeof window !== "undefined") {
			(
				window as unknown as { showDocumentToast: typeof showToast }
			).showDocumentToast = showToast;
		}

		document.querySelectorAll("[data-toast-source]").forEach((source) => {
			if (
				!(source instanceof HTMLElement) ||
				source.dataset.toastConsumed === "true"
			) {
				return;
			}

			source.dataset.toastConsumed = "true";
			showToast({
				message: source.textContent?.trim() ?? "",
				variant: source.dataset.toastVariant === "error" ? "error" : "success",
				title: source.dataset.toastTitle ?? undefined,
				duration: Number(source.dataset.toastDuration ?? "3000") || 3000,
			});
		});

		const currentUrl = new URL(window.location.href);
		const transientParams = [
			"status",
			"code",
			"edit",
			"create",
			"highlight",
		];
		let didUpdateUrl = false;
		transientParams.forEach((key) => {
			if (currentUrl.searchParams.has(key)) {
				currentUrl.searchParams.delete(key);
				didUpdateUrl = true;
			}
		});
		if (didUpdateUrl) {
			window.history.replaceState(
				{},
				"",
				`${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`,
			);
		}
	}

	const moveOverlayToBody = (element: HTMLElement): void => {
		if (element.parentElement !== document.body) {
			document.body.appendChild(element);
		}
	};

	const initDocumentModal = () => {
		const modal = document.getElementById("document-modal");
		if (!(modal instanceof HTMLElement)) {
			return;
		}
		moveOverlayToBody(modal);
		if (modal.dataset.modalReady === "true") {
			return;
		}

		modal.dataset.modalReady = "true";
		if (modal.dataset.open === "true") {
			document.body.style.overflow = "hidden";
		}
		const closeUrl = modal.dataset.closeUrl || "/admin/documents";
		const closeButtons = modal.querySelectorAll(
			"[data-close-document-modal]",
		);

		const closeModal = () => {
			document.body.style.overflow = "";
			window.location.href = closeUrl;
		};

		closeButtons.forEach((button) => {
			button.addEventListener("click", closeModal);
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && modal.dataset.open === "true") {
				closeModal();
			}
		});
	};

	const initDeleteModal = () => {
		const modal = document.getElementById("document-delete-modal");
		const slugInput = document.getElementById("document-delete-slug");
		const titleElement = document.getElementById("document-delete-title");

		if (
			!(modal instanceof HTMLElement) ||
			!(slugInput instanceof HTMLInputElement) ||
			!(titleElement instanceof HTMLElement)
		) {
			return;
		}
		moveOverlayToBody(modal);
		if (modal.dataset.modalReady === "true") {
			return;
		}

		modal.dataset.modalReady = "true";

		const syncBodyOverflow = () => {
			const editorModal = document.getElementById("document-modal");
			document.body.style.overflow =
				editorModal instanceof HTMLElement &&
				editorModal.dataset.open === "true" &&
				!editorModal.classList.contains("hidden")
					? "hidden"
					: "";
		};

		const closeModal = () => {
			modal.classList.add("hidden");
			modal.classList.remove("flex");
			syncBodyOverflow();
		};

		document.addEventListener("click", (event) => {
			const t = event.target;
			if (!(t instanceof Element)) {
				return;
			}
			const openButton = t.closest("[data-open-delete-modal]");
			if (openButton instanceof HTMLElement) {
				slugInput.value = openButton.dataset.documentSlug || "";
				titleElement.textContent = `《${openButton.dataset.documentTitle || "未命名文章"}》`;
				modal.classList.remove("hidden");
				modal.classList.add("flex");
				document.body.style.overflow = "hidden";
				return;
			}

			if (t.closest("[data-close-delete-modal]")) {
				closeModal();
			}
		});
	};

	const syncModalSelect = (kind: "category" | "draft", value: string) => {
		const root = document.querySelector(`[data-modal-select="${kind}"]`);
		if (!root) {
			return;
		}
		const input = root.querySelector("[data-select-input]");
		const label = root.querySelector("[data-select-label]");
		const options = root.querySelectorAll("[data-select-option]");
		if (
			!(input instanceof HTMLInputElement) ||
			!(label instanceof HTMLElement)
		) {
			return;
		}
		input.value = value;
		const active = Array.from(options).find(
			(opt) => opt.getAttribute("data-value") === value,
		);
		const nextLabel =
			active?.getAttribute("data-label") ??
			(kind === "draft" ? (value === "true" ? "草稿" : "已发布") : value);
		label.textContent = nextLabel;
		label.classList.add("is-selected");
		options.forEach((opt) => {
			opt.classList.toggle(
				"is-active",
				opt.getAttribute("data-value") === value,
			);
		});
	};

	const initDocumentImport = () => {
		const importInput = document.getElementById("document-import-file");
		const importButton = document.getElementById("document-import-button");
		const feedback = document.getElementById("document-import-feedback");
		const titleInput = document.getElementById("document-title");
		const slugInput = document.getElementById("document-slug");
		const descriptionInput = document.getElementById(
			"document-description",
		);
		const categoryInput = document.getElementById("document-category");
		const tagsInput = document.getElementById("document-tags");
		const coverImageInput = document.getElementById("document-cover-image");
		const draftInput = document.getElementById("document-draft");
		const isPinnedInput = document.getElementById("document-is-pinned");
		const bodyInput = document.getElementById("document-body");

		if (
			!(importInput instanceof HTMLInputElement) ||
			!(importButton instanceof HTMLButtonElement) ||
			!(feedback instanceof HTMLElement) ||
			!(titleInput instanceof HTMLInputElement) ||
			!(slugInput instanceof HTMLInputElement) ||
			!(descriptionInput instanceof HTMLTextAreaElement) ||
			!(categoryInput instanceof HTMLInputElement) ||
			!(tagsInput instanceof HTMLInputElement) ||
			!(coverImageInput instanceof HTMLInputElement) ||
			!(draftInput instanceof HTMLInputElement) ||
			!(isPinnedInput instanceof HTMLInputElement) ||
			!(bodyInput instanceof HTMLTextAreaElement)
		) {
			return;
		}

		let slugTouched = Boolean(slugInput.value);

		titleInput.addEventListener("input", () => {
			if (slugTouched) {
				return;
			}

			const generated = titleInput.value
				.normalize("NFKD")
				.replace(/[\u0300-\u036f]/g, "")
				.toLowerCase()
				.replace(/[^a-z0-9\s-]/g, " ")
				.replace(/\s+/g, "-")
				.replace(/-+/g, "-")
				.replace(/^-|-$/g, "");

			slugInput.value = generated;
		});

		slugInput.addEventListener("input", () => {
			slugTouched = slugInput.value.trim().length > 0;
		});

		interface ParsedDocumentPayload {
			title?: string;
			slug?: string;
			description?: string;
			category?: string;
			tags?: string[];
			coverImage?: string;
			draft?: boolean;
			isPinned?: boolean;
			body?: string;
		}

		const applyParsedData = (data: ParsedDocumentPayload) => {
			titleInput.value = data.title || "";
			slugInput.value = data.slug || "";
			descriptionInput.value = data.description || "";
			categoryInput.value = data.category || "other";
			tagsInput.value = Array.isArray(data.tags)
				? data.tags.join(", ")
				: "";
			coverImageInput.value = data.coverImage || "";
			draftInput.value = data.draft ? "true" : "false";
			isPinnedInput.checked = Boolean(data.isPinned);
			bodyInput.value = data.body || "";
			slugTouched = false;
			syncModalSelect("category", categoryInput.value);
			syncModalSelect("draft", draftInput.value);
			coverImageInput.dispatchEvent(
				new Event("input", { bubbles: true }),
			);
			bodyInput.dispatchEvent(new Event("input", { bubbles: true }));
		};

		const parseMarkdownFile = async () => {
			const file = importInput.files?.[0];
			if (!file) {
				feedback.textContent = "请先选择一个 Markdown 文件。";
				feedback.className = "mt-3 text-sm text-red-300";
				return;
			}

			feedback.textContent = "正在解析 Markdown 文件...";
			feedback.className = "mt-3 text-sm text-gray-400";

			const formData = new FormData();
			formData.append("file", file);

			try {
				const response = await fetch("/api/admin/documents/parse", {
					method: "POST",
					body: formData,
				});
				const payload = await response.json();

				if (!response.ok || !payload?.data) {
					throw new Error(payload?.message || "解析失败");
				}

				applyParsedData(payload.data);
				feedback.textContent =
					"Markdown 已解析完成，字段已填充到表单中。";
				feedback.className = "mt-3 text-sm text-emerald-300";
			} catch (error) {
				feedback.textContent =
					error instanceof Error && error.message
						? error.message
						: "Markdown 解析失败";
				feedback.className = "mt-3 text-sm text-red-300";
			}
		};

		importButton.addEventListener("click", parseMarkdownFile);
		importInput.addEventListener("change", () => {
			if (importInput.files?.length) {
				void parseMarkdownFile();
			}
		});
	};

	function initCustomSelects() {
		document
			.querySelectorAll("[data-custom-select-root]")
			.forEach((root) => {
				if (!(root instanceof HTMLElement)) {
					return;
				}

				if (root.dataset.selectReady === "true") {
					return;
				}

				const form = root.closest("form");
				const details = root.querySelector("details");
				const summary = root.querySelector("summary");
				const input = root.querySelector("[data-select-input]");
				const label = root.querySelector("[data-select-label]");
				const options = root.querySelectorAll("[data-select-option]");

				if (
					!(form instanceof HTMLFormElement) ||
					!(details instanceof HTMLDetailsElement) ||
					!(summary instanceof HTMLElement) ||
					!(input instanceof HTMLInputElement) ||
					!(label instanceof HTMLElement) ||
					options.length === 0
				) {
					return;
				}

				root.dataset.selectReady = "true";
				let closeTimer: number | undefined;

				root.addEventListener("mouseenter", () => {
					if (closeTimer) {
						clearTimeout(closeTimer);
					}
				});

				root.addEventListener("mouseleave", () => {
					closeTimer = window.setTimeout(() => {
						details.removeAttribute("open");
					}, 120);
				});

				summary.addEventListener("click", (event) => {
					event.preventDefault();
					if (closeTimer) {
						clearTimeout(closeTimer);
					}

					if (details.hasAttribute("open")) {
						details.removeAttribute("open");
					} else {
						document
							.querySelectorAll(
								"[data-custom-select-root] details[open]",
							)
							.forEach((item) => {
								if (item !== details) {
									item.removeAttribute("open");
								}
							});
						details.setAttribute("open", "");
					}
				});

				options.forEach((option) => {
					option.addEventListener("click", () => {
						const nextValue =
							option.getAttribute("data-value") ?? "";
						const nextLabel =
							option.getAttribute("data-label") ??
							option.textContent?.trim() ??
							"";

						input.value = nextValue;
						label.textContent = nextLabel;
						label.classList.toggle(
							"is-selected",
							Boolean(nextValue),
						);
						input.dispatchEvent(
							new Event("change", { bubbles: true }),
						);

						options.forEach((item) =>
							item.classList.remove("is-active"),
						);
						option.classList.add("is-active");
						details.removeAttribute("open");
						if (root.dataset.selectSubmitOnChange === "true") {
							form.requestSubmit();
						}
					});
				});
			});
	}

	function initAdminDocumentsPartialRefresh() {
		const form = document.querySelector(
			"[data-admin-documents-filter-form]",
		);
		const results = document.querySelector(
			"[data-admin-documents-results]",
		);

		if (
			!(form instanceof HTMLFormElement) ||
			!(results instanceof HTMLElement) ||
			form.dataset.partialReady === "true"
		) {
			return;
		}

		form.dataset.partialReady = "true";

		const buildUrlFromForm = (): URL => {
			const url = new URL(
				form.getAttribute("action") || window.location.pathname,
				window.location.origin,
			);
			const formData = new FormData(form);

			for (const [key, value] of formData.entries()) {
				const normalizedValue = String(value).trim();
				if (normalizedValue) {
					url.searchParams.set(key, normalizedValue);
				}
			}

			return url;
		};

		const syncFormWithUrl = (url: URL): void => {
			const keywordInput = form.querySelector('input[name="q"]');
			if (keywordInput instanceof HTMLInputElement) {
				keywordInput.value = url.searchParams.get("q") ?? "";
			}

			form.querySelectorAll("[data-custom-select-root]").forEach(
				(root) => {
					const input = root.querySelector("[data-select-input]");
					const label = root.querySelector("[data-select-label]");
					const options = root.querySelectorAll(
						"[data-select-option]",
					);

					if (
						!(input instanceof HTMLInputElement) ||
						!(label instanceof HTMLElement)
					) {
						return;
					}

					const nextValue = url.searchParams.get(input.name) ?? "";
					input.value = nextValue;

					const activeOption = Array.from(options).find(
						(option) =>
							option.getAttribute("data-value") === nextValue,
					);
					label.textContent =
						activeOption?.getAttribute("data-label") ??
						label.dataset.placeholder ??
						"";
					label.classList.toggle("is-selected", Boolean(nextValue));

					options.forEach((option) => {
						option.classList.toggle(
							"is-active",
							option.getAttribute("data-value") === nextValue,
						);
					});
				},
			);
		};

		const refreshResults = async (
			url: URL | string,
			replaceHistory = false,
		): Promise<void> => {
			results.setAttribute("aria-busy", "true");
			results.style.opacity = "0.55";

			try {
				const response = await fetch(url, {
					headers: {
						"X-Requested-With": "admin-documents-partial",
					},
				});

				if (!response.ok) {
					window.location.href =
						typeof url === "string" ? url : url.toString();
					return;
				}

				const html = await response.text();
				const doc = new DOMParser().parseFromString(html, "text/html");
				const nextResults = doc.querySelector(
					"[data-admin-documents-results]",
				);

				if (!(nextResults instanceof HTMLElement)) {
					window.location.href =
						typeof url === "string" ? url : url.toString();
					return;
				}

				results.innerHTML = nextResults.innerHTML;
				if (replaceHistory) {
					window.history.replaceState({}, "", url);
				} else {
					window.history.pushState({}, "", url);
				}
			} finally {
				results.style.opacity = "";
				results.removeAttribute("aria-busy");
			}
		};

		form.addEventListener("submit", async (event: SubmitEvent) => {
			event.preventDefault();
			await refreshResults(buildUrlFromForm().toString());
		});

		form.addEventListener("click", async (event: MouseEvent) => {
			const target = event.target as Element;
			if (!(target instanceof Element)) {
				return;
			}

			const clearLink = target.closest("[data-admin-documents-clear]");
			if (!(clearLink instanceof HTMLAnchorElement)) {
				return;
			}

			event.preventDefault();
			const url = new URL(clearLink.href, window.location.origin);
			syncFormWithUrl(url);
			await refreshResults(url.toString());
		});
		/* 编辑/新建 必须整页导航才能渲染并打开 #document-modal；局部只替换
		 * [data-admin-documents-results] 时弹窗不会出现在响应片段里。 */
	}

	const runDocumentPageInit = () => {
		if (window.location.pathname !== "/admin/documents") {
			return;
		}
		initDocumentToast();
		initDocumentModal();
		initDeleteModal();
		initCoverPreview();
		initMarkdownEditor();
		initDocumentImport();
		initCustomSelects();
		initAdminDocumentsPartialRefresh();
	};

	runDocumentPageInit();

	const docsWindow = window as Window & {
		__adminDocumentsPageLoadBound?: boolean;
	};
	if (!docsWindow.__adminDocumentsPageLoadBound) {
		document.addEventListener("astro:page-load", runDocumentPageInit);
		docsWindow.__adminDocumentsPageLoadBound = true;
	}
</script>
