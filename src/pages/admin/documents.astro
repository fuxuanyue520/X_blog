									<div class="custom-select__menu">
										<button
											type="button"
											class:list={[
												"custom-select__option",
												!modalDocument?.draft
													? "is-active"
													: "",
											]}
											data-select-option
											data-value="false"
											data-label="已发布">
											<span>已发布</span>
											<span
												class="custom-select__check"
												aria-hidden="true"></span>
										</button>
										<button
											type="button"
											class:list={[
												"custom-select__option",
												modalDocument?.draft
													? "is-active"
													: "",
											]}
											data-select-option
											data-value="true"
											data-label="草稿">
											<span>草稿</span>
											<span
												class="custom-select__check"
												aria-hidden="true"></span>
										</button>
									</div>
								</details>
							</div>
							<div
								class="doc-form__pin-col flex min-w-0 flex-col justify-end">
								<p class="award-form__label">置顶</p>
								<label
									for="document-is-pinned"
									class="doc-form__pin-field">
									<input
										id="document-is-pinned"
										name="isPinned"
										type="checkbox"
										class="doc-form__pin-check"
										value="true"
										checked={Boolean(
											modalDocument?.isPinned,
										)}
									/>
									<span
										class="doc-form__pin-hint doc-form__pin-hint--off"
										>时间排序</span
									>
									<span
										class="doc-form__pin-hint doc-form__pin-hint--on"
										>列表优先</span
									>
									<span
										class="doc-form__pin-rail"
										aria-hidden="true">
										<span class="doc-form__pin-knob"></span>
									</span>
								</label>
							</div>
						</div>

						<div
							class="award-form__row award-form__row--tags-cover">
							<div class="min-w-0">
								<label
									for="document-tags"
									class="award-form__label">标签</label
								>
								<input
									id="document-tags"
									name="tags"
									type="text"
									value={(modalDocument?.tags ?? []).join(
										", ",
									)}
									class="award-form__control"
									placeholder="用英文逗号分隔"
								/>
							</div>
							<div class="min-w-0">
								<div
									class="award-form__label mb-1.5 !flex min-h-[1.375rem] items-center justify-between gap-3">
									<label
										for="document-cover-image"
										class="mb-0 shrink-0 cursor-pointer leading-none">
										封面图
									</label>
									<span
										class="doc-cover-preview-tip group relative inline-flex shrink-0 items-center"
										tabindex="0"
										aria-label="悬停或聚焦此处查看封面预览">
										<span
											class="cursor-default border-b border-dotted border-primary-400/45 text-xs font-medium leading-none text-primary-300/95 hover:text-primary-200">
											预览
										</span>
										<span
											class="doc-cover-preview-tip__panel invisible absolute right-0 top-full z-[70] mt-1 w-max max-w-[min(calc(100vw-2rem),300px)] rounded-xl border border-white/15 bg-dark-900/98 p-2 opacity-0 shadow-[0_16px_40px_rgba(0,0,0,0.45)] backdrop-blur-md transition-opacity duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
											<div
												class="doc-cover-preview-tip__frame flex max-h-52 min-h-[5rem] w-[min(268px,82vw)] items-center justify-center rounded-lg bg-dark-950/95 p-1">
												<img
													id="document-cover-preview-img"
													alt=""
													class="doc-cover-preview-tip__img max-h-48 max-w-full object-contain"
													loading="lazy"
													decoding="async"
												/>
												<span
													id="document-cover-preview-empty"
													class="hidden px-3 py-6 text-center text-xs leading-relaxed text-gray-500">
													填写有效图片地址后，悬停「预览」查看，建议使用完整
													http(s) 链接
												</span>
											</div>
										</span>
									</span>
								</div>
								<input
									id="document-cover-image"
									name="coverImage"
									type="text"
									inputmode="url"
									autocomplete="off"
									value={modalDocument?.coverImage ?? ""}
									class="award-form__control"
									placeholder="https://example.com/cover.jpg"
								/>
								<p
									id="document-cover-preview-fallback"
									class="mt-2 hidden text-xs text-amber-200/90">
								</p>
							</div>
						</div>

						<div>
							<div
								class="doc-md-toolbar mb-1.5 flex flex-col gap-2.5 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
								<label
									for="document-body"
									class="doc-md-heading award-form__label !mb-0 min-w-0 shrink-0 sm:self-center"
									>正文</label
								>
								<div
									class="doc-md-segment w-full min-w-0 sm:max-w-none sm:shrink-0"
									data-doc-md-tabs
									role="tablist"
									aria-label="正文视图">
									<button
										type="button"
										data-doc-md-mode="edit"
										class="doc-md-tab is-active">
										编辑
									</button>
									<button
										type="button"
										data-doc-md-mode="preview"
										class="doc-md-tab">
										预览
									</button>
									<button
										type="button"
										data-doc-md-mode="split"
										class="doc-md-tab">
										分栏
									</button>
								</div>
							</div>
							<div
								data-doc-md-panels
								class="doc-md-panels doc-md-panels--split">
								<textarea
									id="document-body"
									name="body"
									rows="14"
									class="panel-scrollbar award-form__control document-body-editor award-form__textarea"
									placeholder="在此编写正文，右侧可查看渲染效果"
									data-doc-md-source
									>{modalDocument?.body ?? ""}</textarea
								>
								<div
									class="document-md-preview panel-scrollbar prose prose-invert prose-sm max-w-none"
									data-doc-md-preview
									aria-label="Markdown 渲染预览">
								</div>
							</div>
						</div>
					</div>

					<div
						class="shrink-0 border-t border-white/10 bg-dark-900/40 px-4 py-2.5 sm:px-5">
						<button
							type="submit"
							class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-primary-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary-600">
							<Icon
								name={shouldOpenEditModal
									? "ri:save-line"
									: "ri:file-add-line"}
								class="text-lg"
							/>
							{shouldOpenEditModal ? "保存" : "新建"}
						</button>
					</div>
				</form>
			</div>
		</div>

		<div
			id="document-delete-modal"
			class="fixed inset-0 z-[210] hidden items-center justify-center p-4">
			<button
				type="button"
				class="absolute inset-0 bg-dark-950/75 backdrop-blur-sm"
				data-close-delete-modal
				aria-label="关闭删除确认">
			</button>
			<div
				class="relative z-10 w-full max-w-md rounded-3xl border border-white/10 bg-dark-800/95 p-6 shadow-2xl shadow-black/40">
				<div class="flex items-start gap-4">
					<div
						class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-red-500/10 text-red-300">
						<Icon name="ri:delete-bin-line" class="text-xl" />
					</div>
					<div class="min-w-0 flex-1">
						<h2 class="text-xl font-semibold text-white">
							确认删除文章
						</h2>
						<p class="mt-2 text-sm leading-6 text-gray-400">
							删除后将无法恢复。将删除
							<span
								id="document-delete-title"
								class="text-gray-200"></span>
							，并同步移除对应数据记录。
						</p>
					</div>
				</div>
				<form
					method="POST"
					action="/api/admin/documents/delete"
					class="mt-6">
					<input
						id="document-delete-slug"
						type="hidden"
						name="slug"
						value=""
					/>
					<div class="flex justify-end gap-3">
						<button
							type="button"
							class="rounded-2xl border border-white/10 px-4 py-2 text-sm font-medium text-gray-300 transition-all hover:border-primary-400 hover:text-primary-300 focus:outline-none focus:ring-2 focus:ring-primary-500/20"
							data-close-delete-modal
							aria-label="取消删除">
							取消
						</button>
						<button
							type="submit"
							class="rounded-2xl bg-red-500 px-4 py-2 text-sm font-medium text-white transition-all hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-500/20">
							确定删除
						</button>
					</div>
				</form>
			</div>
		</div>
	</AdminShell>
</BaseLayout>

<style>
