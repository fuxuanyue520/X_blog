---
import PageLayout from "../layouts/PageLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Pagination from "../components/Pagination.astro";
import { paginatePublishedArticles } from "@/lib/articles";
import { Icon } from "astro-icon/components";

export const prerender = false;

const rawPage = Astro.params.page;
const requestedPage = rawPage ? Number(rawPage) : 1;
const page = await paginatePublishedArticles(requestedPage, 5);

if (rawPage && (!Number.isInteger(requestedPage) || requestedPage < 1)) {
	Astro.response.status = 404;
}

if (rawPage && requestedPage > page.lastPage) {
	Astro.response.status = 404;
}

const prevUrl =
	page.currentPage > 1
		? page.currentPage === 2
			? "/"
			: `/${page.currentPage - 1}`
		: undefined;
const nextUrl =
	page.currentPage < page.lastPage ? `/${page.currentPage + 1}` : undefined;
---

<PageLayout title="主页">
	<div class="mb-4 flex items-center justify-between">
		<h2
			class="text-xl lg:text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2"
		>
			<span class="w-1 h-5 bg-primary-500 rounded-full"></span>
			最新文章
		</h2>
		<span
			class="text-sm lg:text-base text-gray-500 dark:text-gray-400 hidden md:block"
		>
			共 {page.total} 篇文章
		</span>
	</div>

	<div class="space-y-4">
		{
			page.items.map((post, index) => (
				<div
					class="animate-fade-in-up"
					style={`animation-delay: ${index * 150}ms`}
				>
					<ArticleCard article={post} />
				</div>
			))
		}
	</div>

	<!-- New Pagination Component -->
	<Pagination
		currentPage={page.currentPage}
		lastPage={page.lastPage}
		prevUrl={prevUrl}
		nextUrl={nextUrl}
	/>
</PageLayout>
