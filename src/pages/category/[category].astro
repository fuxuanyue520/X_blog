---
import PageLayout from '../../layouts/PageLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { listPublishedArticles } from '@/lib/articles';
import { Icon } from 'astro-icon/components';

export const prerender = false;

const category = Astro.params.category ?? '';
const allPosts = await listPublishedArticles();
const posts = allPosts.filter((post) => post.data.category === category);

const categoryMap: Record<string, string> = {
    'tech': '技术',
    'essay': '随笔',
    'project': '项目',
    'other': '其他'
};

const displayCategory = categoryMap[category] || category;

if (!posts.length) {
    Astro.response.status = 404;
}
---

<PageLayout title={`分类: ${displayCategory} - 秋兰以为佩的博客`}>
    <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white flex items-center gap-2">
            <Icon name="ri:folder-line" class="text-primary-500" />
            分类: <span class="text-primary-500">{displayCategory}</span>
        </h2>
    </div>
    <div class="space-y-4">
        {posts.map(post => (
            <ArticleCard article={post} />
        ))}
    </div>
</PageLayout>
